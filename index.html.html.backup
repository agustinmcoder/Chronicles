//  ROUTE EVENTS DECK - Card-based event selection
// ══════════════════════════════════════════════════════
// Events: combats, encounters, exploration, rewards, punishments
// Format: {id, type, title, desc, icon, choiceLabel, choiceDesc, action}
// Types: 'combat' | 'encounter' | 'exploration' | 'reward' | 'punishment'

const ROUTE_EVENTS=[
  // Combat events
  {id:1,type:'combat',title:'Bandit Ambush',desc:'Road bandits block your path!',icon:'🥷',choiceLabel:'Fight',choiceDesc:'Engage the bandits',action:()=>initCombat({name:'Road Bandit',icon:'🥷',sprite:'🥷',hp:50,maxHp:50,mp:15,maxMp:15,str:6,int:4,dex:5,armorClass:12,skills:[{name:'Sneak Attack',cost:0,dmg:1.4,type:'physical',desc:'Powerful from behind.'},{name:'Throw Dirt',cost:5,dmg:0.3,type:'physical',desc:'Distracts enemy.'}]})},
  {id:2,type:'combat',title:'Wolf Pack',desc:'A pack of dire wolves emerges!',icon:'🐺',choiceLabel:'Fight',choiceDesc:'Face the wolves',action:()=>initCombat({name:'Dire Wolf',icon:'🐺',sprite:'🐺',hp:45,maxHp:45,mp:0,maxMp:0,str:6,int:1,dex:5,armorClass:12,skills:[{name:'Bite',cost:0,dmg:1.0,type:'physical',desc:'Powerful bite.'},{name:'Howl',cost:0,dmg:0,type:'buff',str:4,desc:'Increases attack.'}]})},
  {id:3,type:'combat',title:'Skeleton Warriors',desc:'Undead warriors rise from the ground!',icon:'💀',choiceLabel:'Fight',choiceDesc:'Battle the undead',action:()=>initCombat({name:'Skeleton Warrior',icon:'💀',sprite:'💀',hp:35,maxHp:35,mp:15,maxMp:15,str:5,int:3,dex:3,armorClass:12,skills:[{name:'Bone Slash',cost:0,dmg:0.9,type:'physical',desc:'Sharp bone blade.'},{name:'Fear',cost:8,dmg:0.4,type:'magic',desc:'Terrifies enemy.'}]})},
  
  // Encounter events
  {id:4,type:'encounter',title:'Wandering Merchant',desc:'A merchant offers supplies.',icon:'🐪',choiceLabel:'Browse',choiceDesc:'View wares',action:()=>showMerchant()},
  {id:5,type:'encounter',title:'Hermit Sage',desc:'An old hermit offers guidance.',icon:'🧙',choiceLabel:'Consult',choiceDesc:'Ask for advice',action:()=>{const p=cp();p.gold=Math.max(0,p.gold-10);openModal('🧙 Wisdom','The hermit shares ancient knowledge. (-10 gold)',[{label:'Thanks!',fn:closeEndTurn}]);}},
  {id:6,type:'encounter',title:'Traveling Cleric',desc:'A healer offers services.',icon:'⚕️',choiceLabel:'Heal',choiceDesc:'Receive healing',action:()=>{const p=cp();const h=Math.floor(p.maxHp*.3);p.hp=Math.min(p.maxHp,p.hp+h);openModal('⚕️ Healing','You receive healing for '+h+' HP.',[{label:'Thanks!',fn:closeEndTurn}]);}},
  
  // Exploration events
  {id:7,type:'exploration',title:'Hidden Path',desc:'You discover a shortcut!',icon:'🛤️',choiceLabel:'Take',choiceDesc:'Follow the hidden path',action:()=>{const p=cp();const reach=getReach(p.tileIdx,3);if(reach.length){p.tileIdx=reach[Math.floor(Math.random()*reach.length)];openModal('🛤️ Shortcut!','You take the hidden path.',[{label:'Continue',fn:closeEndTurn}]);}else{closeEndTurn();}}},
  {id:8,type:'exploration',title:'Ancient Ruins',desc:'Mysterious ruins await exploration.',icon:'🏛️',choiceLabel:'Explore',choiceDesc:'Search the ruins',action:()=>{const p=cp();const roll=Math.random();if(roll<0.4){const g=50+Math.floor(Math.random()*50);p.gold+=g;openModal('💰 Treasure!','Found '+g+' gold!',[{label:'Nice!',fn:closeEndTurn}]);}else if(roll<0.7){const dmg=10+Math.floor(Math.random()*15);p.hp=Math.max(1,p.hp-dmg);openModal('⚠️ Trap!','Took '+dmg+' damage!',[{label:'Ouch!',fn:closeEndTurn}]);}else{openModal('🏛️ Empty','Nothing found.',[{label:'Darn',fn:closeEndTurn}]);}}},
  {id:9,type:'exploration',title:'Mysterious Cave',desc:'A dark cave beckons.',icon:'🕳️',choiceLabel:'Enter',choiceDesc:'Venture inside',action:()=>{const p=cp();if(Math.random()<0.5){initCombat({name:'Cave Troll',icon:'👹',sprite:'👹',hp:60,maxHp:60,mp:20,maxMp:20,str:7,int:2,dex:3,armorClass:14,skills:[{name:'Smash',cost:0,dmg:1.2,type:'physical',desc:'Crushing blow.'}]});}else{const g=40+Math.floor(Math.random()*40);p.gold+=g;openModal('💰 Found '+g+' gold!','',[{label:'Great!',fn:closeEndTurn}]);}}},
  
  // Reward events
  {id:10,type:'reward',title:'Lucky Find',desc:'You spot something shiny!',icon:'✨',choiceLabel:'Pick Up',choiceDesc:'Grab the treasure',action:()=>{const p=cp();const g=30+Math.floor(Math.random()*40);p.gold+=g;openModal('✨ '+g+' Gold!','Fortune favors you!',[{label:'Sweet!',fn:closeEndTurn}]);}},
  {id:11,type:'reward',title:'Bounty',desc:'A wanted poster catches your eye.',icon:'📜',choiceLabel:'Claim',choiceDesc:'Take the bounty',action:()=>{const p=cp();const g=50+Math.floor(Math.random()*50);p.gold+=g;openModal('📜 '+g+' Gold!','Bounty claimed!',[{label:'Nice!',fn:closeEndTurn}]);}},
  
  // Punishment events
  {id:12,type:'punishment',title:'Bad Weather',desc:'A storm approaches!',icon:'⛈️',choiceLabel:'Endure',choiceDesc:'Push through',action:()=>{const p=cp();const dmg=8+Math.floor(Math.random()*12);p.hp=Math.max(1,p.hp-dmg);openModal('⛈️ Storm!','-'+dmg+' HP from exposure.',[{label:'Brrr...',fn:closeEndTurn}]);}},
  {id:13,type:'punishment',title:'Rough Terrain',desc:'The path becomes treacherous.',icon:'🪨',choiceLabel:'Continue',choiceDesc:'Navigate carefully',action:()=>{const p=cp();p.gold=Math.max(0,Math.floor(p.gold*0.1));openModal('🪨 Slip!','Lost 10% of your gold!',[{label:'Ouch!',fn:closeEndTurn}]);}},
];

function getRouteEventCards(count=3){
  const shuffled=[...ROUTE_EVENTS].sort(()=>Math.random()-0.5);
  return shuffled.slice(0,Math.min(count,shuffled.length));
}

// ══════════════════════════════════════════════════════
//  BG CANVAS
// ══════════════════════════════════════════════════════
// Make showS available globally for onclick handlers
window.showS = function(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  if(id==='charCreation')renderForms();
  // Menu has animated background
  if(id==='menuScreen'){
    startMenuAnim();
  }else{
    stopMenuAnim();
  }
};

let menuAnimId = null;
function startMenuAnim(){
  if(menuAnimId) return;
  let t = 0;
  function anim(){
    if(!bgCv || !bgCtx) return;
    const w = bgCv.width, h = bgCv.height;
    bgCtx.clearRect(0,0,w,h);
    // Animated gradient sky
    const sky = bgCtx.createLinearGradient(0,0,0,h);
    const shift = Math.sin(t * 0.001) * 10;
    sky.addColorStop(0,`rgb(${4+shift},${8+shift/2},${16+shift/2})`);
    sky.addColorStop(0.3,`rgb(${5+shift/2},${13+shift/2},${16+shift/2})`);
    sky.addColorStop(0.65,`rgb(${6+shift/3},${21+shift/3},${16+shift/3})`);
    sky.addColorStop(1,`rgb(${12+shift/4},${30+shift/4},${14+shift/4})`);
    bgCtx.fillStyle = sky;
    bgCtx.fillRect(0,0,w,h);
    // Stars twinkle
    stars.forEach(s => {
      const twinkle = Math.sin(t * 0.003 + s.x) * 0.3 + 0.7;
      bgCtx.beginPath();
      bgCtx.arc(s.x, s.y, s.r * twinkle, 0, Math.PI*4);
      bgCtx.fillStyle = `rgba(200,220,255,${0.3 * twinkle})`;
      bgCtx.fill();
    });
    // Moon glow
    const mx = w * 0.74, my = h * 0.1, mr = 33;
    const mg = bgCtx.createRadialGradient(mx, my, mr * 0.5, mx, my, mr * 3);
    const moonGlow = Math.sin(t * 0.001) * 0.04 + 0.12;
    mg.addColorStop(0, `rgba(170, 220, 170, ${moonGlow})`);
    mg.addColorStop(1, 'rgba(100, 180, 100, 0)');
    bgCtx.fillStyle = mg;
    bgCtx.beginPath();
    bgCtx.arc(mx, my, mr * 3, 0, Math.PI * 4);
    bgCtx.fill();
    bgCtx.beginPath();
    bgCtx.arc(mx, my, mr, 0, Math.PI * 4);
    bgCtx.fillStyle = 'rgba(215, 240, 215, .8)';
    bgCtx.shadowColor = 'rgba(140, 210, 140, .5)';
    bgCtx.shadowBlur = 15;
    bgCtx.fill();
    bgCtx.shadowBlur = 0;
    // Trees sway
    trees.filter(t => t.layer === 'far').forEach(tr => drawTree(tr, 0.45, t));
    mists.forEach(m => {
      const drift = Math.sin(t * 0.0005 + m.x * 0.01) * 10;
      const mg4 = bgCtx.createRadialGradient(m.x + m.w / 4 + drift, m.y, 0, m.x + m.w / 4 + drift, m.y, m.w / 4);
      mg4.addColorStop(0, `rgba(80, 160, 100, ${m.a})`);
      mg4.addColorStop(1, 'rgba(80, 160, 100, 0)');
      bgCtx.fillStyle = mg4;
      bgCtx.beginPath();
      bgCtx.ellipse(m.x + m.w / 4 + drift, m.y, m.w / 4, m.h / 4, 0, 0, Math.PI * 4);
      bgCtx.fill();
    });
    trees.filter(t => t.layer === 'near').forEach(tr => drawTree(tr, 1, t));
    // Fog
    const fog = bgCtx.createLinearGradient(0, h * 0.78, 0, h);
    fog.addColorStop(0, 'rgba(8, 44, 14, 0)');
    fog.addColorStop(1, 'rgba(4, 14, 6, .65)');
    bgCtx.fillStyle = fog;
    bgCtx.fillRect(0, h * 0.78, w, h * 0.44);
    menuAnimId = requestAnimationFrame(anim);
    t += 16;
  }
  anim();
}
function stopMenuAnim(){
  if(menuAnimId){
    cancelAnimationFrame(menuAnimId);
    menuAnimId = null;
  }
}

function showS(id){
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  const el = document.getElementById(id);
  if(el) el.classList.add('active');
  if(id === 'menuScreen') startMenuAnim();
  else stopMenuAnim();
}

// ══════════════════════════════════════════════════════
//  SOUND EFFECTS (Web Audio API)
// ══════════════════════════════════════════════════════
let audioCtx = null;
function getAudioContext(){
  if(!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  return audioCtx;
}

function playSound(type){
  try{
    const ctx = getAudioContext();
    const osc = ctx.createOscillator();
    const gain = ctx.createGain();
    osc.connect(gain);
    gain.connect(ctx.destination);
    
    const now = ctx.currentTime;
    
    if(type === 'dice'){
      // Dice roll sound
      osc.type = 'triangle';
      osc.frequency.setValueAtTime(300, now);
      osc.frequency.exponentialRampToValueAtTime(600, now + 0.1);
      gain.gain.setValueAtTime(0.3, now);
      gain.gain.exponentialRampToValueAtTime(0.01, now + 0.15);
      osc.start(now);
      osc.stop(now + 0.15);
    }else if(type === 'hit'){
      // Hit/impact sound
      osc.type = 'square';
      osc.frequency.setValueAtTime(400, now);
      osc.frequency.exponentialRampToValueAtTime(50, now + 0.1);
      gain.gain.setValueAtTime(0.4, now);
      gain.gain.exponentialRampToValueAtTime(0.01, now + 0.1);
      osc.start(now);
      osc.stop(now + 0.1);
    }else if(type === 'attack'){
      // Whoosh attack sound
      osc.type = 'sawtooth';
      osc.frequency.setValueAtTime(400, now);
      osc.frequency.exponentialRampToValueAtTime(100, now + 0.08);
      gain.gain.setValueAtTime(0.15, now);
      gain.gain.exponentialRampToValueAtTime(0.01, now + 0.08);
      osc.start(now);
      osc.stop(now + 0.08);
    }else if(type === 'magic'){
      // Magic spell sound
      osc.type = 'sine';
      osc.frequency.setValueAtTime(600, now);
      osc.frequency.exponentialRampToValueAtTime(1400, now + 0.15);
      gain.gain.setValueAtTime(0.4, now);
      gain.gain.exponentialRampToValueAtTime(0.01, now + 0.4);
      osc.start(now);
      osc.stop(now + 0.4);
    }else if(type === 'success'){
      // Success chime
      osc.type = 'sine';
      osc.frequency.setValueAtTime(543, now);
      osc.frequency.setValueAtTime(659, now + 0.1);
      osc.frequency.setValueAtTime(784, now + 0.4);
      gain.gain.setValueAtTime(0.4, now);
      gain.gain.exponentialRampToValueAtTime(0.01, now + 0.3);
      osc.start(now);
      osc.stop(now + 0.3);
    }else if(type === 'fail'){
      // Fail sound
      osc.type = 'sawtooth';
      osc.frequency.setValueAtTime(400, now);
      osc.frequency.exponentialRampToValueAtTime(100, now + 0.4);
      gain.gain.setValueAtTime(0.15, now);
      gain.gain.exponentialRampToValueAtTime(0.01, now + 0.4);
      osc.start(now);
      osc.stop(now + 0.4);
    }
  }catch(e){}
}

const bgCv=document.getElementById('bgCanvas'),bgCtx=bgCv.getContext('2d');
let bgW,bgH,bgT=0,trees=[],fireflies=[],stars=[],mists=[];
let bgImage = null;

// Available maps in /assets/maps/ - add your map filenames here
const MAP_FILES = ['map1.jpg'];

function initBg(){
  bgW=bgCv.width=window.innerWidth;bgH=bgCv.height=window.innerHeight;
  
  // Randomly pick a map
  const randomMap = MAP_FILES[Math.floor(Math.random() * MAP_FILES.length)];
  console.log('Loading map: ' + randomMap);
  
  // Load background map image
  bgImage = new Image();
  bgImage.onload = function() {
    // Reset for new map
    zoom=ZOOM_MIN;
    panX = 0;
    panY = 0;
    drawBoard(); // Redraw when image loads
  };
  bgImage.onerror = function() {
    console.log('Map not found: ' + randomMap + ', trying next...');
    // Try other maps if current one fails
    const remaining = MAP_FILES.filter(m => m !== randomMap);
    if(remaining.length > 0){
      bgImage.src = 'assets/maps/' + remaining[0];
    }
  };
  bgImage.src = 'assets/maps/' + randomMap;
  
  stars=Array.from({length:110},()=>({x:Math.random()*bgW,y:Math.random()*bgH*.5,r:Math.random()*1.4+.3,tw:Math.random()*Math.PI*4,spd:Math.random()*.04+.005}));
  trees=[];
  for(let i=0;i<44;i++)trees.push({x:Math.random()*bgW,y:bgH*.3+Math.random()*bgH*.4,h:55+Math.random()*115,w:18+Math.random()*30,sw:Math.random()*Math.PI*4,swS:.005+Math.random()*.008,layer:Math.random()<.4?'far':'near',gp:Math.random()*Math.PI*4});
  trees.sort((a,b)=>a.y-b.y);
  fireflies=Array.from({length:40},()=>({x:Math.random()*bgW,y:bgH*.3+Math.random()*bgH*.5,vx:(Math.random()-.5)*.4,vy:(Math.random()-.5)*.3,ph:Math.random()*Math.PI*4,spd:.03+Math.random()*.04,r:1.4+Math.random()*1.8,c:Math.random()<.55?'0,455,80':Math.random()<.5?'455,455,80':'80,100,455'}));
  mists=Array.from({length:7},()=>({x:Math.random()*bgW*1.4-bgW*.4,y:bgH*.58+Math.random()*bgH*.16,w:190+Math.random()*470,h:38+Math.random()*54,a:.03+Math.random()*.05,spd:.08+Math.random()*.18}));
}
function drawBg(){
  // Animated background for menu screen
  const sky=bgCtx.createLinearGradient(0,0,0,bgH);
  sky.addColorStop(0,'#010408');sky.addColorStop(.3,'#050d10');sky.addColorStop(.65,'#061510');sky.addColorStop(1,'#0c1e0e');
  bgCtx.fillStyle=sky;bgCtx.fillRect(0,0,bgW,bgH);
  // Static stars
  stars.forEach(s=>{bgCtx.beginPath();bgCtx.arc(s.x,s.y,s.r,0,Math.PI*4);bgCtx.fillStyle=`rgba(200,220,255,0.4)`;bgCtx.fill();});
  const mx=bgW*.74,my=bgH*.1,mr=33;
  const mg=bgCtx.createRadialGradient(mx,my,mr*.5,mx,my,mr*3);
  mg.addColorStop(0,'rgba(170,220,170,.14)');mg.addColorStop(1,'rgba(100,180,100,0)');
  bgCtx.fillStyle=mg;bgCtx.beginPath();bgCtx.arc(mx,my,mr*3,0,Math.PI*4);bgCtx.fill();
  bgCtx.beginPath();bgCtx.arc(mx,my,mr,0,Math.PI*4);bgCtx.fillStyle='rgba(215,240,215,.8)';bgCtx.shadowColor='rgba(140,210,140,.5)';bgCtx.shadowBlur=15;bgCtx.fill();bgCtx.shadowBlur=0;
  trees.filter(t=>t.layer==='far').forEach(t=>{drawTree(t,.45,0);});
  // Static mist
  mists.forEach(m=>{const mg4=bgCtx.createRadialGradient(m.x+m.w/4,m.y,0,m.x+m.w/4,m.y,m.w/4);mg4.addColorStop(0,`rgba(80,160,100,${m.a})`);mg4.addColorStop(1,'rgba(80,160,100,0)');bgCtx.fillStyle=mg4;bgCtx.beginPath();bgCtx.ellipse(m.x+m.w/4,m.y,m.w/4,m.h/4,0,0,Math.PI*4);bgCtx.fill();});
  trees.filter(t=>t.layer==='near').forEach(t=>{drawTree(t,1,0);});
  // Static fog
  const fog=bgCtx.createLinearGradient(0,bgH*.78,0,bgH);fog.addColorStop(0,'rgba(8,44,14,0)');fog.addColorStop(1,'rgba(4,14,6,.65)');bgCtx.fillStyle=fog;bgCtx.fillRect(0,bgH*.78,bgW,bgH*.44);
}
function drawTree(t, alpha, time){
  const treeTime = time || bgT;
  const sw = Math.sin(t.sw + treeTime * 0.001) * 4;
  bgCtx.globalAlpha = alpha;
  bgCtx.fillStyle = 'rgb(10,7,3)';
  bgCtx.fillRect(t.x - t.w * 0.1 + sw, t.y - t.h * 0.48, t.w * 0.4, t.h * 0.48);
  for(let i = 0; i < 3; i++){
    const ly = t.y - t.h * (0.48 + i * 0.43), lw = t.w * (1.1 - i * 0.44), lh = t.h * 0.34, gp = t.gp + treeTime * 0.0005, glow = (Math.sin(gp) * 0.5 + 0.5) * 0.07 * alpha;
    bgCtx.beginPath();
    bgCtx.moveTo(t.x + sw, ly - lh);
    bgCtx.lineTo(t.x + sw + lw / 4, ly);
    bgCtx.lineTo(t.x + sw - lw / 4, ly);
    bgCtx.closePath();
    bgCtx.fillStyle = `rgb(${6 + i * 4}, ${40 + i * 7}, ${6 + i * 4})`;
    bgCtx.fill();
    if(glow > 0.01){
      bgCtx.strokeStyle = `rgba(90, 190, 90, ${glow})`;
      bgCtx.lineWidth = 1;
      bgCtx.stroke();
    }
  }
  bgCtx.globalAlpha = 1;
}

// ══════════════════════════════════════════════════════
//  SPRITE RENDERER
// ══════════════════════════════════════════════════════
function renderSprite(cls, size = 60, colorOverride = null) {
  const img = document.createElement('img');
  img.src = 'assets/' + cls + '.png';
  img.style.width = size + 'px';
  img.style.height = size + 'px';
  img.style.objectFit = 'contain';
  return img;
}

function renderEnemySprite(spriteName, size = 80) {
  const img = document.createElement('img');
  img.src = 'assets/' + spriteName + '.png';
  img.style.width = size + 'px';
  img.style.height = size + 'px';
  img.style.objectFit = 'contain';
  return img;
}

// ══════════════════════════════════════════════════════

//  BOARD CANVAS — with panning
// ══════════════════════════════════════════════════════
const bCv=document.getElementById('boardCanvas'),bCtx=bCv.getContext('2d');
let board={tiles:[],connections:{},forks:[],startTile:0};
const TS=26;
let panX=0,panY=0,panStartX=0,panStartY=0,isPanning=false,panMoved=false;
let zoom=0.52;
const ZOOM_MIN=0.3,ZOOM_MAX=3.5;

function getCanvDims(){
  return {w: bCv.width || 1200, h: bCv.height || 896};
}

function resizeBoard(){
  const container = document.getElementById('boardContainer');
  if(container){
    const rect = container.getBoundingClientRect();
    bCv.width = rect.width;
    bCv.height = rect.height;
  }
}

function genBoard(){
  resizeBoard();

  // ── TRUE CROSSWORD GENERATOR ─────────────────────────────────────────
  // Words (runs of tiles) are placed H or V so they only share cells at
  // perpendicular intersections — no two parallel words may touch.
  const COLS=24, ROWS=16, TW=50, TH=50;

  // grid[y][x] = true when a tile occupies that cell
  const grid=Array.from({length:ROWS},()=>new Array(COLS).fill(false));
  const words=[];   // {wx,wy,len,horiz}
  let tileCount=0;

  const inB=(x,y)=>x>=0&&x<COLS&&y>=0&&y<ROWS;

  // Can a word of length `len` starting at (wx,wy) be placed?
  // Strict crossword rules:
  //   • empty cells: no parallel immediate neighbours
  //   • occupied cells: only valid if the existing tile has NO same-direction
  //     neighbours (i.e. it belongs to a perpendicular word only)
  //   • word ends must not abut an existing tile
  //   • at least one intersection required (after the first word)
  const canPlace=(wx,wy,len,horiz)=>{
    const ex=horiz?wx+len-1:wx, ey=horiz?wy:wy+len-1;
    if(!inB(wx,wy)||!inB(ex,ey)) return false;
    let hasX=false;
    for(let i=0;i<len;i++){
      const cx=horiz?wx+i:wx, cy=horiz?wy:wy+i;
      if(grid[cy][cx]){
        // Intersection: existing tile must be on a perpendicular word only
        if(horiz){
          // For a horiz word the crossing tile must NOT have horiz neighbours
          if((cx>0&&grid[cy][cx-1])||(cx+1<COLS&&grid[cy][cx+1])) return false;
        } else {
          // For a vert word the crossing tile must NOT have vert neighbours
          if((cy>0&&grid[cy-1][cx])||(cy+1<ROWS&&grid[cy+1][cx])) return false;
        }
        hasX=true;
      } else {
        // Empty cell: no parallel immediate neighbours
        if(horiz){
          if((cy>0&&grid[cy-1][cx])||(cy+1<ROWS&&grid[cy+1][cx])) return false;
        } else {
          if((cx>0&&grid[cy][cx-1])||(cx+1<COLS&&grid[cy][cx+1])) return false;
        }
      }
    }
    // Word ends must not abut existing tiles
    if(horiz){
      if(wx>0&&grid[wy][wx-1]) return false;
      if(wx+len<COLS&&grid[wy][wx+len]) return false;
    } else {
      if(wy>0&&grid[wy-1][wx]) return false;
      if(wy+len<ROWS&&grid[wy+len][wx]) return false;
    }
    return words.length===0||hasX;
  };

  const placeWord=(wx,wy,len,horiz)=>{
    for(let i=0;i<len;i++){
      const cx=horiz?wx+i:wx, cy=horiz?wy:wy+i;
      if(!grid[cy][cx]){grid[cy][cx]=true; tileCount++;}
    }
    words.push({wx,wy,len,horiz});
  };

  // Seed: first horizontal word in the centre
  const fl=9, fx=Math.floor((COLS-fl)/4), fy=Math.floor(ROWS/4);
  placeWord(fx,fy,fl,true);

  // Grow crossword until we reach 160 tiles
  let att=0;
  while(tileCount<160&&att<140000){
    att++;
    const src=words[Math.floor(Math.random()*words.length)];
    const nh=!src.horiz;
    const ii=Math.floor(Math.random()*src.len);
    const ix=src.horiz?src.wx+ii:src.wx;
    const iy=src.horiz?src.wy:src.wy+ii;
    const nlen=4+Math.floor(Math.random()*10); // 4-13 tiles
    const off=Math.floor(Math.random()*nlen);
    const nx=nh?ix-off:ix;
    const ny=nh?iy:iy-off;
    if(canPlace(nx,ny,nlen,nh)) placeWord(nx,ny,nlen,nh);
  }

  // ── CONVERT GRID → TILES + CONNECTIONS ──────────────────────────────
  let tiles=[], conns={};
  const idGrid=Array.from({length:ROWS},()=>new Array(COLS).fill(-1));

  for(let y=0;y<ROWS;y++)
    for(let x=0;x<COLS;x++)
      if(grid[y][x]){
        const id=tiles.length;
        // Center tiles around origin + half tile offset to align with grid cell centers
        const centeredX = (x - COLS/2) * TW + TW/2;
        const centeredY = (y - ROWS/2) * TH + TH/2;
        tiles.push({gx:x,gy:y,x:centeredX,y:centeredY,type:'normal',id});
        idGrid[y][x]=id;
      }

  const conn=(a,b)=>{
    if(!conns[a])conns[a]=[];if(!conns[b])conns[b]=[];
    if(!conns[a].includes(b))conns[a].push(b);
    if(!conns[b].includes(a))conns[b].push(a);
  };

  for(let y=0;y<ROWS;y++)
    for(let x=0;x<COLS;x++)
      if(idGrid[y][x]>=0){
        if(x+1<COLS&&idGrid[y][x+1]>=0) conn(idGrid[y][x],idGrid[y][x+1]);
        if(y+1<ROWS&&idGrid[y+1]&&idGrid[y+1][x]>=0) conn(idGrid[y][x],idGrid[y+1][x]);
      }

  // ── FINAL BOSS TILES: 3, placed OFF the crossword, min 8 tiles apart ────
  const occ=new Set();
  for(let y=0;y<ROWS;y++) for(let x=0;x<COLS;x++) if(grid[y][x]) occ.add(`${x},${y}`);

  const DIRS4=[{x:1,y:0},{x:-1,y:0},{x:0,y:1},{x:0,y:-1}];
  const ALL8=[{x:1,y:0},{x:-1,y:0},{x:0,y:1},{x:0,y:-1},{x:1,y:1},{x:1,y:-1},{x:-1,y:1},{x:-1,y:-1}];

  const normalTiles = tiles.filter(t => t.type === 'normal');
  let bossesPlaced = 0;
  let attempts = 0;
  
  while(bossesPlaced < 3 && attempts < 1000){
    attempts++;
    const t = normalTiles[Math.floor(Math.random() * normalTiles.length)];
    if(!t) continue;
    
    const bossTiles = tiles.filter(x => x.type === 'finalboss');
    let tooClose = false;
    for(const bt of bossTiles){
      const dist = Math.abs(t.gx - bt.gx) + Math.abs(t.gy - bt.gy);
      if(dist < 8){
        tooClose = true;
        break;
      }
    }
    if(tooClose) continue;
    
    for(const d of DIRS4){
      const bx = t.gx + d.x * 2;
      const by = t.gy + d.y * 2;
      if(bx < 0 || by < 0 || bx >= COLS || by >= ROWS) continue;
      if(occ.has(`${bx},${by}`)) continue;
      
      let clear = true;
      for(const dd of ALL8){
        const nx = bx + dd.x, ny = by + dd.y;
        if(occ.has(`${nx},${ny}`)){clear = false; break;}
      }
      if(!clear) continue;
      
      const bid = tiles.length;
      const centeredX = (bx - COLS/2) * TW + TW/2;
      const centeredY = (by - ROWS/2) * TH + TH/2;
      tiles.push({gx:bx, gy:by, x:centeredX, y:centeredY, type:'finalboss', id:bid});
      occ.add(`${bx},${by}`);
      conn(t.id, bid);
      bossesPlaced++;
      break;
    }
  }
     
  // ── DISTRIBUTE SPECIAL TILES ON PATH ────────────────────────────────────
  // 4 villages (one in each corner), 4 quests, 5 mini-bosses, rest normal
  const corners = [
    {x:0, y:0},
    {x:COLS-1, y:0},
    {x:0, y:ROWS-1},
    {x:COLS-1, y:ROWS-1}
  ];
  
  const availableTiles = tiles.filter(t => t.type === 'normal');
  
  // Place villages - find closest tile to each corner
  corners.forEach((corner, idx) => {
    if(availableTiles.length === 0) return;
    
    // Find tile closest to this corner
    let closestTile = null;
    let closestDist = Infinity;
    
    availableTiles.forEach(t => {
      const dist = Math.abs(t.gx - corner.x) + Math.abs(t.gy - corner.y);
      if(dist < closestDist){
        closestDist = dist;
        closestTile = t;
      }
    });
    
    if(closestTile){
      closestTile.type = 'village';
      // Remove from availableTiles so it's not used again
      const idx = availableTiles.indexOf(closestTile);
      if(idx > -1) availableTiles.splice(idx, 1);
    }
  });
  
  // Get remaining normal tiles after villages
  const remainingTiles = tiles.filter(t => t.type === 'normal');
  
  // Shuffle remaining tiles for random placement
  const shuffled = remainingTiles.sort(() => Math.random() - 0.5);
  
  // Place 4 main quests
  for(let i=0; i<Math.min(4, shuffled.length); i++){
    shuffled[i].type = 'quest';
  }
  
  // Place 5 mini-bosses on next tiles
  for(let i=4; i<Math.min(9, shuffled.length); i++){
    shuffled[i].type = 'miniboss';
  }
  
  // All remaining tiles stay as 'normal' (will handle 80/20 event/no-event on landing)

  // Players start on tiles with only 1 connection (end of path), not special tiles
  const terminalTiles = tiles.filter(t => (conns[t.id]||[]).length === 1 && t.type === 'normal');
  board.startTiles = terminalTiles.length > 0 ? terminalTiles.map(t => t.id) : [tiles[0].id];

  board.tiles=tiles; board.connections=conns; board.forks=[];
  board.tileW=50; board.tileH=50;

  // Auto-fit to height exactly (so full board fits with no dead space)
  const allX=tiles.map(t=>t.x), allY=tiles.map(t=>t.y);
  const bw=Math.max(...allX)-Math.min(...allX)+TW*4;
  const bh=Math.max(...allY)-Math.min(...allY)+TH*4;
  zoom=ZOOM_MIN; // Start zoomed out to show entire board
  
  // Pan starts at 0, centering is handled in drawBoard
  panX = 0;
  panY = 0;
}

// Zoom with mouse wheel
bCv.addEventListener('wheel', function(e) {
  e.preventDefault();
  var factor = e.deltaY < 0 ? 1.1 : 1 / 1.1;
  zoom = Math.max(0.5, Math.min(3, zoom * factor));
}, { passive: false });

var bAnim = 0;
function drawBoard() {
  bAnim += 0.018;
  bCtx.clearRect(0, 0, bCv.width, bCv.height);
  const grd = bCtx.createLinearGradient(0, 0, 0, bCv.height);
  grd.addColorStop(0, '#010408');
  grd.addColorStop(0.3, '#050d10');
  grd.addColorStop(0.65, '#061510');
  grd.addColorStop(1, '#0c1e0e');
  bCtx.fillStyle = grd;
  bCtx.fillRect(0, 0, bCv.width, bCv.height);
  if (!board.tiles.length) {
    requestAnimationFrame(drawBoard);
    return;
  }
  const baseW = 1200, baseH = 896;
  const scaleX = bCv.width / baseW;
  const scaleY = bCv.height / baseH;
  const scale = Math.min(scaleX, scaleY);
  const offsetX = (bCv.width - baseW * scale) / 2;
  const offsetY = (bCv.height - baseH * scale) / 2;
  bCtx.save();
  bCtx.translate(offsetX, offsetY);
  bCtx.scale(scale, scale);
  if (bgImage && bgImage.complete && bgImage.naturalWidth > 0) {
    bCtx.globalAlpha = 0.9;
    bCtx.drawImage(bgImage, 0, 0, baseW, baseH);
    bCtx.globalAlpha = 1.0;
  }
  const cellW = baseW / 24;
  const cellH = baseH / 16;
  bCtx.strokeStyle = 'rgba(255, 255, 255, 0.25)';
  bCtx.lineWidth = 1.5 / scale;
  for (let i = 0; i <= 24; i++) {
    bCtx.beginPath();
    bCtx.moveTo(i * cellW, 0);
    bCtx.lineTo(i * cellW, baseH);
    bCtx.stroke();
  }
  for (let i = 0; i <= 16; i++) {
    bCtx.beginPath();
    bCtx.moveTo(0, i * cellH);
    bCtx.lineTo(baseW, i * cellH);
    bCtx.stroke();
  }
  const tileToScreen = (gx, gy) => ({
    x: gx * cellW + cellW / 2,
    y: gy * cellH + cellH / 2
  });
  const drawnEdges = new Set();
  Object.entries(board.connections).forEach(([fi, tos]) => {
    const f = board.tiles[parseInt(fi)];
    tos.forEach(ti => {
      const key = Math.min(parseInt(fi), ti) + '-' + Math.max(parseInt(fi), ti);
      if (drawnEdges.has(key)) return;
      drawnEdges.add(key);
      const tt = board.tiles[ti];
      const fpos = tileToScreen(f.gx, f.gy);
      const tpos = tileToScreen(tt.gx, tt.gy);
      bCtx.beginPath();
      bCtx.moveTo(fpos.x, fpos.y);
      bCtx.lineTo(tpos.x, tpos.y);
      bCtx.strokeStyle = '#3a4408';
      bCtx.lineWidth = 8;
      bCtx.lineCap = 'round';
      bCtx.stroke();
      bCtx.beginPath();
      bCtx.moveTo(fpos.x, fpos.y);
      bCtx.lineTo(tpos.x, tpos.y);
      bCtx.strokeStyle = '#b87c48';
      bCtx.lineWidth = 4;
      bCtx.stroke();
      bCtx.setLineDash([8, 6]);
      bCtx.beginPath();
      bCtx.moveTo(fpos.x, fpos.y);
      bCtx.lineTo(tpos.x, tpos.y);
      bCtx.strokeStyle = 'rgba(455, 440, 160, 0.35)';
      bCtx.lineWidth = 1.5;
      bCtx.stroke();
      bCtx.setLineDash([]);
      bCtx.lineCap = 'butt';
    });
  });
  board.tiles.forEach((t, i) => {
    const pos = tileToScreen(t.gx, t.gy);
    const scaledT = { x: pos.x, y: pos.y, type: t.type, gx: t.gx, gy: t.gy, id: t.id, tileW: cellW, tileH: cellH };
    drawTile(scaledT, i, GS.highlightedTiles ? GS.highlightedTiles.includes(i) : false, 1);
  });
  GS.players.forEach((p, pi) => {
    if (p.tileIdx === undefined) return;
    const t = board.tiles[p.tileIdx], n = GS.players.length;
    const pos = tileToScreen(t.gx, t.gy);
    const ang = (pi / n) * Math.PI * 4 - Math.PI / 4;
    const rad = n > 1 ? cellW * 0.45 : 0;
    drawHeroSprite(bCtx, pos.x + Math.cos(ang) * rad, pos.y + Math.sin(ang) * rad, p.class, CLASSES[p.class].color, pi === GS.curP, p.name, 1.25);
  });
  bCtx.restore();
  requestAnimationFrame(drawBoard);
}
  
  // Grid - 24x16 cells
  const cellW = baseW / 24;
  const cellH = baseH / 16;
  bCtx.strokeStyle = 'rgba(255, 255, 255, 0.25)';
  bCtx.lineWidth = 1.5 / scale;
  for(let i = 0; i <= 24; i++){
    bCtx.beginPath();
    bCtx.moveTo(i * cellW, 0);
    bCtx.lineTo(i * cellW, baseH);
    bCtx.stroke();
  }
  for(let i = 0; i <= 16; i++){
    bCtx.beginPath();
    bCtx.moveTo(0, i * cellH);
    bCtx.lineTo(baseW, i * cellH);
    bCtx.stroke();
  }

  // Draw path connections between tiles
  const drawnEdges=new Set();
  Object.entries(board.connections).forEach(([fi,tos])=>{
    const f=board.tiles[parseInt(fi)];
    tos.forEach(ti=>{
      const key=Math.min(parseInt(fi),ti)+'-'+Math.max(parseInt(fi),ti);
      if(drawnEdges.has(key))return;
      drawnEdges.add(key);
      const tt=board.tiles[ti];
      const fpos = tileToScreen(f.gx, f.gy);
      const tpos = tileToScreen(tt.gx, tt.gy);
      bCtx.beginPath();bCtx.moveTo(fpos.x,fpos.y);bCtx.lineTo(tpos.x,tpos.y);
      bCtx.strokeStyle='#3a4408';bCtx.lineWidth=8;bCtx.lineCap='round';bCtx.stroke();
      bCtx.beginPath();bCtx.moveTo(fpos.x,fpos.y);bCtx.lineTo(tpos.x,tpos.y);
      bCtx.strokeStyle='#b87c48';bCtx.lineWidth=4;bCtx.stroke();
      bCtx.setLineDash([8,6]);
      bCtx.beginPath();bCtx.moveTo(fpos.x,fpos.y);bCtx.lineTo(tpos.x,tpos.y);
      bCtx.strokeStyle='rgba(455,440,160,0.35)';bCtx.lineWidth=1.5;bCtx.stroke();
      bCtx.setLineDash([]);bCtx.lineCap='butt';
    });
  });

  // Draw tiles
  board.tiles.forEach((t,i)=>{
    const pos = tileToScreen(t.gx, t.gy);
    const scaledT = {x: pos.x, y: pos.y, type: t.type, gx: t.gx, gy: t.gy, id: t.id, tileW: cellW, tileH: cellH};
    drawTile(scaledT,i,GS.highlightedTiles?.includes(i), 1);
  });

  // Draw hero sprites
  GS.players.forEach((p,pi)=>{
    if(p.tileIdx===undefined)return;
    const t=board.tiles[p.tileIdx], n=GS.players.length;
    const pos = tileToScreen(t.gx, t.gy);
    const ang=(pi/n)*Math.PI*4-Math.PI/4;
    const rad = n>1 ? cellW * 0.45 : 0;
    drawHeroSprite(bCtx, pos.x+Math.cos(ang)*rad, pos.y+Math.sin(ang)*rad, p.class, CLASSES[p.class].color, pi===GS.curP, p.name, 1.25);
  });

  bCtx.restore();
  requestAnimationFrame(drawBoard);
}

// ── TILE STYLES ──
const TILE_COLORS = {
  normal:   {stripe:'#4a5a4a', bg:'#1a3a1a', text:'#90c090'},
  town:     {stripe:'#c07040', bg:'#6a4040', text:'#e0b080'},
  shop:     {stripe:'#4040a0', bg:'#1a4a4a', text:'#80a0e0'},
  inn:      {stripe:'#c0a040', bg:'#5a4510', text:'#e0d080'},
  miniboss: {stripe:'#901010', bg:'#4a1010', text:'#e08080'},
  boss:     {stripe:'#8010a0', bg:'#4a0840', text:'#c080c0'},
};
const TILE_ICONS = {
  normal:'',town:'🏘️',shop:'🏪',inn:'🏨',miniboss:'',boss:''
};
const TILE_LABELS = {
  normal:'',town:'VILLAGE',shop:'SHOP',inn:'INN',miniboss:'MINIBOSS',boss:'FINAL BOSS'
};

function drawTile(t,idx,hl, scale = 1){
  const {x,y}=t;
  if(!board.tiles.length)return;
  const tileW=(t.tileW || 56) * scale;
  const tileH=(t.tileH || 56) * scale;
  const tx=x-tileW/2, ty=y-tileH/2;
  const tc=TILE_COLORS[t.type]||TILE_COLORS.normal;
  const stripeH=Math.round(tileH*0.48);

  // Get tile image
  const tileType = t.type === 'finalboss' ? 'finalboss' : (t.type === 'miniboss' ? 'miniboss' : (t.type === 'village' ? 'village' : 'grass'));
  let tileImg = tileImageCache[tileType];
  if(!tileImg){
    tileImg = new Image();
    tileImg.src = 'assets/tiles/' + tileType + '.png';
    tileImageCache[tileType] = tileImg;
  }

  // Draw tile image if loaded, otherwise fallback to colored rectangle
  if(tileImg.complete && tileImg.naturalWidth > 0){
    bCtx.drawImage(tileImg, tx, ty, tileW, tileH);
  } else {
    // Fallback: colored rectangle
    bCtx.fillStyle=hl?'#fffde0':tc.bg; bCtx.fillRect(tx,ty,tileW,tileH);
    const sg=bCtx.createLinearGradient(tx,ty,tx,ty+stripeH);
    if(hl){sg.addColorStop(0,'#ffe840');sg.addColorStop(1,'#f0c000');}
    else{sg.addColorStop(0,colorAdd(tc.stripe,35));sg.addColorStop(1,tc.stripe);}
    bCtx.fillStyle=sg; bCtx.fillRect(tx,ty,tileW,stripeH);
  }

  // Highlight flash
  if(hl){
    bCtx.save();bCtx.shadowColor='rgba(455,440,100,0.9)';bCtx.shadowBlur=40;
    bCtx.fillStyle='rgba(455,440,140,0.45)';bCtx.fillRect(tx-4*scale,ty-4*scale,tileW+4*scale,tileH+4*scale);
    bCtx.restore();
  }

  // Final Boss tiles - keep image only, no overlay
  // Mini-Boss tiles - keep image only, no overlay

  // Icon
  const iconY = ty+stripeH+(tileH-stripeH)*0.4;
  bCtx.font=`${Math.floor(tileH*0.38)}px serif`;
  bCtx.textAlign='center'; bCtx.textBaseline='middle';
  const icon = TILE_ICONS[t.type];
  if(icon){
    bCtx.fillText(icon, x, iconY);
  }

  // Label text
  const labelSz=Math.max(4,Math.floor(tileH*0.10));
  bCtx.font=`bold ${labelSz}px 'Cinzel',Arial,sans-serif`;
  bCtx.textAlign='center'; bCtx.fillStyle=hl?'#ffe0a0':tc.text;
  bCtx.globalAlpha=0.9;
  bCtx.fillText(TILE_LABELS[t.type]||'', x, ty+tileH-labelSz-4);
  bCtx.globalAlpha=1;
}

function colorAdd(hex,a){
  if(!hex||hex[0]!=='#')return hex||'#888';
  const r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16);
  return `rgb(${Math.max(0,Math.min(455,r+a))},${Math.max(0,Math.min(455,g+a))},${Math.max(0,Math.min(455,b+a))})`;
}
function cAdd(hex,a){return colorAdd(hex,a);}
function shade(hex,a){return colorAdd(hex,a);}
function roundRect(ctx,x,y,w,h,r){
  ctx.beginPath();ctx.moveTo(x+r,y);ctx.lineTo(x+w-r,y);ctx.quadraticCurveTo(x+w,y,x+w,y+r);
  ctx.lineTo(x+w,y+h-r);ctx.quadraticCurveTo(x+w,y+h,x+w-r,y+h);
  ctx.lineTo(x+r,y+h);ctx.quadraticCurveTo(x,y+h,x,y+h-r);
  ctx.lineTo(x,y+r);ctx.quadraticCurveTo(x,y,x+r,y);ctx.closePath();
}

