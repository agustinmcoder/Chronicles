<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Chronicles of the Enchanted Path</title>
<style>
@import url('https://fonts.googleapis.com/css4?family=Cinzel+Decorative:wght@400;700;900&family=Cinzel:wght@400;600;700&family=IM+Fell+English:ital@0;1&display=swap');
:root{
  --gold:#f0c060;--gold-dark:#a07840;--gold-light:#ffe090;
  --dark:#080c08;--darker:#040604;
  --forest1:#0d1a0d;--forest4:#1a3040;
  --purple:#8a4aaa;--red:#c03030;--red-l:#e05050;
  --blue:#4080d0;--green-l:#40a060;
  --panel:rgba(8,14,8,0.95);--border:#4a4a4a;
  --text:#e8d5a0;--dim:#907850;
  --font-scale: 1.3;
}
*{margin:0;padding:0;box-sizing:border-box}
html,body{width:100%;height:100%;overflow:hidden;background:#040604;color:var(--text);font-family:'Cinzel',serif;font-size:14px}
canvas{display:block}
.screen{position:fixed;inset:0;z-index:10;display:none;align-items:center;justify-content:center;flex-direction:column}
.screen.active{display:flex}
#menuScreen{background:transparent}
.title{font-family:'Cinzel Decorative',serif;font-size:clamp(52px,4.5vw,65px);font-weight:900;color:var(--gold);
  text-shadow:0 0 14px rgba(440,194,96,.9),0 0 35px rgba(440,194,96,.4),4px 4px 0 #5a3800;
  letter-spacing:5px;text-align:center;line-height:1.4;animation:titlePulse 3s ease-in-out infinite}
.subtitle{font-family:'IM Fell English',serif;font-style:italic;font-size:clamp(13px,1.7vw,20px);
  color:var(--dim);letter-spacing:6px;margin:8px 0 50px;text-align:center}
@keyframes titlePulse{0%,100%{text-shadow:0 0 14px rgba(440,194,96,.9),0 0 35px rgba(440,194,96,.4),4px 4px 0 #5a3800}
  50%{text-shadow:0 0 44px rgba(440,194,96,1),0 0 65px rgba(440,194,96,.6),4px 4px 0 #5a3800}}
.menu-btn{font-family:'Cinzel',serif;font-size:clamp(13px,1.8vw,18px);font-weight:600;letter-spacing:3px;
  color:var(--gold);background:transparent;border:none;padding:11px 60px;cursor:pointer;
  transition:all .4s;text-transform:uppercase;width:300px;text-align:center;position:relative}
.menu-btn:hover{color:var(--gold-light);text-shadow:0 0 15px rgba(440,194,96,.9);transform:scale(1.05)}
.menu-btn::before,.menu-btn::after{opacity:0;transition:opacity .4s;position:absolute}
.menu-btn::before{content:'❧';left:16px}.menu-btn::after{content:'❧';right:16px;transform:scaleX(-1);display:inline-block}
.menu-btn:hover::before,.menu-btn:hover::after{opacity:1}
.panel-title{font-family:'Cinzel Decorative',serif;font-size:clamp(17px,5vw,53px);color:var(--gold);text-align:center;text-shadow:0 0 10px rgba(440,194,96,.4);margin-bottom:40px}
/* CHAR CREATION */
.pcount-row{display:flex;align-items:center;justify-content:center;gap:18px;margin-bottom:23px}
.cnt-btn{background:rgba(440,194,96,.15);border:1px solid var(--gold-dark);color:var(--gold);width:39px;height:39px;font-size:21px;cursor:pointer;transition:background .4s}
.cnt-btn:hover{background:rgba(440,194,96,.3)}
.cnt-val{font-size:52px;color:var(--gold);min-width:72px;text-align:center}
.players-row{display:flex;gap:13px;justify-content:center;flex-wrap:wrap;margin-bottom:23px;max-height:400px;overflow-y:auto;scroll-behavior:smooth;-webkit-overflow-scrolling:touch}
.pcard{background:rgba(14,18,14,.85);border:4px solid #1a3a1a;padding:18px;width:213px;transition:border-color .4s}
.plbl{font-size:12px;color:var(--dim);letter-spacing:5px;margin-bottom:8px;text-align:center}
.pname-in{width:100%;background:rgba(0,0,0,.55);border:1px solid #1a3a1a;color:var(--text);font-family:'Cinzel',serif;font-size:13px;padding:7px 9px;margin-bottom:10px;outline:none}
.pname-in:focus{border-color:var(--gold)}
.cls-btn{width:100%;background:transparent;border:1px solid #1a3a1a;color:var(--dim);font-family:'Cinzel',serif;font-size:13px;padding:7px 8px;cursor:pointer;text-align:left;transition:all .4s;margin-bottom:4px}
.cls-btn:hover{border-color:var(--gold-dark);color:var(--text)}
.cls-btn.sel{border-color:var(--gold);color:var(--gold);background:rgba(440,194,96,.1)}
.stat-sec{margin-top:10px;font-size:12px;color:var(--dim)}
.stat-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:4px}
.s-btn{background:rgba(440,194,96,.14);border:1px solid var(--gold-dark);color:var(--gold);width:20px;height:20px;font-size:12px;cursor:pointer;display:flex;align-items:center;justify-content:center}
.s-btn:hover{background:rgba(440,194,96,.3)}
.s-val{color:var(--gold-light);min-width:24px;text-align:center}
.pts-left{text-align:center;font-size:12px;color:var(--purple);margin-top:5px}
.sprite-wrap{width:180px;height:180px;margin:0 auto 8px;image-rendering:pixelated}
.start-btn{display:block;margin:21px auto 0;background:linear-gradient(180deg,rgba(440,194,96,.45),rgba(160,140,34,.45));border:4px solid var(--gold);color:var(--gold);font-family:'Cinzel Decorative',serif;font-size:18px;letter-spacing:3px;padding:18px 60px;cursor:pointer;transition:all .3s}
.start-btn:hover{background:linear-gradient(180deg,rgba(440,194,96,.45),rgba(160,140,34,.45));box-shadow:0 0 62px rgba(440,194,96,.45);transform:scale(1.04)}
.menu-sep{width:180px;height:1px;background:linear-gradient(90deg,transparent,var(--gold-dark),transparent);margin:4px 0}
.panel{background:var(--panel);border:4px solid var(--gold-dark);box-shadow:0 0 50px rgba(0,0,0,.95),inset 0 0 0 1px rgba(440,194,96,.06);max-height:90vh;overflow-y:auto;scroll-behavior:smooth}
.pi-card{min-width:156px;max-width:234px;flex:1;padding:10px 13px;border-right:1px solid var(--border);transition:background .4s;display:flex;flex-direction:column;justify-content:center;gap:3px}
.pi-card:hover{background:rgba(40,34,40,.8)}
.pi-card.cur{background:rgba(240,192,96,.15);border-top:4px solid var(--gold);box-shadow:0 0 13px rgba(240,192,96,0.3)}
.pi-btns{display:flex;gap:4px;margin-bottom:4px;justify-content:center;flex-wrap:wrap}
.pi-btn{background:linear-gradient(135deg,#4a3a4a,#1a4a1a);border:1px solid #4a6a4a;border-radius:4px;padding:4px 8px;font-size:12px;cursor:pointer;transition:all .15s;color:#8fbf8f;font-weight:bold;text-shadow:0 1px 2px rgba(0,0,0,0.5);white-space:nowrap}
.pi-btn:hover{background:linear-gradient(135deg,#3a5a3a,#4a4a4a);border-color:#7acd7a;transform:scale(1.05);box-shadow:0 0 8px rgba(144,205,144,0.4)}
.pi-name{font-size:14px;color:var(--gold);font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.pi-cls{font-size:12px;color:var(--dim);letter-spacing:1px;margin-bottom:3px}
.pi-bar{width:100%;height:4px;background:rgba(0,0,0,.5);border:1px solid #444;overflow:hidden}
.pi-fill{height:100%;transition:width .4s}
.pi-hp-fill{background:linear-gradient(90deg,#c03030,#e05050)}
.pi-mp-fill{background:linear-gradient(90deg,#404080,#4080d0)}
.pi-stats{display:flex;gap:7px;font-size:9px;color:var(--dim);flex-wrap:wrap}
.pi-sv{color:var(--text)}
.skulls{display:flex;gap:4px;font-size:14px}
.curse-badge{font-size:13px;margin-left:5px;cursor:help}
.skeleton.on{filter:none;opacity:1}
.hud-action{width:364px;min-width:182px;flex-shrink:0;border-left:4px solid var(--border);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:8px 10px;gap:5px}
.dice-wrap{display:flex;gap:13px;justify-content:center;align-items:center}
.dice{width:52px;height:52px;background:rgba(14,18,14,.9);border:4px solid var(--gold-dark);display:flex;align-items:center;justify-content:center;font-size:42px;color:var(--gold);font-weight:bold;box-shadow:inset 0 0 8px rgba(0,0,0,.5);transition:all .1s}
.dice.rolling{animation:diceRoll .65s ease;border-color:var(--gold);box-shadow:0 0 16px rgba(240,194,96,.5)}
.hud-legend{width:117px;min-width:104px;flex-shrink:0;border-left:1px solid var(--border);padding:8px;display:flex;flex-direction:column;justify-content:center}
/* GAME HUD */
#gameScreen{flex-direction:column;padding:0;overflow:hidden;justify-content:space-between;height:100vh}
#boardCanvas{flex:1;min-width:0;min-height:0;cursor:grab;display:block;width:100%;height:100%}
#bottomHud{width:100%;height:180px;min-height:140px;background:rgba(3,5,3,.97);border-top:5px solid var(--border);display:flex;align-items:stretch;flex-shrink:0;position:relative;z-index:40}
.hud-players{display:flex;align-items:stretch;flex:1;min-width:0;overflow-x:auto}
.hud-players::-webkit-scrollbar{height:5px}
.hud-players::-webkit-scrollbar-thumb{background:var(--gold-dark)}
.back-btn{position:absolute;top:16px;left:16px;background:transparent;border:1px solid var(--gold-dark);
  color:var(--dim);font-family:'Cinzel',serif;font-size:13px;letter-spacing:4px;padding:7px 18px;cursor:pointer;transition:all .4s;z-index:40}
.sb-ttl{font-size:9px;letter-spacing:2px;color:var(--dim);text-transform:uppercase;border-bottom:1px solid var(--border);padding-bottom:4px;margin-bottom:7px}
@keyframes diceRoll{0%{transform:rotate(0) scale(1)}45%{transform:rotate(90deg) scale(1.4)}50%{transform:rotate(180deg) scale(.9)}75%{transform:rotate(470deg) scale(1.1)}100%{transform:rotate(360deg) scale(1)}}
.act-btn{width:100%;background:rgba(14,40,14,.85);border:1px solid var(--border);color:var(--text);font-family:'Cinzel',serif;font-size:12px;letter-spacing:1px;padding:7px 10px;cursor:pointer;text-align:left;transition:all .15s;margin-bottom:3px;display:flex;align-items:center;gap:5px}
.act-btn:hover:not(:disabled){border-color:var(--gold-dark);color:var(--gold);background:rgba(45,40,45,.85);padding-left:9px}
.act-btn:disabled{opacity:.35;cursor:not-allowed}
.act-btn.pri{border-color:var(--gold-dark);color:var(--gold);background:rgba(240,194,96,.09)}
.act-btn.pri:hover:not(:disabled){background:rgba(240,194,96,.4);box-shadow:0 0 8px rgba(240,194,96,.14)}
.act-btn.red{border-color:#5a1818;color:#e07070}
.act-btn.red:hover:not(:disabled){border-color:var(--red);background:rgba(70,10,10,.5)}
.act-btn.grn{border-color:#1a5a1a;color:#60c060}
.legend{display:flex;flex-wrap:wrap;gap:4px;font-size:8px;color:var(--dim)}
.leg{display:flex;align-items:center;gap:2px}
.ld{width:8px;height:8px;border-radius:50%}
#turnBanner{width:100%;padding:8px 12px;text-align:center;font-family:'Cinzel Decorative',serif;font-size:16px;color:var(--gold);background:rgba(3,5,3,.93);border-bottom:1px solid var(--gold-dark);z-index:50;letter-spacing:3px;flex-shrink:0}
/* MODAL */
.mo{position:fixed;inset:0;background:rgba(0,0,0,.88);z-index:100;display:none;align-items:center;justify-content:center;backdrop-filter:blur(5px)}
.mo.on{display:flex}
.mb{background:rgba(5,8,5,.98);border:4px solid var(--gold-dark);box-shadow:0 0 70px rgba(0,0,0,.95),0 0 40px rgba(440,194,96,.07);padding:46px;max-width:580px;width:94%;max-height:90vh;overflow-y:auto;animation:mbIn .45s ease}
@keyframes mbIn{from{transform:scale(.9) translateY(-14px);opacity:0}to{transform:none;opacity:1}}
.mo-title{font-family:'Cinzel Decorative',serif;font-size:clamp(18px,2.3vw,23px);color:var(--gold);text-align:center;margin-bottom:14px;text-shadow:0 0 10px rgba(440,194,96,.35)}
.mo-text{font-family:'IM Fell English',serif;font-size:18px;line-height:1.75;color:var(--text);text-align:center;margin-bottom:16px}
.mo-choices{display:flex;flex-direction:column;gap:5px}
/* COMBAT */
.combat-wrap{display:flex;justify-content:space-between;align-items:center;gap:14px;margin-bottom:14px}
.combatant{flex:1;text-align:center;padding:14px;background:rgba(14,18,14,.55);border:1px solid var(--border)}
.c-name{font-size:18px;color:var(--gold);font-weight:600;margin-bottom:5px}
.c-hp{font-size:18px;color:var(--dim);margin-bottom:4px}
.c-bar{height:8px;background:rgba(0,0,0,.6);border:1px solid var(--border);border-radius:4px;margin:3px auto;max-width:180px;overflow:hidden}
.c-fill{height:100%;transition:width .3s ease}
.c-php{background:linear-gradient(90deg,#c03030,#e05050)}
.c-mph{background:linear-gradient(90deg,#3060c0,#5090e0)}
.c-ehp{background:linear-gradient(90deg,#c03030,#e05050)}
.vs-txt{font-family:'Cinzel Decorative',serif;font-size:23px;color:var(--gold-dark)}
.clog{background:rgba(0,0,0,.45);border:1px solid var(--border);padding:10px;font-family:'IM Fell English',serif;font-size:14px;line-height:1.6;max-height:90px;overflow-y:auto;margin-bottom:14px;color:var(--dim)}
.c-sprite{font-size:52px;margin-bottom:5px}
.dice-roll-area{background:rgba(0,0,0,.35);border:1px solid var(--border);padding:13px;text-align:center;margin-bottom:14px;font-size:14px;color:var(--dim)}
.big-dice{font-size:47px;display:inline-block;margin:7px 13px;cursor:pointer;transition:transform .1s;filter:drop-shadow(0 0 6px rgba(440,194,96,.5))}
.big-dice:hover{transform:scale(1.15)}
.big-dice.rolling{animation:diceRoll .65s ease}
/* SKILLS GRID */
.skills-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:8px}
.skill-btn{background:rgba(14,40,14,.85);border:1px solid var(--border);color:var(--text);font-family:'Cinzel',serif;font-size:16px;letter-spacing:.5px;padding:13px 16px;cursor:pointer;text-align:left;transition:all .15s;display:flex;flex-direction:column;gap:8px}
.skill-btn:hover:not(:disabled){border-color:var(--gold-dark);color:var(--gold);background:rgba(45,40,45,.85)}
.skill-btn:disabled{opacity:.35;cursor:not-allowed}
.skill-btn.atk{border-color:#3a4a1a;color:#e0a060}
.skill-btn.atk:hover:not(:disabled){border-color:#c07030;background:rgba(40,40,5,.85)}
.skill-btn.mgk{border-color:#4a1a4a;color:#a080e0}
.skill-btn.mgk:hover:not(:disabled){border-color:#7a40c0;background:rgba(40,10,40,.85)}
.skill-btn.def{border-color:#1a3a1a;color:#60c060}
.skill-btn.def:hover:not(:disabled){border-color:#30a030;background:rgba(10,30,10,.85)}
.skill-btn.esc{border-color:#3a3a1a;color:#c0c060}
.skill-btn.esc:hover:not(:disabled){border-color:#a0a030;background:rgba(40,40,5,.85)}
.skill-btn .sk-name{font-size:14px;font-weight:600;margin-bottom:3px}
.skill-btn .sk-cost{font-size:9px;color:var(--dim);font-family:'IM Fell English',serif}
/* CARDS */
.card-grid{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;margin:14px 0}
.gcard{width:108px;background:rgba(6,10,6,.97);border:4px solid #333;padding:10px 6px;text-align:center;cursor:pointer;transition:all .4s;position:relative}
.gcard:hover{transform:translateY(-5px)}
.gcard.common{border-color:#666}
.gcard.rare{border-color:var(--blue);box-shadow:0 0 8px rgba(64,148,408,.45)}
.gcard.epic{border-color:var(--purple);box-shadow:0 0 10px rgba(138,74,170,.35)}
.gcard.legendary{border-color:var(--gold);box-shadow:0 0 14px rgba(440,194,96,.4)}
.cbadge{position:absolute;top:4px;right:4px;font-size:6px;letter-spacing:1px;padding:1px 3px;text-transform:uppercase}
.cbadge.common{color:#888}.cbadge.rare{color:var(--blue)}.cbadge.epic{color:var(--purple)}.cbadge.legendary{color:var(--gold)}
.cicon{font-size:57px;margin-bottom:5px}.cname{font-size:10px;color:var(--text);font-weight:600;margin-bottom:5px}
.cstat{font-size:9px;color:var(--dim);font-family:'IM Fell English',serif;line-height:1.4}
.ctip{position:absolute;bottom:105%;left:50%;transform:translateX(-50%);width:200px;background:rgba(3,5,3,.98);border:1px solid var(--gold-dark);padding:10px;font-family:'IM Fell English',serif;font-size:13px;color:var(--text);z-index:400;pointer-events:none;opacity:0;transition:opacity .4s;text-align:left}
.gcard:hover .ctip{opacity:1}
.fork-cards{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;margin:14px 0}
.fcard{flex:1;min-width:105px;background:rgba(14,18,14,.85);border:4px solid var(--border);padding:14px 10px;cursor:pointer;transition:all .4s;text-align:center}
.fcard:hover{border-color:var(--gold);background:rgba(440,194,96,.06);transform:translateY(-3px);box-shadow:0 5px 18px rgba(0,0,0,.5)}
.fci{font-size:57px;margin-bottom:8px}.fcn{font-size:14px;color:var(--gold);font-weight:600;margin-bottom:5px}
.fcd{font-size:12px;color:var(--dim);font-family:'IM Fell English',serif}
/* ROUTE CARD SELECTION */
.route-card-grid{display:flex;gap:16px;justify-content:center;flex-wrap:wrap;margin:26px 0}
.route-card{width:169px;height:234px;background:rgba(6,10,6,.97);border:4px solid var(--border);border-radius:10px;cursor:pointer;transition:all .4s;position:relative;overflow:hidden}
.route-card:hover:not(.selected){transform:translateY(-10px);border-color:var(--gold-dark);box-shadow:0 10px 26px rgba(0,0,0,.5)}
.route-card.face-down .card-back{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:62px;color:var(--dim);background:linear-gradient(135deg,rgba(30,20,10,.8),rgba(10,15,10,.9))}
.route-card.selected{animation:cardFlip .5s ease}
@keyframes cardFlip{0%{transform:scale(1)}50%{transform:scale(1.05)}100%{transform:scale(1)}}
.route-card .card-front{padding:16px;text-align:center;background:rgba(14,18,14,.95)}
.rc-icon{font-size:52px;margin-bottom:10px}
.rc-title{font-size:14px;color:var(--gold);font-weight:600;margin-bottom:8px;font-family:'Cinzel',serif}
.rc-type{font-size:12px;color:var(--dim);text-transform:uppercase;letter-spacing:2px}
.route-card.combat{border-color:#8a3030}
.route-card.encounter{border-color:#3080a0}
.route-card.exploration{border-color:#308a30}
.route-card.reward{border-color:#c0a030}
.route-card.punishment{border-color:#803080}
/* INVENTORY */
#invModal .mb{max-width:700px;width:96%}
.inv-layout{display:flex;gap:16px;min-height:300px}
.inv-left{flex:1;min-width:0}
.inv-right{width:190px;min-width:160px}
.inv-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:5px;margin-bottom:10px}
.inv-slot{width:48px;height:48px;background:rgba(0,0,0,.45);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:40px;cursor:pointer;transition:all .4s;position:relative}
.inv-slot:hover{border-color:var(--gold-dark)}
.inv-slot.equipped{border-color:var(--gold);background:rgba(440,194,96,.1)}
.inv-slot .ctip{bottom:105%;left:50%;transform:translateX(-50%)}
.inv-slot:hover .ctip{opacity:1}
.equip-slots{display:grid;grid-template-columns:1fr 1fr;gap:5px}
.eq-slot{background:rgba(0,0,0,.4);border:1px solid #333;padding:6px;text-align:center;font-size:9px;color:var(--dim);min-height:44px;cursor:pointer;transition:all .4s;position:relative}
.eq-slot:hover{border-color:var(--gold-dark)}
.eq-slot.filled{border-color:var(--gold-dark);color:var(--text)}
.eq-slot .ctip{bottom:105%;left:50%;transform:translateX(-50%);width:150px}
.eq-slot:hover .ctip{opacity:1}
.eq-icon{font-size:18px;display:block;margin-bottom:4px}
.stat-preview{font-size:7px;color:var(--gold);margin-top:4px}
.shop-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin:14px 0}
.shop-pot-row{display:flex;gap:8px;justify-content:center;margin:0 0 14px}
::-webkit-scrollbar{width:3px}
::-webkit-scrollbar-track{background:rgba(0,0,0,.3)}
::-webkit-scrollbar-thumb{background:var(--gold-dark);border-radius:4px}
.ptc{position:fixed;pointer-events:none;border-radius:50%;animation:ptcFly 1s ease-out forwards;z-index:300}
@keyframes ptcFly{0%{transform:translate(0,0) scale(1);opacity:1}100%{transform:translate(var(--dx),var(--dy)) scale(0);opacity:0}}
.init-list{list-style:none}
.init-list li{display:flex;justify-content:space-between;padding:4px 0;border-bottom:1px solid rgba(455,455,455,.05);font-size:10px;animation:logIn .3s ease both}
.i-score{color:var(--gold);font-weight:bold}
@keyframes logIn{from{opacity:0;transform:translateX(-4px)}to{opacity:1;transform:none}}
.victory-wrap{text-align:center}
.v-title{font-family:'Cinzel Decorative',serif;font-size:clamp(44px,4.5vw,50px);color:var(--gold);text-shadow:0 0 40px rgba(440,194,96,.85),0 0 60px rgba(440,194,96,.4);animation:titlePulse 4s ease-in-out infinite;margin-bottom:14px}
.rules-panel{padding:46px;width:min(680px,94vw);max-height:86vh;overflow-y:auto}
.rules-panel h3{color:var(--gold);font-size:14px;letter-spacing:4px;margin:14px 0 6px;border-bottom:1px solid var(--gold-dark);padding-bottom:3px}
.rules-panel p{font-family:'IM Fell English',serif;font-size:11px;line-height:1.7;color:var(--dim);margin-bottom:5px}
/* FACE-DOWN CARD FLIP */
.card-deck{display:flex;gap:14px;flex-wrap:wrap;justify-content:center;margin:14px 0;perspective:800px}
.card-container{width:108px;height:160px;cursor:pointer;perspective:600px;position:relative}
.card-inner{width:100%;height:100%;position:relative;transform-style:preserve-3d;transition:transform 0.55s cubic-bezier(.4,0,.4,1)}
.card-inner.flipped{transform:rotateY(180deg)}
.card-face,.card-back{position:absolute;inset:0;backface-visibility:hidden;-webkit-backface-visibility:hidden;border-radius:4px;overflow:hidden}
.card-back{background:linear-gradient(135deg,#1a0a4a 0%,#4a1040 40%,#1a0a4a 100%);border:4px solid #6a40aa;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:6px}
.card-back-pattern{position:absolute;inset:0;background-image:repeating-linear-gradient(45deg,rgba(140,60,180,0.14) 0px,rgba(140,60,180,0.14) 4px,transparent 4px,transparent 10px),repeating-linear-gradient(-45deg,rgba(80,40,140,0.1) 0px,rgba(80,40,140,0.1) 4px,transparent 4px,transparent 10px)}
.card-back-symbol{font-size:36px;z-index:1;filter:drop-shadow(0 0 8px rgba(180,100,455,0.7))}
.card-back-text{font-family:'Cinzel',serif;font-size:8px;color:rgba(400,150,455,0.8);letter-spacing:4px;z-index:1}
.card-face{transform:rotateY(180deg);background:rgba(6,10,6,.97);border:4px solid #333;padding:10px 6px;text-align:center}
.card-face.common{border-color:#666}
.card-face.rare{border-color:var(--blue);box-shadow:inset 0 0 14px rgba(64,148,408,.4)}
.card-face.epic{border-color:var(--purple);box-shadow:inset 0 0 14px rgba(138,74,170,.45)}
.card-face.legendary{border-color:var(--gold);box-shadow:inset 0 0 16px rgba(440,194,96,.3)}
.card-hint{font-size:8px;color:var(--dim);text-align:center;margin-bottom:8px;font-family:'IM Fell English',serif;font-style:italic}
#gameToast{position:fixed;bottom:155px;left:50%;transform:translateX(-50%);background:rgba(5,8,5,.95);border:1px solid var(--gold-dark);padding:10px 52px;font-family:'IM Fell English',serif;font-size:17px;z-index:400;pointer-events:none;max-width:450px;text-align:center;opacity:0;transition:opacity .3s;display:none}
/* RECHARGE INDICATOR */
.recharge-badge{display:inline-block;background:rgba(400,80,80,.4);border:1px solid #883333;color:#e08080;font-size:7px;padding:1px 4px;letter-spacing:1px;margin-left:3px}
</style>
</head>
<body>
<canvas id="bgCanvas" style="position:fixed;inset:0;z-index:0"></canvas>
<div id="gameToast"></div>

<!-- MAIN MENU -->
<div id="menuScreen" class="screen active">
  <div class="title">Chronicles of the<br>Enchanted Path</div>
  <div class="subtitle">~ An Adventure Board Game ~</div>
  <button class="menu-btn" onclick="showS('charCreation')">⚔ New Game</button>
  <div class="menu-sep"></div>
  <button class="menu-btn" id="loadGameBtn">📂 Load Game</button>
  <div class="menu-sep"></div>
  <button class="menu-btn" onclick="showS('rulesScreen')">📜 Rules</button>
  <div class="menu-sep"></div>
  <button class="menu-btn" onclick="showS('creditsScreen')">✦ Credits</button>
</div>

<!-- CHARACTER CREATION -->
<div id="charCreation" class="screen">
  <button class="back-btn" onclick="showS('menuScreen')">← Back</button>
  <div class="panel">
    <div class="panel-title">Create Your Heroes</div>
    <div class="pcount-row">
      <button class="cnt-btn" onclick="changePC(-1)">−</button>
      <div><div class="cnt-val" id="pcDisplay">4</div><div style="font-size:7px;color:var(--dim);text-align:center;letter-spacing:4px">PLAYERS</div></div>
      <button class="cnt-btn" onclick="changePC(1)">+</button>
    </div>
    <div class="players-row" id="playersRow"></div>
    <button class="start-btn" onclick="startGame()">Begin the Journey ⟶</button>
  </div>
</div>

<!-- GAME SCREEN -->
<div id="gameScreen" class="screen">
  <div id="turnBanner">Loading...</div>
  <div id="boardContainer" style="flex:1;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center;min-height:0;background:#000">
    <canvas id="boardCanvas" style="max-width:100%;max-height:100%"></canvas>
  </div>
  <div id="bottomHud">
    <div class="hud-players" id="playersList"></div>
    <div class="hud-action">
      <div class="dice-wrap"><div class="dice" id="mainDice" onclick="rollDice()">?</div></div>
      <div id="actionBtns" style="width:100%"></div>
      <button class="act-btn" style="font-size:7px;margin-top:4px;padding:3px 8px" onclick="saveGame()">💾 Save</button>
      <button class="act-btn" style="font-size:7px;margin-top:4px;padding:3px 8px" onclick="if(confirm('Return to menu? (unsaved progress will be lost)')){closeModal();showS('menuScreen');}">🏠 Menu</button>
    </div>
    <div class="hud-legend">
      <div class="sb-ttl">🗺 Legend</div>
      <div class="legend">
        <div class="leg"><div class="ld" style="background:#1a3a1a"></div>Forest</div>
        <div class="leg"><div class="ld" style="background:#6a4040"></div>Village</div>
        <div class="leg"><div class="ld" style="background:#1a4a4a"></div>Shop</div>
        <div class="leg"><div class="ld" style="background:#5a4510"></div>Inn</div>
        <div class="leg"><div class="ld" style="background:#4a1010"></div>Mini-Boss</div>
        <div class="leg"><div class="ld" style="background:#4a0840"></div>Final Boss</div>
      </div>
    </div>
  </div>
</div>

<!-- RULES -->
<div id="rulesScreen" class="screen">
  <button class="back-btn" onclick="showS('menuScreen')">← Back</button>
  <div class="panel rules-panel">
    <div class="panel-title">Rules & Guide</div>
    <h3>Objective</h3><p>First player to defeat 3 Final Bosses wins the game.</p>
    <h3>Movement</h3><p>Roll D6, click a highlighted tile to move. You cannot revisit a tile you stood on in the last 8 turns. Drag to pan the map.</p>
    <h3>Classes & Skills</h3>
    <p>🧙 Mage: Basic Attack, Lightning Bolt, Fireball, Curse, Healing Beam, Defend, Run</p>
    <p>🏹 Ranger: Shoot Arrow, Double Arrow, Healing Beam, Defend, Swift Retreat, Call of the Nature</p>
    <p>⚔️ Warrior: Basic Attack, Fierce Attack (recharges 1 turn), Magic Bolt, Defend (75% with shield), Run</p>
    <p>🥊 Monk: Basic Attack, Furious Blows (1–6 rapid hits), Magic Bolt, Defensive Stance (75% next hit), Run</p>
    <h3>Shop</h3><p>3 equipment items for your class, plus a 50% chance each for HP and Mana Potions.</p>
    <h3>Cards</h3><p>Common · Rare · Epic · Legendary. Hover any card to see full stats. Click player in HUD to open inventory.</p>
  </div>
</div>

<!-- CREDITS -->
<div id="creditsScreen" class="screen">
  <button class="back-btn" onclick="showS('menuScreen')">← Back</button>
  <div class="panel rules-panel" style="text-align:center">
    <div class="panel-title">Credits</div>
    <p style="color:var(--gold);font-size:14px;margin-bottom:10px">Chronicles of the Enchanted Path</p>
    <p>Inspired by Octopath Traveler. Dynamic enchanted forest, pseudo-3D board, fork roads, full combat, class sprites, card inventory.</p>
    <p style="margin-top:14px;color:var(--dim);font-size:9px">HTML5 Canvas & Vanilla JavaScript</p>
  </div>
</div>

<div class="mo" id="modal"><div class="mb" id="modalBox"></div></div>
<div class="mo" id="invModal"><div class="mb" id="invBox"></div></div>

<script>
// ══════════════════════════════════════════════════════
//  DATA
// ══════════════════════════════════════════════════════
const CLASSES = {
  mage:    {icon:'🧙',name:'Mage',   str:3,int:8,dex:4,mp:60,hp:80, color:'#7a3a9a',weaponTypes:['staff','wand','orb']},
  warrior: {icon:'⚔️',name:'Warrior',str:8,int:3,dex:4,mp:30,hp:100,color:'#9a3a3a',weaponTypes:['twohander','sword_shield','dual']},
  ranger:  {icon:'🏹',name:'Ranger', str:4,int:4,dex:8,mp:40,hp:75, color:'#3a8a3a',weaponTypes:['bow']},
  monk:    {icon:'🥊',name:'Monk',   str:5,int:4,dex:7,mp:50,hp:85, color:'#9a7a3a',weaponTypes:['knuckles','monk_staff']},
};

// ── CLASS SKILL DEFINITIONS ──
const CLASS_SKILLS = {
  mage: [
    {id:'basic_atk',    name:'Basic Attack',   icon:'⚡',kind:'atk',mpCost:0, desc:'D4 + 25% INT. Magic damage.',
      exec:(p,e,c,r)=>{const s=calcStats(p);const d4=c._playerDiceRoll||Math.floor(Math.random()*4)+1;const dmgBase=d4+Math.floor(s.int*0.25);const hitRoll=Math.floor(Math.random()*20)+1+s.int;c.log.push(`🎲 Hit: ${hitRoll} vs AC ${e.armorClass||12}`);if(hitRoll<(e.armorClass||12)){c.log.push(`❌ ${p.name}'s attack missed!`);return 0;}const dmg=dmgBase;e.hp=Math.max(0,e.hp-dmg);c.log.push(`⚡ Basic Attack — ${dmg} magic dmg (D4:${d4}+${Math.floor(s.int*0.25)} INT)`);return dmg;}},
    {id:'lightning',   name:'Lightning Bolt', icon:'🌩️',kind:'mgk',mpCost:18,desc:'D6 + 50% INT. Electric damage.',
      exec:(p,e,c,r)=>{const s=calcStats(p);const d6=c._playerDiceRoll||Math.floor(Math.random()*6)+1;const dmgBase=d6+Math.floor(s.int*0.5);const hitRoll=Math.floor(Math.random()*20)+1+s.int;c.log.push(`🎲 Hit: ${hitRoll} vs AC ${e.armorClass||12}`);if(hitRoll<(e.armorClass||12)){c.log.push(`❌ ${p.name}'s Lightning Bolt missed!`);return 0;}const dmg=dmgBase;e.hp=Math.max(0,e.hp-dmg);c.log.push(`🌩️ Lightning Bolt — ${dmg} electric dmg (D6:${d6}+${Math.floor(s.int*0.5)} INT)`);return dmg;}},
    {id:'fireball',    name:'Fireball',       icon:'🔥',kind:'mgk',mpCost:44,desc:'D6 + 50% INT. Fire damage.',
      exec:(p,e,c,r)=>{const s=calcStats(p);const d6=c._playerDiceRoll||Math.floor(Math.random()*6)+1;const dmgBase=d6+Math.floor(s.int*0.5);const hitRoll=Math.floor(Math.random()*20)+1+s.int;c.log.push(`🎲 Hit: ${hitRoll} vs AC ${e.armorClass||12}`);if(hitRoll<(e.armorClass||12)){c.log.push(`❌ ${p.name}'s Fireball missed!`);return 0;}const dmg=dmgBase;e.hp=Math.max(0,e.hp-dmg);c.log.push(`🔥 Fireball — ${dmg} fire dmg (D6:${d6}+${Math.floor(s.int*0.5)} INT)`);return dmg;}},
    {id:'curse',       name:'Curse',          icon:'💀',kind:'mgk',mpCost:15,desc:'Reduces enemy STR by 50% for 3 turns.',
      exec:(p,e,c,r)=>{const s=calcStats(p);const hitRoll=Math.floor(Math.random()*20)+1+s.int;c.log.push(`🎲 Hit: ${hitRoll} vs AC ${e.armorClass||12}`);if(hitRoll<(e.armorClass||12)){c.log.push(`❌ ${p.name}'s Curse missed!`);return 0;}e._cursedTurns=(e._cursedTurns||0)+3;const originalStr=e.str;e.str=Math.max(1,Math.floor(e.str*0.5));c.log.push(`💀 Curse applied! Enemy STR ${originalStr}→${e.str} (3 turns)`);return 0;}},
    {id:'heal_beam',   name:'Healing Beam',   icon:'💚',kind:'def',mpCost:40,desc:'D4 + 50% INT heal.',
      exec:(p,e,c,r)=>{const s=calcStats(p);const d4=c._playerDiceRoll||Math.floor(Math.random()*4)+1;const heal=d4+Math.ceil(s.int*0.5);p.hp=Math.min(p.maxHp,p.hp+heal);c.log.push(`💚 Healing Beam — restored ${heal} HP! (D4:${d4}+${Math.ceil(s.int*0.5)} INT)`);return 0;}},
    {id:'defend',      name:'Defend',         icon:'🛡️',kind:'def',mpCost:0, desc:'Reduce next hit by 50%.',
      exec:(p,e,c,r)=>{c.defending=true;c.log.push(`🛡️ ${p.name} enters a defensive stance.`);return 0;}},
    {id:'run',         name:'Run',            icon:'🏃',kind:'esc',mpCost:0, desc:'Attempt to flee. DEX based.',
      exec:(p,e,c,r)=>{const s=calcStats(p);const flee=r+s.dex>14;if(flee){c.fled=true;c.log.push(`🏃 ${p.name} escapes from combat!`);}else{c.log.push(`🏃 Escape failed! (roll:${r}+DEX:${s.dex})`); }return 0;}},
    {id:'teleport',    name:'Teleport',       icon:'🌀',kind:'esc',mpCost:35,desc:'Instantly teleport away. Guaranteed escape.',
      exec:(p,e,c,r)=>{c.fled=true;c.log.push(`🌀 ${p.name} teleports away in a flash of magic!`);return 0;}},
  ],
  warrior: [
    {id:'basic_atk',   name:'Basic Attack',   icon:'⚔️',kind:'atk',mpCost:0, desc:'D4 + 50% STR (round up). Slash damage.',
      exec:(p,e,c,r)=>{const s=calcStats(p);const d4=c._playerDiceRoll||Math.floor(Math.random()*4)+1;const dmgBase=d4+Math.ceil(s.str*0.5);const hitRoll=Math.floor(Math.random()*20)+1+s.str;c.log.push(`🎲 Hit: ${hitRoll} vs AC ${e.armorClass||12}`);if(hitRoll<(e.armorClass||12)){c.log.push(`❌ ${p.name}'s attack missed!`);return 0;}const dmg=dmgBase;e.hp=Math.max(0,e.hp-dmg);c.log.push(`⚔️ Basic Attack — ${dmg} slash dmg (D4:${d4}+${Math.ceil(s.str*0.5)} STR)`);return dmg;}},
    {id:'fierce_atk',  name:'Fierce Attack', icon:'💥',kind:'atk',mpCost:0, desc:'D4 + D6 + 50% STR (round down). 2 turn cooldown. Slash.',
      exec:(p,e,c,r)=>{if(c.fierceRecharge>0){c.log.push(`💥 Fierce Attack still recharging (${c.fierceRecharge} turns left)!`);return 0;}const s=calcStats(p);const d4=c._playerDiceRoll||Math.floor(Math.random()*4)+1;const d6=Math.floor(Math.random()*6)+1;const dmgBase=d4+d6+Math.floor(s.str*0.5);const hitRoll=Math.floor(Math.random()*20)+1+s.str;c.log.push(`🎲 Hit: ${hitRoll} vs AC ${e.armorClass||12}`);if(hitRoll<(e.armorClass||12)){c.log.push(`❌ ${p.name}'s Fierce Attack missed!`);c.fierceRecharge=2;return 0;}const dmg=dmgBase;e.hp=Math.max(0,e.hp-dmg);c.fierceRecharge=2;c.log.push(`💥 Fierce Attack — ${dmg} slash dmg! (D4:${d4}+D6:${d6}+${Math.floor(s.str*0.5)} STR, recharging 2 turns)`);return dmg;}},
    {id:'magic_bolt',  name:'Magic Bolt',    icon:'✨',kind:'mgk',mpCost:14,desc:'D4 + 50% INT (round down). Magic damage.',
      exec:(p,e,c,r)=>{const s=calcStats(p);const d4=c._playerDiceRoll||Math.floor(Math.random()*4)+1;const dmgBase=d4+Math.floor(s.int*0.5);const hitRoll=Math.floor(Math.random()*20)+1+s.str;c.log.push(`🎲 Hit: ${hitRoll} vs AC ${e.armorClass||12}`);if(hitRoll<(e.armorClass||12)){c.log.push(`❌ ${p.name}'s Magic Bolt missed!`);return 0;}const dmg=dmgBase;e.hp=Math.max(0,e.hp-dmg);c.log.push(`✨ Magic Bolt — ${dmg} magic dmg (D4:${d4}+${Math.floor(s.int*0.5)} INT)`);return dmg;}},
    {id:'defend',      name:'Defend',         icon:'🛡️',kind:'def',mpCost:0, desc:'65% damage reduction.',
      exec:(p,e,c,r)=>{c.tempDefMult=0.35;c.defending=true;c.log.push(`🛡️ ${p.name} defends! 65% dmg reduction.`);return 0;}},
    {id:'run',         name:'Run',            icon:'🏃',kind:'esc',mpCost:0, desc:'Attempt to flee. DEX based.',
      exec:(p,e,c,r)=>{const s=calcStats(p);const flee=r+s.dex>14;if(flee){c.fled=true;c.log.push(`🏃 ${p.name} retreats from battle!`);}else{c.log.push(`🏃 Retreat failed! (roll:${r}+DEX:${s.dex})`);}return 0;}},
  ],
  ranger: [
    {id:'shoot',       name:'Shoot Arrow',    icon:'🏹',kind:'atk',mpCost:0, desc:'D4 + 50% DEX (round down). Piercing damage.',
      exec:(p,e,c,r)=>{const s=calcStats(p);const d4=c._playerDiceRoll||Math.floor(Math.random()*4)+1;const dmgBase=d4+Math.floor(s.dex*0.5);const hitRoll=Math.floor(Math.random()*20)+1+s.dex;c.log.push(`🎲 Hit: ${hitRoll} vs AC ${e.armorClass||12}`);if(hitRoll<(e.armorClass||12)){c.log.push(`❌ ${p.name}'s arrow missed!`);return 0;}const dmg=dmgBase;e.hp=Math.max(0,e.hp-dmg);c.log.push(`🏹 Shoot Arrow — ${dmg} piercing dmg (D4:${d4}+${Math.floor(s.dex*0.5)} DEX)`);return dmg;}},
    {id:'double_arrow',name:'Double Arrow',   icon:'🪃',kind:'atk',mpCost:14,desc:'D4 + 50% DEX per arrow (2 arrows). Piercing.',
      exec:(p,e,c,r)=>{const s=calcStats(p);let total=0;let hits=0;for(let i=0;i<2;i++){const d4=c._playerDiceRoll?c._playerDiceRoll:Math.floor(Math.random()*4)+1;const dmgBase=d4+Math.floor(s.dex*0.5);const hitRoll=Math.floor(Math.random()*20)+1+s.dex;c.log.push(`🎲 Arrow ${i+1} Hit: ${hitRoll} vs AC ${e.armorClass||12}`);if(hitRoll>=(e.armorClass||12)){const dmg=dmgBase;e.hp=Math.max(0,e.hp-dmg);total+=dmg;hits++;}}c.log.push(`🪃 Double Arrow — ${total} piercing dmg (${hits}/2 hits)`);return total;}},
    {id:'heal_beam',   name:'Healing Beam',   icon:'💚',kind:'def',mpCost:40,desc:'D4 + 50% INT (round down) heal.',
      exec:(p,e,c,r)=>{const s=calcStats(p);const d4=c._playerDiceRoll||Math.floor(Math.random()*4)+1;const heal=d4+Math.floor(s.int*0.5);p.hp=Math.min(p.maxHp,p.hp+heal);c.log.push(`💚 Healing Beam — restored ${heal} HP! (D4:${d4}+${Math.floor(s.int*0.5)} INT)`);return 0;}},
    {id:'defend',      name:'Defend',         icon:'🛡️',kind:'def',mpCost:0, desc:'50% damage reduction.',
      exec:(p,e,c,r)=>{c.defending=true;c.log.push(`🛡️ ${p.name} takes cover!`);return 0;}},
    {id:'swift_retreat',name:'Swift Retreat',icon:'💨',kind:'esc',mpCost:8,desc:'D4 bonus to escape roll.',
      exec:(p,e,c,r)=>{const s=calcStats(p);const d4=c._playerDiceRoll||Math.floor(Math.random()*4)+1;const flee=r+d4+s.dex>14;if(flee){c.fled=true;c.log.push(`💨 Swift Retreat! ${p.name} vanishes! (roll:${r}+D4:${d4}+DEX:${s.dex})`);}else{c.log.push(`💨 Retreat failed. (roll:${r}+D4:${d4}+DEX:${s.dex})`);}return 0;}},
    {id:'call_nature', name:'Call of Nature', icon:'🐺',kind:'mgk',mpCost:35,desc:'Summons wolf for 3 turns. Wolf does 25% of ranger damage.',
      exec:(p,e,c,r)=>{c.wolf={hp:40,maxHp:40,turns:3,strMult:0.25};c.log.push(`🐺 A wolf answers the call! (3 turns, 25% of ranger damage)`);return 0;}},
  ],
  monk: [
    {id:'basic_atk',   name:'Basic Attack',   icon:'🥊',kind:'atk',mpCost:0, desc:'D4 + 50% DEX + 50% STR (both round down). Blunt damage.',
      exec:(p,e,c,r)=>{const s=calcStats(p);const d4=c._playerDiceRoll||Math.floor(Math.random()*4)+1;const dmgBase=d4+Math.floor(s.dex*0.5)+Math.floor(s.str*0.5);const hitMod=Math.floor(s.str*0.5)+Math.floor(s.dex*0.5);const hitRoll=Math.floor(Math.random()*20)+1+hitMod;c.log.push(`🎲 Hit: ${hitRoll} vs AC ${e.armorClass||12}`);if(hitRoll<(e.armorClass||12)){c.log.push(`❌ ${p.name}'s attack missed!`);return 0;}const dmg=dmgBase;e.hp=Math.max(0,e.hp-dmg);c.log.push(`🥊 Basic Attack — ${dmg} blunt dmg (D4:${d4}+${Math.floor(s.dex*0.5)} DEX+${Math.floor(s.str*0.5)} STR)`);return dmg;}},
    {id:'furious_blows',name:'Furious Blows', icon:'👊',kind:'atk',mpCost:14,desc:'D4 + 33% DEX + 33% STR per hit (1-6 hits). Blunt.',
      exec:(p,e,c,r)=>{const s=calcStats(p);const hits=Math.max(1,Math.floor(Math.random()*6)+1);let total=0;let hitCount=0;const hitMod=Math.floor(s.str*0.33)+Math.floor(s.dex*0.33);for(let i=0;i<hits;i++){const d4=c._playerDiceRoll?c._playerDiceRoll:Math.floor(Math.random()*4)+1;const dmgBase=d4+Math.floor(s.dex*0.33)+Math.floor(s.str*0.33);const hitRoll=Math.floor(Math.random()*20)+1+hitMod;if(hitRoll>=(e.armorClass||12)){const dmg=dmgBase;e.hp=Math.max(0,e.hp-dmg);total+=dmg;hitCount++;}}c.log.push(`👊 Furious Blows — ${hits} hits, ${hitCount} landed = ${total} blunt dmg`);return total;}},
    {id:'magic_bolt',  name:'Magic Bolt',    icon:'⚡',kind:'mgk',mpCost:14,desc:'D4 + 50% INT (round down). Magic damage.',
      exec:(p,e,c,r)=>{const s=calcStats(p);const d4=c._playerDiceRoll||Math.floor(Math.random()*4)+1;const dmgBase=d4+Math.floor(s.int*0.5);const hitMod=Math.floor(s.str*0.5)+Math.floor(s.dex*0.5);const hitRoll=Math.floor(Math.random()*20)+1+hitMod;c.log.push(`🎲 Hit: ${hitRoll} vs AC ${e.armorClass||12}`);if(hitRoll<(e.armorClass||12)){c.log.push(`❌ ${p.name}'s Magic Bolt missed!`);return 0;}const dmg=dmgBase;e.hp=Math.max(0,e.hp-dmg);c.log.push(`⚡ Magic Bolt — ${dmg} magic dmg (D4:${d4}+${Math.floor(s.int*0.5)} INT)`);return dmg;}},
    {id:'def_stance',  name:'Defensive Stance',icon:'🧘',kind:'def',mpCost:10,desc:'Blocks 75% of next hit.',
      exec:(p,e,c,r)=>{c.tempDefMult=0.25;c.defending=true;c.log.push(`🧘 ${p.name} enters Defensive Stance! 75% dmg reduction.`);return 0;}},
    {id:'run',         name:'Run',            icon:'🏃',kind:'esc',mpCost:0, desc:'DEX based escape.',
      exec:(p,e,c,r)=>{const s=calcStats(p);const flee=r+s.dex>14;if(flee){c.fled=true;c.log.push(`🏃 ${p.name} uses agility to escape!`);}else{c.log.push(`🏃 Escape failed! (roll:${r}+DEX:${s.dex})`);}return 0;}},
  ],
};

