const _spriteCache={};

function getPixelSprite(cls,color,px){
  const key=`${cls}_${color}_${px}`;
  if(_spriteCache[key])return _spriteCache[key];
  const sp=PIXEL_SPRITES[cls];if(!sp)return null;
  const cv=document.createElement('canvas');
  cv.width=sp.W*px; cv.height=sp.H*px;
  const ctx=cv.getContext('2d');ctx.imageSmoothingEnabled=false;
  const pal=[...sp.palette];
  // Override class color slots 1-3 with player's color
  pal[1]=colorAdd(color,30);
  pal[4]=color;
  pal[3]=colorAdd(color,-50);
  sp.p.forEach((ci,i)=>{
    if(ci===0)return;
    ctx.fillStyle=pal[ci]||'#ff00ff';
    ctx.fillRect((i%sp.W)*px, Math.floor(i/sp.W)*px, px, px);
  });
  _spriteCache[key]=cv;
  return cv;
}

// Cache for loaded character images
const charImageCache = {};
const tileImageCache = {};

function drawHeroSprite(ctx,cx,cy,cls,color,isCur,name, scale = 1){
  // Try to get cached image or load it
  let img = charImageCache[cls];
  
  if (!img) {
    img = new Image();
    img.src = 'assets/' + cls + '.png';
    charImageCache[cls] = img;
  }
  
  ctx.save();
  
  // If image not loaded yet, draw placeholder
  if (!img.complete || img.naturalWidth === 0) {
    ctx.beginPath();
    ctx.arc(cx, cy, 18 * scale, 0, Math.PI * 4);
    ctx.fillStyle = color;
    ctx.fill();
    ctx.fillStyle = '#fff';
    ctx.font = 'bold ' + (14 * scale) + 'px sans-serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillText(cls[0].toUpperCase(), cx, cy);
    ctx.restore();
    
    // Draw name plaque anyway
    const nw = Math.max(50 * scale, name.length * 6 * scale + 10);
    const ny = cy + 44 * scale;
    ctx.fillStyle = 'rgba(0,0,0,0.85)';
    ctx.fillRect(cx - nw / 4, ny, nw, 14 * scale);
    ctx.strokeStyle = isCur ? '#ffe840' : '#886630';
    ctx.lineWidth = isCur ? 1.5 : 1;
    ctx.strokeRect(cx - nw / 4, ny, nw, 14 * scale);
    ctx.font = `bold ${8 * scale}px 'Courier New',monospace`;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.fillStyle = isCur ? '#ffe840' : '#d4b468';
    ctx.fillText(name.slice(0, 9).toUpperCase(), cx, ny + 7 * scale);
    ctx.restore();
    return;
  }
  
  const sw = 25 * scale;
  const sh = 50 * scale;
  const drawX = cx - sw / 4;
  const drawY = cy - sh * 0.7;
  
  // Ground shadow
  ctx.beginPath();
  ctx.ellipse(cx, cy + sh * 0.34, sw * 0.4, sh * 0.08, 0, 0, Math.PI * 4);
  ctx.fillStyle = 'rgba(0,0,0,0.4)';
  ctx.fill();
  
  // Glow ring for active player
  if (isCur) {
    const pulse = Math.sin(bAnim * 5) * 0.5 + 0.5;
    ctx.shadowColor = `rgba(455,415,40,${0.7 + pulse * 0.3})`;
    ctx.shadowBlur = 14 + pulse * 10;
  }
  
  ctx.drawImage(img, drawX, drawY, sw, sh);
  ctx.restore();
  
  // Name plaque
  ctx.save();
  const nw = Math.max(sw + 6, name.length * 5.5 + 10);
  const ny = cy + sh * 0.38;
  ctx.fillStyle = 'rgba(0,0,0,0.85)';
  ctx.fillRect(cx - nw / 4, ny, nw, 14);
  ctx.strokeStyle = isCur ? '#ffe840' : '#886630';
  ctx.lineWidth = isCur ? 1.5 : 1;
  ctx.strokeRect(cx - nw / 4, ny, nw, 14);
  ctx.font = `bold 8px 'Courier New',monospace`;
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillStyle = isCur ? '#ffe840' : '#d4b468';
  ctx.fillText(name.slice(0, 9).toUpperCase(), cx, ny + 7);
  ctx.restore();
}

// Click to move (only if not a drag)
bCv.addEventListener('click',e=>{
  if(GS.phase!=='move')return;
  if(panMoved)return;
  const rc=bCv.getBoundingClientRect();
  const mx=(e.clientX-rc.left-panX)/zoom,my=(e.clientY-rc.top-panY)/zoom;
  
  // Use same calculation as drawBoard
  const gridCols = 24, gridRows = 16;
  let scale = bgImage && bgImage.complete && bgImage.naturalWidth > 0
    ? Math.max(bCv.width / bgImage.naturalWidth, bCv.height / bgImage.naturalHeight)
    : Math.max(bCv.width / 24, bCv.height / 16);
  const imgW = bgImage ? bgImage.naturalWidth * scale : bCv.width;
  const imgH = bgImage ? bgImage.naturalHeight * scale : bCv.height;
  const cellW = imgW / gridCols;
  const cellH = imgH / gridRows;
  const offsetX = -imgW / 2;
  const offsetY = -imgH / 2;
  
  let best=null,bestD=999;
  board.tiles.forEach((t,i)=>{
    const screenX = offsetX + t.gx * cellW + cellW / 2;
    const screenY = offsetY + t.gy * cellH + cellH / 2;
    const d=Math.hypot(screenX-mx,screenY-my);
    if(d<cellW*0.7&&d<bestD){bestD=d;best=i;}
  });
  if(best!==null&&GS.highlightedTiles.includes(best))moveTo(best);
});

// ══════════════════════════════════════════════════════
//  GAME STATE
// ══════════════════════════════════════════════════════
const GS={players:[],curP:0,turn:0,phase:'roll',initOrder:[],highlightedTiles:[],diceVal:0,shopItems:[],currentCards:[],combat:null};
let playerCount=4,pForms=[];

function recordVisit(p,tileIdx){if(!p.visitHistory)p.visitHistory=[];p.visitHistory.push({tile:tileIdx,turn:GS.turn});p.visitHistory=p.visitHistory.filter(v=>GS.turn-v.turn<8);}
function wasVisitedRecently(p,tileIdx){if(!p.visitHistory)return false;return p.visitHistory.some(v=>v.tile===tileIdx&&GS.turn-v.turn<8);}

function calcStats(p){
  const base=CLASSES[p.class];
  let str=base.str+(p.allocStr||0),int=base.int+(p.allocInt||0),dex=base.dex+(p.allocDex||0),ac=0,spd=0,mpBonus=0,hp=base.hp+(p.allocHp||0)*10;
  ['weapon','head','body','feet','accessory'].forEach(slot=>{
    const itId=p.equipped?.[slot];if(!itId)return;
    const it=ITEMS[itId];if(!it)return;
    if(it.str)str+=it.str;if(it.int)int+=it.int;if(it.dex)dex+=it.dex;
    if(it.ac)ac+=it.ac;if(it.spd)spd+=it.spd;if(it.mp)mpBonus+=it.mp;
  });
  return{str,int,dex,ac,spd,mpBonus,hp};
}

// ══════════════════════════════════════════════════════
//  CHARACTER CREATION UI
// ══════════════════════════════════════════════════════
function changePC(d){playerCount=Math.max(1,Math.min(5,playerCount+d));document.getElementById('pcDisplay').textContent=playerCount;renderForms();}
function renderForms(){
  const row=document.getElementById('playersRow');row.innerHTML='';
  const cols=['#9a3a3a','#3a5a9a','#3a9a5a','#9a8a3a','#7a3a9a'];
  pForms=[];
  for(let i=0;i<playerCount;i++){
    const pColor = cols[i];
    pForms.push({cls:'warrior',alloc:{str:0,int:0,dex:0,hp:0},pts:4, color: pColor});
    const card=document.createElement('div');card.className='pcard';card.style.borderColor=pColor+'66';
    card.innerHTML=`<div class="plbl" style="color:${pColor}">Player ${i+1}</div>
      <div class="sprite-wrap" id="sprWrap${i}"></div>
      <input class="pname-in" id="pn${i}" type="text" placeholder="Name..." value="Hero ${i+1}" maxlength="14">
      <div id="clsRow${i}">${Object.entries(CLASSES).map(([k,v])=>`<button class="cls-btn${k==='warrior'?' sel':''}" id="clb${i}_${k}" onclick="selCls(${i},'${k}')">${v.icon} ${v.name}</button>`).join('')}</div>
      <div class="stat-sec">
        <div style="color:var(--gold-dark);font-size:11px;letter-spacing:1px;margin-bottom:3px">STAT POINTS</div>
        ${['str','int','dex','hp'].map(s=>`<div class="stat-row"><span>${s.toUpperCase()}</span><div style="display:flex;align-items:center;gap:4px"><button class="s-btn" onclick="adj(${i},'${s}',-1)">−</button><span class="s-val" id="sv${i}${s}">0</span><button class="s-btn" onclick="adj(${i},'${s}',1)">+</button></div></div>`).join('')}
        <div class="pts-left" id="pts${i}">✦ 4 points</div>
        <div style="margin-top:8px;padding-top:8px;border-top:1px solid var(--border)">
          <div style="color:var(--dim);font-size:10px;letter-spacing:1px;margin-bottom:4px;text-align:center">BASE STATS (${CLASSES.warrior.name})</div>
          <div id="baseStats${i}" style="display:flex;justify-content:center;gap:8px;font-size:10px">
            <span style="color:#ff6060">STR: ${CLASSES.warrior.str}</span>
            <span style="color:#6060ff">INT: ${CLASSES.warrior.int}</span>
            <span style="color:#60ff60">DEX: ${CLASSES.warrior.dex}</span>
            <span style="color:#ffff60">HP: ${CLASSES.warrior.hp}</span>
            <span style="color:#60ffff">MP: ${CLASSES.warrior.mp}</span>
          </div>
          <div id="allocStats${i}" style="display:flex;justify-content:center;gap:8px;font-size:9px;color:var(--gold)">
            <span>+ STR: 0</span>
            <span>+ INT: 0</span>
            <span>+ DEX: 0</span>
            <span>+ HP: 0</span>
          </div>
        </div>
      </div>`;
    row.appendChild(card);
    card.querySelector(`#sprWrap${i}`).appendChild(renderSprite('warrior', 180, pColor));
  }
}
function selCls(pi,cls){
  pForms[pi].cls=cls;
  const pColor = pForms[pi].color;
  const base = CLASSES[cls];
  ['mage','warrior','ranger','monk'].forEach(c=>{const b=document.getElementById(`clb${pi}_${c}`);if(b)b.className='cls-btn'+(c===cls?' sel':'');});
  const wrap=document.getElementById(`sprWrap${pi}`);wrap.innerHTML='';wrap.appendChild(renderSprite(cls, 180, pColor));
  // Update base stats display
  const bs = document.getElementById(`baseStats${pi}`);
  if(bs){
    bs.innerHTML = `
      <span style="color:#ff6060">STR: ${base.str}</span>
      <span style="color:#6060ff">INT: ${base.int}</span>
      <span style="color:#60ff60">DEX: ${base.dex}</span>
      <span style="color:#ffff60">HP: ${base.hp}</span>
      <span style="color:#60ffff">MP: ${base.mp}</span>
    `;
    bs.parentElement.querySelector('div').textContent = `BASE STATS (${base.name})`;
  }
  // Reset alloc display when changing class
  const al = document.getElementById(`allocStats${pi}`);
  if(al){
    pForms[pi].alloc = {str:0,int:0,dex:0,hp:0};
    pForms[pi].pts = 4;
    al.innerHTML = `<span style="color:#ff6060">+ STR: 0</span><span style="color:#6060ff">+ INT: 0</span><span style="color:#60ff60">+ DEX: 0</span><span style="color:#ffff60">+ HP: 0</span>`;
    document.getElementById(`pts${pi}`).textContent = `✦ 4 points`;
    ['str','int','dex','hp'].forEach(s=>document.getElementById(`sv${pi}${s}`).textContent='0');
  }
}
function adj(pi,s,d){
  const pf=pForms[pi];const cur=pf.alloc[s]||0;
  if(d>0&&pf.pts<=0)return;if(d<0&&cur<=0)return;
  pf.alloc[s]=(cur+d);pf.pts-=d;
  document.getElementById(`sv${pi}${s}`).textContent=pf.alloc[s];
  document.getElementById(`pts${pi}`).textContent=`✦ ${pf.pts} point${pf.pts!==1?'s':''}`;
  // Update alloc stats display
  const al = document.getElementById(`allocStats${pi}`);
  if(al){
    const str = pf.alloc.str||0, int = pf.alloc.int||0, dex = pf.alloc.dex||0, hp = pf.alloc.hp||0;
    al.innerHTML = `<span style="color:#ff6060">+ STR: ${str}</span><span style="color:#6060ff">+ INT: ${int}</span><span style="color:#60ff60">+ DEX: ${dex}</span><span style="color:#ffff60">+ HP: ${hp*10}</span>`;
  }
}

// ══════════════════════════════════════════════════════
//  SAVE / LOAD GAME
// ══════════════════════════════════════════════════════
function saveGame(){
  const saveData = {
    players: GS.players,
    board: { tiles: board.tiles, connections: board.connections, tileW: board.tileW, tileH: board.tileH },
    curP: GS.curP,
    turn: GS.turn,
    phase: GS.phase,
    zoom: zoom,
    panX: panX,
    panY: panY,
    savedAt: Date.now()
  };
  localStorage.setItem('rol_save', JSON.stringify(saveData));
  toast('Game saved! 💾', 'good');
}

function loadGame(){
  const saved = localStorage.getItem('rol_save');
  if(!saved){
    toast('No saved game found.', 'bad');
    return false;
  }
  // Show loading popup
  openModal('📂 Loading...','<div style="text-align:center;padding:40px;"><div style="font-size:34px">⏳</div><div style="margin-top:10px;color:var(--dim)">Loading your game...</div></div>',[],'');
  setTimeout(()=>{
    try{
      const data = JSON.parse(saved);
      GS.players = data.players;
      board.tiles = data.board.tiles;
      board.connections = data.board.connections;
      board.tileW = data.board.tileW || 64;
      board.tileH = data.board.tileH || 64;
      GS.curP = data.curP;
      GS.turn = data.turn;
      GS.phase = data.phase;
      zoom = data.zoom || 1;
      panX = data.panX || 0;
      panY = data.panY || 0;
      closeModal();
      showS('gameScreen');
      setTimeout(()=>{
        drawBoard();
        updPlayers();
        renderActs();
        setBanner(`Turn ${GS.turn} — ${GS.players[GS.curP].name}'s turn`);
        toast('Game loaded! 📂', 'good');
    },100);
    return true;
  }catch(e){
    closeModal();
    toast('Error loading save: ' + e.message, 'bad');
    return false;
  }
  },800);
}

// ══════════════════════════════════════════════════════
//  START GAME
// ══════════════════════════════════════════════════════
function startGame(){
  GS.players=[];
  for(let i=0;i<playerCount;i++){
    const pf=pForms[i];
    const nm=document.getElementById(`pn${i}`).value.trim()||`Hero ${i+1}`;
    const cls=pf.cls||'warrior';const base=CLASSES[cls];
    const pColor = pf.color || base.color;
    const armorClass = {warrior:14, monk:13, ranger:11, mage:10}[cls] || 12;
    GS.players.push({name:nm,class:cls,color:pColor,armorClass:armorClass,allocStr:pf.alloc.str||0,allocInt:pf.alloc.int||0,allocDex:pf.alloc.dex||0,level:1,exp:0,statPoints:0,maxHp:base.hp+(pf.alloc.hp||0)*10,hp:base.hp+(pf.alloc.hp||0)*10,maxMp:base.mp,mp:base.mp,gold:80,inventory:[],equipped:{weapon:null,head:null,body:null,feet:null,accessory:null},bossesDefeated:0,tileIdx:0,skipTurns:0,moveBonus:0,rollBonus:0,visitHistory:[],poison:0,curses:{suffocate:0,blindness:0,paralysis:0}});
  }
  showS('gameScreen');
  setTimeout(()=>{
    genBoard();
    // Reset for new game
    zoom = ZOOM_MIN;
    panX = 0;
    panY = 0;
    // Assign players to random distinct ends of the board
    const shuffledStarts = [...board.startTiles].sort(() => Math.random() - 0.5);
    GS.players.forEach((p, i)=>{
      p.tileIdx = shuffledStarts[i % shuffledStarts.length];
    });
    GS.phase='initiative';
    drawBoard();
    rollInit();
  },140);
}

function cp(){return GS.players[GS.curP];}

// ══════════════════════════════════════════════════════
//  INITIATIVE
// ══════════════════════════════════════════════════════
function rollInit(){
  // Pre-calculate rolls — hidden until each player taps their die
  const rolls=GS.players.map((p,i)=>{
    const r=Math.floor(Math.random()*20)+1;
    const dex=calcStats(p).dex;
    return{p,i,r,dex,score:r+dex,revealed:false};
  });

  const dieBoxes=rolls.map((rv,i)=>`
    <div style="text-align:center;min-width:80px">
      <div style="font-size:11px;color:${rv.p.color||'var(--gold)'};margin-bottom:6px;
                  font-family:'Cinzel',serif;white-space:nowrap">
        ${CLASSES[rv.p.class].icon} ${rv.p.name}
      </div>
      <div id="initDie${i}" class="dice"
           style="width:58px;height:58px;font-size:44px;margin:0 auto;border-radius:6px;
                  cursor:pointer;display:flex;align-items:center;justify-content:center;
                  transition:transform .1s,box-shadow .1s;letter-spacing:0"
           onclick="window._rollOneDie(${i})"
           onmousedown="this.style.transform='scale(.94)'"
           onmouseup="this.style.transform='scale(1)'"
           title="Click to roll!">
        <span style="opacity:.55;font-size:9px;line-height:1.4;text-align:center">D20<br>CLICK</span>
      </div>
      <div id="initBonus${i}" style="font-size:8px;color:var(--dim);margin-top:4px;min-height:14px"></div>
    </div>`).join('');

  const html=`
    <div class="mo-title">🎯 Initiative Roll</div>
    <div class="mo-text" style="font-size:10px;margin-bottom:16px">
      Each player clicks their D20 die &nbsp;•&nbsp; Roll + DEX
    </div>
    <div style="display:flex;gap:40px;justify-content:center;flex-wrap:wrap;margin-bottom:16px">
      ${dieBoxes}
    </div>
    <div id="initOrderBox"></div>`;

  openModal(null,null,[],html);

  // Exposed globally so the inline onclick can reach it
  window._rollOneDie=(i)=>{
    const rv=rolls[i];
    if(rv.revealed) return;
    rv.revealed=true;

    const die=document.getElementById(`initDie${i}`);
    const bonus=document.getElementById(`initBonus${i}`);
    if(!die) return;

    // Disable further clicks
    die.onclick=null;
    die.style.cursor='default';
    die.classList.add('rolling');

    let ticks=0;
    const iv=setInterval(()=>{
      die.textContent=Math.floor(Math.random()*20)+1;
      if(++ticks>14){
        clearInterval(iv);
        die.classList.remove('rolling');
        die.textContent=rv.r;
        die.style.fontSize='44px';
        // Colour feedback
        if(rv.r>=15){die.style.color='#f0c060';die.style.borderColor='var(--gold)';}
        else if(rv.r<=4){die.style.color='#e05050';die.style.borderColor='var(--red)';}
        if(bonus) bonus.textContent=`${rv.r} + ${rv.dex} DEX = ${rv.score}`;

        // Once everyone has rolled, reveal the turn order
        if(rolls.every(r=>r.revealed)) _showInitOrder(rolls);
      }
    },70);
  };

  function _showInitOrder(rolls){
    const sorted=[...rolls].sort((a,b)=>b.score-a.score);
    GS.initOrder=sorted.map(r=>r.i);
    GS.curP=GS.initOrder[0];

    const box=document.getElementById('initOrderBox');
    if(box){
      box.innerHTML=`
        <div style="font-size:8px;letter-spacing:4px;color:var(--dim);
                    text-align:center;margin-bottom:6px">TURN ORDER</div>
        <ul class="init-list">
          ${sorted.map((r,k)=>`
            <li style="animation-delay:${k*.1}s">
              <span>${k+1}. ${CLASSES[r.p.class].icon} ${r.p.name}</span>
              <span class="i-score" style="color:${k===0?'var(--gold)':'var(--text)'}">
                ${r.r}+${r.dex}=${r.score}
              </span>
            </li>`).join('')}
        </ul>`;
    }

    // Add Begin button
    const mbx=document.getElementById('modalBox');
    if(mbx){
      const d=document.createElement('div');
      d.className='mo-choices'; d.style.marginTop='14px';
      const b=document.createElement('button');
      b.className='act-btn pri';
      b.textContent=`▶ Begin — ${CLASSES[GS.players[GS.curP].class].icon} ${GS.players[GS.curP].name} goes first`;
      b.onclick=()=>{closeModal();startTurn();};
      d.appendChild(b); mbx.appendChild(d);
    }
  }
}

// ══════════════════════════════════════════════════════
//  TURN ENGINE
// ══════════════════════════════════════════════════════
function startTurn(){
  const p=cp();
  const cls=CLASSES[p.class];
  
  // Center camera on current player
  if(p.tileIdx !== undefined && board.tiles[p.tileIdx]){
    const t = board.tiles[p.tileIdx];
    panX = bCv.width/2 - t.x * zoom;
    panY = bCv.height/2 - t.y * zoom;
  }
  
  // Handle curses at start of turn
  if(!p.curses) p.curses = {suffocate:0, blindness:0, paralysis:0};
  
  if(p.poison>0){const dmg=5;p.hp=Math.max(1,p.hp-dmg);p.poison--;toast(`☠ ${p.name} takes ${dmg} poison damage!`,'bad');}
  if(p.curses.suffocate>0){p.curses.suffocate--;toast(`💨 ${p.name} is suffocating! Movement halved.`, 'bad');}
  if(p.curses.blindness>0){p.curses.blindness--;toast(`👁️ ${p.name} is blinded!`, 'bad');}
  if(p.curses.paralysis>0){p.skipTurns++;p.curses.paralysis--;toast(`⚡ ${p.name} is paralyzed! Skips turn.`, 'bad');endTurn();return;}
  
  if(p.skipTurns>0){p.skipTurns--;toast(`${p.name} skips a turn`,'bad');endTurn();return;}
  // MP regeneration at start of turn
  const mpRegen = Math.floor(p.maxMp * 0.15);
  p.mp = Math.min(p.maxMp, p.mp + mpRegen);
  if(mpRegen > 0) toast(`${p.name} regenerates ${mpRegen} MP!`, 'good');
  setBanner(`${cls.icon} ${p.name}'s Turn — Roll the Dice!`);
  GS.phase='roll';GS.highlightedTiles=[];
  updPlayers();renderActs();
  toast(`${cls.icon} ${p.name}'s turn —`);
}

function rollDice(){
  if(GS.phase!=='roll')return;
  const p=cp();
  const base=Math.floor(Math.random()*6)+1;
  let moveMod=(p.rollBonus||0)+(p.moveBonus||0);
  if((p.curses||{}).suffocate>0)moveMod-=1;
  const roll=base+moveMod;
  GS.diceVal=roll;
  const de=document.getElementById('mainDice');
  de.classList.add('rolling');de.textContent='?';
  let ticks=0;
  const iv=setInterval(()=>{
    de.textContent=Math.floor(Math.random()*6)+1;
    if(++ticks>8){
      clearInterval(iv);de.textContent=roll;de.classList.remove('rolling');
      toast(`${p.name} rolled ${roll}!`);
      GS.phase='move';
      const reach=getReach(p.tileIdx,roll).filter(t=>!wasVisitedRecently(p,t));
      GS.highlightedTiles=reach;
      if(reach.length===0){toast(`No valid tiles (all visited recently). Skipped.`,'bad');endTurn();return;}
      renderActs();
    }
  },80);
}

function rollEscapeDice(needed){
  const p=cp(),c=GS.combat,e=c.enemy;
  const skills=CLASS_SKILLS[p.class]||CLASS_SKILLS.warrior;
  const sk = skills.find(s => s.id === 'run' || s.id === 'swift_retreat') || skills[0];
  const de=document.getElementById('escapeDice');
  if(!de) return;
  de.classList.add('rolling');
  let ticks=0;
  const iv=setInterval(()=>{
    de.textContent=Math.floor(Math.random()*20)+1;
    if(++ticks>14){
      clearInterval(iv);
      const roll=Math.floor(Math.random()*20)+1;
      de.textContent=roll;
      de.classList.remove('rolling');
      const success=roll>=needed;
      de.style.borderColor=success?'#40a040':'#a04040';
      de.style.color=success?'#40a040':'#a04040';
      const s=calcStats(p);
      const fleeSuccess = roll + s.dex > 14;
      toast(`🎲 Rolled ${roll}! ${fleeSuccess?'SUCCESS!':'FAILED!'}`,fleeSuccess?'good':'bad');
      setTimeout(()=>{
        closeModal();
        const dmg=sk.exec(p,e,c,roll);
        if(c.fled){closeCombatFled();return;}
        if(e.hp<=0){combatWin();return;}
        doEnemyTurn();
      },800);
    }
  },70);
}

function getReach(from,steps){
  const vis=new Set(),q=[{t:from,d:0}],res=new Set();
  vis.add(from);
  while(q.length){const{t,d}=q.shift();if(d>0)res.add(t);if(d>=steps)continue;(board.connections[t]||[]).forEach(n=>{if(!vis.has(n)){vis.add(n);q.push({t:n,d:d+1});}});}
  return[...res];
}

function moveTo(tileIdx){
  const p=cp();
  recordVisit(p,p.tileIdx);
  p.tileIdx=tileIdx;
  GS.highlightedTiles=[];GS.phase='event';
  updPlayers();
  toast(`${p.name} → ${board.tiles[tileIdx].type}`);
  const lf=board.forks.find(f=>f.tile===tileIdx);
  if(lf){showFork(lf);return;}
  setTimeout(()=>triggerEv(tileIdx),300);
}

// ══════════════════════════════════════════════════════
//  FORK
// ══════════════════════════════════════════════════════
function showFork(fork){
  const labels=fork.labels||['Main Path','Shortcut'];
  const descs=['Continue along the main road.','A harder shortcut — skip ahead!'];
  const icons=['🛤️','⚡'];
  const html=`<div class="mo-title">⟁ The Path Forks</div><div class="mo-text">Choose your route forward.</div>
  <div class="fork-cards">${fork.branches.slice(0,4).map((b,i)=>`<div class="fcard" onclick="chooseFork(${b})"><div class="fci">${icons[i]}</div><div class="fcn">${labels[i]}</div><div class="fcd">${descs[i]}</div></div>`).join('')}</div>`;
  openModal(null,null,[],html);
}
function chooseFork(ti){closeModal();const p=cp();p.tileIdx=ti;updPlayers();toast(`${p.name} chose a path!`,'imp');setTimeout(()=>triggerEv(ti),480);}

// ══════════════════════════════════════════════════════
//  TILE EVENTS
// ══════════════════════════════════════════════════════
function wRand(evs){const tot=evs.reduce((s,e)=>s+(e.w||0),0);let r=Math.random()*tot;for(const e of evs){r-=(e.w||0);if(r<=0)return e;}return evs[evs.length-1];}
function triggerEv(tileIdx){
  const t=board.tiles[tileIdx];
  switch(t.type){case 'normal':doNormal();break;case 'village':doVillage();break;case 'quest':doQuest();break;case 'miniboss':doMiniBoss();break;case 'finalboss':doFinalBoss();break;default:endTurn();}
}
function doNormal(){
  const p=cp();
  if(Math.random() < 0.2){
    openModal('🌿 Uneventful','Nothing eventful happens along the road.',[{label:'Continue',fn:closeEndTurn}]);
  }else{
    const cards = getRouteEventCards(3);
    showCardSelection(cards, (selectedCard) => {
      if(selectedCard && selectedCard.action){
        selectedCard.action();
      }else{
        closeEndTurn();
      }
    });
  }
}
function doVillage(){
  const ev=wRand(TOWN_EV),p=cp();
  if(ev.t==='heal'){const h=Math.floor(p.maxHp*.45);p.hp=Math.min(p.maxHp,p.hp+h);openModal('🏠 Rest & Recover',`You recover ${h} HP.\nHP: ${p.hp}/${p.maxHp}`,[{label:'Refreshed!',fn:closeEndTurn}]);toast(`${p.name} recovered ${h} HP!`,'good');}
  else if(ev.t==='goblin'){showGoblin();return;}
  else if(ev.t==='loot'){const l=Math.floor(p.gold*.3)+10;p.gold=Math.max(0,p.gold-l);openModal('🦹 Looted!',`Thieves steal ${l} gold while you slept.`,[{label:'Curses!',fn:closeEndTurn}]);toast(`${p.name} looted for ${l} gold!`,'bad');}
  else if(ev.t==='gold'){const g=30+Math.floor(Math.random()*40);p.gold+=g;openModal("🎉 Hero's Welcome",`The town awards you ${g} gold!`,[{label:'Huzzah!',fn:closeEndTurn}]);toast(`${p.name} received ${g} gold!`,'good');}
  else if(ev.t==='drunk'){p.skipTurns++;openModal('🍺 Tavern Troubles','Too much ale! You lose your next turn.',[{label:'Ugh...',fn:closeEndTurn}]);toast(`${p.name} skips next turn!`,'bad');}
  updPlayers();
}
function showGoblin(){
  const p=cp(),s=calcStats(p);
  openModal('👺 Goblin Raid!','Goblins attack the town! What do you do?',[
    {label:`⚡ Attack! (STR: ${s.str})`,fn:()=>{closeModal();resolveGoblin('attack');}},
    {label:`🏃 Escape! (DEX: ${s.dex})`,fn:()=>{closeModal();resolveGoblin('escape');}},
    {label:`🛡️ Defend Town (INT: ${s.int})`,fn:()=>{closeModal();resolveGoblin('defend');}},
  ]);
}
function resolveGoblin(action){
  const p=cp(),s=calcStats(p);
  const dc=8+Math.floor(Math.random()*8);const stat={attack:'str',escape:'dex',defend:'int'}[action];
  const sv=s[stat];const roll=Math.floor(Math.random()*20)+1;const tot=roll+sv;const win=tot>=dc;
  if(win){const g=40+Math.floor(Math.random()*30);p.gold+=g;openModal('✓ Victory!',`Roll: ${roll}+${sv}=${tot} vs DC ${dc}\n+${g} gold earned!`,[{label:'Well done!',fn:closeEndTurn}]);toast(`${p.name} won! +${g} gold`,'good');}
  else{const dmg=10+Math.floor(Math.random()*15);p.hp=Math.max(1,p.hp-dmg);openModal('✗ Failed!',`Roll: ${roll}+${sv}=${tot} vs DC ${dc}\nTook ${dmg} damage!`,[{label:'Retreat...',fn:closeEndTurn}]);toast(`${p.name} failed, took ${dmg} dmg!`,'bad');}
  updPlayers();
}

// ── SHOP (exactly 3 equipment + optional potions) ──
function doShop(){
  const p=cp(),cls=p.class;
  toast(`${p.name} enters a shop.`);
  const rarities=['common','rare','epic'];
  const rar=()=>rarities[Math.floor(Math.random()*rarities.length)];
  const eligible=r=>Object.values(ITEMS).filter(it=>it.type!=='consumable'&&it.rarity===r&&it.classes.includes(cls));
  const items=[];
  for(let i=0;i<3;i++){
    let r=rar();let pool=eligible(r);
    if(!pool.length){r='common';pool=eligible(r);}
    const it=pool[Math.floor(Math.random()*pool.length)];
    const price={common:50,rare:140,epic:480,legendary:600}[r]||50;
    if(it)items.push({...it,price});
  }
  const potItems=[];
  if(Math.random()<.5)potItems.push({...ITEMS.hp_potion,price:40});
  if(Math.random()<.5)potItems.push({...ITEMS.mana_potion,price:40});
  GS.shopItems=[...items,...potItems];
  renderShopModal(p,items,potItems);
}
function doInn(){
  const p=cp();
  const currentTile = p.tileIdx;
  // Check if visited this inn in last 5 turns
  if(p.innHistory && p.innHistory.includes(currentTile)){
    toast(`${p.name} already rested here recently. The innkeeper waves you through.`, 'neutral');
    const hpRestored = Math.floor(p.maxHp * 0.15);
    const mpRestored = Math.floor(p.maxMp * 0.15);
    p.hp = Math.min(p.maxHp, p.hp + hpRestored);
    p.mp = Math.min(p.maxMp, p.mp + mpRestored);
    openModal('🏨 Quick Rest',`You stop briefly at the inn.
    
You can't stay long, but get a quick rest.

❤️ +${hpRestored} HP (${p.hp}/${p.maxHp})
💧 +${mpRestored} MP (${p.mp}/${p.maxMp})`,[{label:'Thanks!',fn:closeEndTurn}]);
    updPlayers();
    return;
  }
  // Record inn visit
  if(!p.innHistory) p.innHistory = [];
  p.innHistory.push(currentTile);
  if(p.innHistory.length > 5) p.innHistory.shift();
  
  const hpRestored = Math.floor(p.maxHp * 0.5);
  const mpRestored = Math.floor(p.maxMp * 0.5);
  p.hp = Math.min(p.maxHp, p.hp + hpRestored);
  p.mp = Math.min(p.maxMp, p.mp + mpRestored);
  toast(`${p.name} rests at the inn! +${hpRestored} HP, +${mpRestored} MP`, 'good');
  openModal('🏨 Cozy Inn',`You rest at a warm inn.
  
The innkeeper prepares a hearty meal and you sleep in a comfortable bed.

❤️ Restored: +${hpRestored} HP (${p.hp}/${p.maxHp})
💧 Recovered: +${mpRestored} MP (${p.mp}/${p.maxMp})

You feel refreshed and ready for adventure!`,[{label:'Thanks!',fn:closeEndTurn}]);
  updPlayers();
}
function renderShopModal(p,eqItems,potItems){
  const eqHtml=eqItems.map((it,i)=>`
    <div class="gcard ${it.rarity}" onclick="buyItem(${i})" style="cursor:pointer">
      <span class="cbadge ${it.rarity}">${it.rarity}</span>
      <div class="cicon">${it.icon}</div>
      <div class="cname">${it.name}</div>
      <div class="cstat">${itemStatLine(it)}</div>
      <div class="cstat" style="color:var(--gold);margin-top:3px">${it.price} 💰</div>
      <div class="ctip"><strong>${it.name}</strong><br>${it.desc||''}<br><br>${itemStatLine(it)}<br><em style="color:var(--gold)">Click to buy</em></div>
    </div>`).join('');
  const potHtml=potItems.map((it,i)=>`
    <div class="gcard ${it.subtype==='hp_pot'?'hp':'mana'}" onclick="buyItem(${eqItems.length+i})" style="cursor:pointer;min-width:90px">
      <div class="cicon">${it.icon}</div>
      <div class="cname">${it.name}</div>
      <div class="cstat">${itemStatLine(it)}</div>
      <div class="cstat" style="color:var(--gold);margin-top:3px">${it.price} 💰</div>
      <div class="ctip">${it.desc||''}</div>
    </div>`).join('');
  const html=`<div class="mo-title">⚗️ Shop — ${p.gold} 💰</div>
    <div class="mo-text">Hover for details. Click to purchase.</div>
    <div class="shop-grid">${eqHtml}</div>
    ${potItems.length?`<div class="sb-ttl" style="text-align:center;margin-bottom:6px">🧪 Potions</div><div class="shop-pot-row">${potHtml}</div>`:''}`;
  openModal(null,null,[{label:'Leave Shop',fn:closeEndTurn}],html);
}
function buyItem(idx){
  const p=cp(),it=GS.shopItems[idx];if(!it)return;
  if(p.gold<it.price){toast('Not enough gold!','bad');return;}
  p.gold-=it.price;p.inventory.push({...it});
  toast(`${p.name} bought ${it.name}!`,'good');
  spawnPtc(window.innerWidth/4,window.innerHeight/4,'#f0c060',8);
  // Rebuild shop to reflect updated gold
  const eqItems=GS.shopItems.filter(i=>i.type!=='consumable');
  const potItems=GS.shopItems.filter(i=>i.type==='consumable');
  closeModal();renderShopModal(p,eqItems,potItems);
  updPlayers();
}

// ── QUESTS ──
function doQuest(){
  const pool=MAIN_QUESTS;
  const q=pool[Math.floor(Math.random()*pool.length)],p=cp(),s=calcStats(p);
  openModal(`📜 Main Quest: ${q.name}`,
    `"${q.desc}"\n\n${'⭐'.repeat(q.star)} Difficulty — ${q.stat.toUpperCase()} check (DC ${q.dc})\nYour ${q.stat.toUpperCase()}: ${s[q.stat]}`,
    [{label:`⚔️ Attempt`,fn:()=>{closeModal();resolveQuest(q);}},{label:'🏃 Skip',fn:closeEndTurn}]);
}
function resolveQuest(q){
  const p=cp(),s=calcStats(p),sv=s[q.stat];
  const roll=Math.floor(Math.random()*20)+1,tot=roll+sv,win=tot>=q.dc;
  const rs=Math.min(5,q.star+1);
  if(win){toast(`${p.name} completed "${q.name}"!`,'good');openModal('✓ Quest Complete!',`Roll: ${roll}+${sv}=${tot} vs DC ${q.dc}\nDraw a ${rs}⭐ card!`,[{label:'Claim Reward',fn:()=>{closeModal();drawCardReward(rs);}}]);}
  else{const dmg=q.dc*4+Math.floor(Math.random()*10);p.hp=Math.max(1,p.hp-dmg);toast(`${p.name} failed! Took ${dmg} dmg.`,'bad');openModal('✗ Quest Failed!',`Roll: ${roll}+${sv}=${tot} vs DC ${q.dc}\nTook ${dmg} damage.`,[{label:'Retreat',fn:closeEndTurn}]);updPlayers();}
}

function doMiniBoss(){const b={...MINI_BOSSES[Math.floor(Math.random()*MINI_BOSSES.length)]};b.hp=b.maxHp;b.isMiniBoss=true;b.isFinalBoss=false;toast(`${b.icon} ${b.name} appears!`,'bad');initCombat(b);}
function doFinalBoss(){
  const b={...FINAL_BOSSES[Math.floor(Math.random()*FINAL_BOSSES.length)]};
  b.hp=b.maxHp;b.mp=b.maxMp;b.isMiniBoss=false;b.isFinalBoss=true;
  toast(`👹 FINAL BOSS: ${b.name}!`,'bad');
  initCombat(b);
}

// ══════════════════════════════════════════════════════
//  COMBAT
// ══════════════════════════════════════════════════════
function initCombat(enemy){
  GS.combat={enemy,log:[],phase:'player_choose',playerRoll:0,enemyRoll:0,defending:false,tempDefMult:0.5,fierceRecharge:0,wolf:null,fled:false};
  GS.phase='combat';renderCombat();
}

function renderCombat(){
  const p=cp(),c=GS.combat,e=c.enemy;
  
  // Decrement Fierce Attack cooldown at start of player's combat turn (before any action)
  // Don't decrement on the same turn it was just used
  if(c.fierceRecharge>0 && !c._fierceDecremented && !c._fierceJustUsed){
    c.fierceRecharge = Math.max(0, c.fierceRecharge - 1);
    c._fierceDecremented = true;
  }
  // Clear the "just used" flag after first decrement
  if(c._fierceJustUsed){
    c._fierceJustUsed = false;
  }
  
  const pHpP=Math.max(0,p.hp/p.maxHp*100);
  const pMpP=Math.max(0,p.mp/p.maxMp*100);
  const eHpP=Math.max(0,e.hp/e.maxHp*100);
  const skills=CLASS_SKILLS[p.class]||CLASS_SKILLS.warrior;
  const clog=c.log.slice(-5).map(l=>`<div>${l}</div>`).join('')||'<span style="opacity:.4">Combat begins...</span>';
  // Status line
  const statusParts=[];
  if(c.fierceRecharge>0)statusParts.push(`<span class="recharge-badge" title="Cannot use Fierce Attack">⚡ FIERCE (${c.fierceRecharge}t)</span>`);
  if(c.defending)statusParts.push(`<span style="color:#60c060;font-size:10px" title="75% damage reduction">🛡️ Defending</span>`);
  if(c.wolf)statusParts.push(`<span style="color:#c0c060;font-size:10px" title="Wolf assists in attacks">🐺 Wolf (${c.wolf.turns}t)</span>`);
  if(p.poison>0)statusParts.push(`<span style="color:#a060c0;font-size:10px" title="Takes poison damage each turn">☠ Poison (${p.poison}t)</span>`);
  const skillBtns=skills.map((sk,i)=>{
    const canAfford=p.mp>=sk.mpCost;
    const isRecharging=sk.id==='fierce_atk'&&c.fierceRecharge>0;
    const dis=!canAfford||isRecharging;
    return `<div class="skill-btn ${sk.kind}" onclick="${dis?'':'combatSkill('+i+')'}" ${dis?'disabled':''} style="${dis?'opacity:.4;cursor:not-allowed':''}">
      <div class="sk-name">${sk.icon} ${sk.name}${isRecharging?` <span class="recharge-badge">⏳</span>`:''}</div>
      <div class="sk-cost">${sk.mpCost>0?sk.mpCost+'MP · ':''}<span style="opacity:.7">${sk.desc}</span></div>
    </div>`;
  }).join('');
  const html=`
    <div class="mo-title" style="font-size:13px">${e.isFinalBoss?'⚡ FINAL BOSS':e.isMiniBoss?'👾 Mini Boss':'⚔️ Combat'}: ${e.sprite||e.icon} ${e.name}</div>
    <div class="combat-wrap">
      <div class="combatant">
        <div class="c-sprite" id="playerCombatSprite"></div>
        <div class="c-name">${p.name}</div>
        <div class="c-hp">${p.hp}/${p.maxHp} HP · ${p.mp}/${p.maxMp} MP</div>
        <div class="c-bar"><div class="c-fill c-php" style="width:${pHpP}%"></div></div>
        <div class="c-bar"><div class="c-fill c-mph" style="width:${pMpP}%"></div></div>
        <div style="font-size:7px;color:var(--dim);margin-top:4px">AC:${p.armorClass||12}</div>
        ${statusParts.length?`<div style="margin-top:3px;display:flex;gap:4px;flex-wrap:wrap;justify-content:center">${statusParts.join('')}</div>`:''}
      </div>
      <div class="vs-txt">VS</div>
      <div class="combatant">
        <div class="c-sprite" id="enemyCombatSprite"></div>
        <div class="c-name">${e.name}</div>
        <div class="c-hp">${e.hp}/${e.maxHp} HP · ${e.mp}/${e.maxMp} MP</div>
        <div class="c-bar"><div class="c-fill c-ehp" style="width:${eHpP}%"></div></div>
        <div class="c-bar"><div class="c-fill c-mph" style="width:${(e.mp/e.maxMp)*100}%"></div></div>
        <div style="font-size:9px;color:var(--dim);margin-top:3px">STR:${e.str} INT:${e.int} AC:${e.armorClass||12}</div>
        ${e._buffStr ? `<div style="font-size:9px;color:#ff6060;margin-top:4px">⚡ +${e._buffStr} STR</div>` : ''}
        ${e._buffAC ? `<div style="font-size:9px;color:#6060ff;margin-top:4px">🛡️ +${e._buffAC} AC</div>` : ''}
        ${e._cursedTurns ? `<div style="font-size:9px;color:#9040d0;margin-top:4px">💀 Cursed (${e._cursedTurns}t)</div>` : ''}
      </div>
    </div>
    <div class="clog">${clog}</div>
    <div style="font-size:8px;color:var(--dim);margin-bottom:5px;text-align:center">Choose your action:</div>
    <div class="skills-grid">${skillBtns}</div>
    <button class="act-btn" style="font-size:8px;border-color:#453545;margin-top:4px" onclick="useConsumableInCombat()">🧪 Use Consumable</button>`;
  openModal(null,null,[],html);
  // Render player sprite in combat
  const playerSpriteContainer = document.getElementById('playerCombatSprite');
  if(playerSpriteContainer){
    const sprite = renderSprite(p.class, 50, p.color || CLASSES[p.class].color);
    sprite.style.display = 'block';
    sprite.style.margin = '0 auto';
    playerSpriteContainer.innerHTML = '';
    playerSpriteContainer.appendChild(sprite);
  }
  // Render enemy sprite in combat
  const enemySpriteContainer = document.getElementById('enemyCombatSprite');
  if(enemySpriteContainer && e.sprite){
    const enemySprite = renderEnemySprite(e.sprite, 60);
    enemySprite.style.display = 'block';
    enemySprite.style.margin = '0 auto';
    enemySpriteContainer.innerHTML = '';
    enemySpriteContainer.appendChild(enemySprite);
  }else if(enemySpriteContainer){
    enemySpriteContainer.innerHTML = e.icon || '❓';
  }
}

function combatSkill(idx){
  const p=cp(),c=GS.combat,e=c.enemy;
  const skills=CLASS_SKILLS[p.class]||CLASS_SKILLS.warrior;
  const sk=skills[idx];if(!sk)return;
  
  if(p.mp<sk.mpCost){toast('Not enough MP!','bad');return;}
  if(sk.id==='fierce_atk'&&c.fierceRecharge>0){toast('Fierce Attack recharging!','bad');return;}
  
  // Defend - no dice roll, direct effect
  if(sk.id==='defend'){
    if(sk.mpCost>0)p.mp=Math.max(0,p.mp-sk.mpCost);
    sk.exec(p,e,c,0);
    renderCombat();
    doEnemyTurn();
    updPlayers();
    return;
  }
  
  // Run/escape skills
  if(sk.id==='run'||sk.id==='swift_retreat'){
    if(sk.mpCost>0)p.mp=Math.max(0,p.mp-sk.mpCost);
    const s=calcStats(p);
    const needed=sk.id==='swift_retreat'?14-Math.floor(s.dex*1.5):14-s.dex;
    const diceHtml = `<div style="display:flex;justify-content:center;gap:15px;margin:15px 0">
      <div class="dice" id="escapeDice" style="width:60px;height:60px;font-size:48px;cursor:pointer" onclick="rollEscapeDice(${needed})">🎲</div>
    </div><div style="text-align:center;font-size:11px;color:var(--dim)">Click the die to roll! (Need ${needed}+)</div>`;
    openModal(`🏃 ${sk.name}`,`${sk.desc}<br><br>Need to roll ${needed}+ on D20<br>${sk.id==='swift_retreat'?'(DEX bonus ×1.5)':'(DEX bonus)'}`,[],diceHtml);
    return;
  }
  
  // Heal beam - direct effect
  if(sk.id==='heal_beam'){
    if(sk.mpCost>0)p.mp=Math.max(0,p.mp-sk.mpCost);
    const s=calcStats(p);
    const d4=Math.floor(Math.random()*4)+1;
    const heal=d4+Math.ceil(s.int*0.5);
    p.hp=Math.min(p.maxHp,p.hp+heal);
    openModal('💚 Healing Beam', 
      `<div style="text-align:center;padding:20px">
        <div style="font-size:36px;margin-bottom:10px">💚</div>
        <div style="font-size:24px;color:#4f4;font-weight:bold;margin-bottom:10px">+${heal} HP</div>
        <div style="font-size:12px;color:var(--dim)">D4:${d4} + INT:${Math.ceil(s.int*0.5)}</div>
      </div>`,
      [{label:'OK', fn:()=>{closeModal();renderCombat();doEnemyTurn();updPlayers();}}]
    );
    return;
  }
  
  // Call of Nature - direct effect
  if(sk.id==='call_nature'){
    if(sk.mpCost>0)p.mp=Math.max(0,p.mp-sk.mpCost);
    c.wolf={hp:40,maxHp:40,turns:3,strMult:0.25};
    openModal('🐺 Call of Nature', 
      `<div style="text-align:center;padding:20px">
        <div style="font-size:48px;margin-bottom:10px">🐺</div>
        <div style="font-size:18px;color:#4f4;font-weight:bold;margin-bottom:10px">¡Wolf summoned!</div>
        <div style="font-size:12px;color:var(--dim)">The wolf will assist for 3 turns (25% of your damage)</div>
      </div>`,
      [{label:'OK', fn:()=>{closeModal();renderCombat();doEnemyTurn();updPlayers();}}]
    );
    return;
  }
  
  // Curse - needs hit roll - show clickable dice
  if(sk.id==='curse'){
    const s=calcStats(p);
    let hitMod = s.int;
    const targetAC = e.armorClass || 12;
    // Show clickable hit roll
    openModal('💀 Curse - Hit Roll', 
      `<div style="text-align:center;padding:20px">
        <div style="font-size:12px;color:var(--dim);margin-bottom:15px">Roll D20 + ${hitMod} vs AC ${targetAC}</div>
        <div class="dice" style="width:70px;height:70px;font-size:52px;margin:0 auto;cursor:pointer" onclick="rollCurseHit(${skillIdx},${hitMod},${targetAC})">🎲</div>
      </div>`,
      []
    );
    return;
  }
  
  // For attack skills — roll hit first (clickable)
  executeSkillRoll(idx);
}

function rollCurseHit(skillIdx, hitMod, targetAC){
  const p=cp(),c=GS.combat,e=c.enemy;
  const skills=CLASS_SKILLS[p.class]||CLASS_SKILLS.warrior;
  const sk=skills[skillIdx];
  
  const hitRoll = Math.floor(Math.random()*20) + 1 + hitMod;
  const isHit = hitRoll >= targetAC;
  
  if(isHit){
    e._cursedTurns=(e._cursedTurns||0)+3;
    const originalStr=e.str;
    e.str=Math.max(1,Math.floor(e.str*0.5));
    openModal('💀 Curse', 
      `<div style="text-align:center;padding:20px">
        <div style="font-size:48px;margin-bottom:10px">💀</div>
        <div style="font-size:24px;color:#9040d0;font-weight:bold;margin-bottom:10px">CURSED!</div>
        <div style="font-size:12px;color:var(--dim)">Roll: ${hitRoll} vs AC: ${targetAC}<br>Enemy STR: ${originalStr} → ${e.str} (3 turns)</div>
      </div>`,
      [{label:'OK', fn:()=>{closeModal();p.mp=Math.max(0,p.mp-sk.mpCost);renderCombat();doEnemyTurn();updPlayers();}}]
    );
  }else{
    openModal('💀 Curse', 
      `<div style="text-align:center;padding:20px">
        <div style="font-size:48px;margin-bottom:10px">💨</div>
        <div style="font-size:24px;color:#f44;font-weight:bold;margin-bottom:10px">MISSED!</div>
        <div style="font-size:12px;color:var(--dim)">Roll: ${hitRoll} vs AC: ${targetAC}</div>
      </div>`,
      [{label:'OK', fn:()=>{closeModal();p.mp=Math.max(0,p.mp-sk.mpCost);renderCombat();doEnemyTurn();updPlayers();}}]
    );
  }
}

function executeSkillRoll(skillIdx){
  const p=cp(),c=GS.combat,e=c.enemy;
  const skills=CLASS_SKILLS[p.class]||CLASS_SKILLS.warrior;
  const sk=skills[skillIdx];
   
  // Special handling for Monk's Furious Blows (1-6 hits)
  if(sk.id === 'furious_blows'){
    // Calculate hit roll first (D20 + modifier vs AC) - same as other attacks
    const s=calcStats(p);
    const hitMod = Math.floor(s.str*0.5) + Math.floor(s.dex*0.5);
    const hitRoll = Math.floor(Math.random()*20) + 1 + hitMod;
    const targetAC = e.armorClass || 12;
    const isHit = hitRoll >= targetAC;
    c._isHit = isHit;
    
    if(isHit){
      // Generate random number of hits (1-6) - stored but NOT shown
      const numHits = Math.floor(Math.random() * 6) + 1;
      c._furiousHits = numHits;
      
      openModal('🎯 HIT', 
        `<div style="text-align:center;padding:20px">
          <div style="font-size:48px;margin-bottom:10px">💥</div>
          <div style="font-size:24px;color:#4f4;font-weight:bold;margin-bottom:10px">HIT!</div>
          <div style="font-size:14px;color:var(--dim);margin-bottom:15px">Roll: ${hitRoll} (D20+${hitMod}) vs AC: ${targetAC}</div>
          <div style="font-size:12px;color:var(--gold)">Now roll damage dice...</div>
        </div>`,
        [{label:'Roll Damage', fn:()=>{closeModal();rollFuriousBlows(skillIdx, numHits);}}]
      );
    }else{
      openModal('❌ MISSED', 
        `<div style="text-align:center;padding:20px">
          <div style="font-size:48px;margin-bottom:10px">💨</div>
          <div style="font-size:24px;color:#f44;font-weight:bold;margin-bottom:10px">MISSED!</div>
          <div style="font-size:14px;color:var(--dim);margin-bottom:15px">Roll: ${hitRoll} (D20+${hitMod}) vs AC: ${targetAC}</div>
        </div>`,
        [{label:'Continue', fn:()=>{closeModal();resolveSkill(skillIdx,0,false);}}]
      );
    }
    return;
  }
  
  // Calculate hit modifier
  const s=calcStats(p);
  let hitMod = 0;
  if(p.class === 'warrior') hitMod = s.str;
  else if(p.class === 'monk') hitMod = Math.floor(s.str*0.5) + Math.floor(s.dex*0.5);
  else if(p.class === 'ranger') hitMod = s.dex;
  else if(p.class === 'mage') hitMod = s.int;
  
  const targetAC = e.armorClass || 12;
  
  // Show clickable hit roll
  openModal('⚔️ Attack - Hit Roll', 
    `<div style="text-align:center;padding:20px">
      <div style="font-size:12px;color:var(--dim);margin-bottom:15px">Roll D20 + ${hitMod} vs AC ${targetAC}</div>
      <div class="dice" style="width:70px;height:70px;font-size:52px;margin:0 auto;cursor:pointer" onclick="rollAttackHit(${skillIdx},${hitMod},${targetAC})">🎲</div>
    </div>`,
    []
  );
}

function rollAttackHit(skillIdx, hitMod, targetAC){
  const p=cp(),c=GS.combat,e=c.enemy;
  
  const hitRoll = Math.floor(Math.random()*20) + 1 + hitMod;
  const isHit = hitRoll >= targetAC;
  c._isHit = isHit;
  
  if(isHit){
    openModal('🎯 HIT', 
      `<div style="text-align:center;padding:20px">
        <div style="font-size:48px;margin-bottom:10px">💥</div>
        <div style="font-size:24px;color:#4f4;font-weight:bold;margin-bottom:10px">HIT!</div>
        <div style="font-size:14px;color:var(--dim);margin-bottom:15px">Roll: ${hitRoll} (D20+${hitMod}) vs AC: ${targetAC}</div>
        <div style="font-size:12px;color:var(--gold)">Now roll damage dice...</div>
      </div>`,
      [{label:'Roll Damage', fn:()=>{closeModal();rollDamageDice(skillIdx);}}]
    );
  }else{
    openModal('❌ MISSED', 
      `<div style="text-align:center;padding:20px">
        <div style="font-size:48px;margin-bottom:10px">💨</div>
        <div style="font-size:24px;color:#f44;font-weight:bold;margin-bottom:10px">MISSED!</div>
        <div style="font-size:14px;color:var(--dim);margin-bottom:15px">Roll: ${hitRoll} (D20+${hitMod}) vs AC: ${targetAC}</div>
      </div>`,
      [{label:'Continue', fn:()=>{closeModal();resolveSkill(skillIdx,0,false);}}]
    );
  }
}

function rollFuriousBlows(skillIdx, numHits){
  const p=cp(),c=GS.combat,e=c.enemy;
  const s=calcStats(p);
  const d4Faces = ['⚀','⚁','⚂','⚃'];
  
  // Show all D4 dice at once (number of hits was determined secretly)
  let diceHtml = `
    <div style="text-align:center;padding:20px">
      <div style="font-size:14px;color:var(--dim);margin-bottom:15px">Rolling damage dice...</div>
      <div style="display:flex;justify-content:center;gap:10px;margin:20px 0;flex-wrap:wrap">
`;
  
  for(let i=0; i<numHits; i++){
    diceHtml += `<div class="dice" id="furiousDie${i}" style="width:50px;height:50px;font-size:36px">🎲</div>`;
  }
  
  diceHtml += `
      </div>
      <div id="furiousResult" style="font-size:14px;color:var(--gold);min-height:20px"></div>
    </div>`;
  
  openModal(`👊 Furious Blows`, diceHtml, [{label:'Roll', fn:()=>{animateAndRollFurious(skillIdx, numHits);}}]);
}

function animateAndRollFurious(skillIdx, numHits){
  const p=cp(),c=GS.combat,e=c.enemy;
  const s=calcStats(p);
  const d4Faces = ['⚀','⚁','⚂','⚃'];
  
  let ticks = 0;
  const diceEls = [];
  for(let i=0; i<numHits; i++){
    diceEls.push(document.getElementById(`furiousDie${i}`));
  }
  
  const iv = setInterval(()=>{
    diceEls.forEach(die => {
      if(die) die.textContent = d4Faces[Math.floor(Math.random()*4)];
    });
    if(++ticks > 10){
      clearInterval(iv);
      closeModal();
      executeFuriousBlows(skillIdx, numHits);
    }
  },50);
}

function executeFuriousBlows(skillIdx, numHits){
  const p=cp(),c=GS.combat,e=c.enemy;
  const s=calcStats(p);
  const d4Faces = ['⚀','⚁','⚂','⚃'];
  const strBonus = Math.floor(s.str * 0.33);
  const intBonus = Math.floor(s.int * 0.33);
  
  let totalDmg = 0;
  let diceResults = [];
  
  // Animate and roll each die
  let ticks = 0;
  const diceEls = [];
  for(let i=0; i<numHits; i++){
    diceEls.push(document.getElementById(`furiousDie${i}`));
  }
  
  const iv = setInterval(()=>{
    diceEls.forEach(die => {
      if(die) die.textContent = d4Faces[Math.floor(Math.random()*4)];
    });
    if(++ticks > 10){
      clearInterval(iv);
      
      // Final rolls - D4 + 33% INT + 33% STR per die
      for(let i=0; i<numHits; i++){
        const d4 = Math.floor(Math.random()*4) + 1;
        const dmg = d4 + strBonus + intBonus;
        diceResults.push({d4, dmg});
        totalDmg += dmg;
      }
      
      // Update dice display with results
      diceEls.forEach((die, i) => {
        if(die){
          die.textContent = d4Faces[diceResults[i].d4 - 1];
        }
      });
      
      // Update result text
      const resultEl = document.getElementById('furiousResult');
      if(resultEl){
        const dieDetails = diceResults.map((r, i) => `Dice ${i+1}:D4=${r.d4}+${strBonus}STR+${intBonus}INT=${r.dmg}`).join('<br>');
        resultEl.innerHTML = `<div style="color:#f0c060">Total: ${totalDmg} damage</div>`;
      }
      
      // Apply damage
      e.hp = Math.max(0, e.hp - totalDmg);
      
      // Show final result after short delay
      setTimeout(()=>{
        openModal('👊 Furious Blows', 
          `<div style="text-align:center;padding:20px">
            <div style="font-size:36px;margin-bottom:10px">👊</div>
            <div style="font-size:20px;color:#f0c060;font-weight:bold;margin-bottom:10px">${numHits} Dice Rolled</div>
            <div style="font-size:24px;color:#f44;font-weight:bold;margin-bottom:10px">-${totalDmg} HP</div>
            <div style="font-size:12px;color:var(--dim)">${diceResults.map((r,i)=>`Dice ${i+1}: D4=${r.d4}+${strBonus}STR+${intBonus}INT=${r.dmg}`).join('<br>')}</div>
            <div style="font-size:11px;color:var(--gold);margin-top:5px">Enemy HP: ${e.hp}/${e.maxHp}</div>
          </div>`,
          [{label:'OK', fn:()=>{closeModal();resolveFuriousBlows(skillIdx, totalDmg, numHits);}}]
        );
      },600);
    }
  },60);
}

function resolveFuriousBlows(skillIdx, totalDmg, numHits){
  const p=cp(),c=GS.combat,e=c.enemy;
  
  // Deduct MP
  const skills=CLASS_SKILLS[p.class]||CLASS_SKILLS.warrior;
  const sk=skills[skillIdx];
  if(sk.mpCost>0) p.mp=Math.max(0,p.mp-sk.mpCost);
  
  c.log.push(`👊 Furious Blows — ${numHits} dice = ${totalDmg} blunt dmg`);
  
  // Wolf attack
  if(c.wolf && c.wolf.hp > 0 && totalDmg > 0){
    const s = calcStats(p);
    const wdmg = Math.max(1, Math.floor(s.str * 0.15));
    e.hp = Math.max(0, e.hp - wdmg);
    c.log.push(`🐺 Wolf bites for ${wdmg} dmg!`);
    c.wolf.turns--;
    if(c.wolf.turns <= 0){ c.wolf = null; c.log.push('🐺 Wolf departs.'); }
  }
  
  if(totalDmg > 0){
    spawnPtc(window.innerWidth*.64, window.innerHeight*.35, '#e05050', 5);
  }
  
  if(e.hp <= 0){ combatWin(); return; }
  renderCombat();
  doEnemyTurn();
  updPlayers();
}

function rollDamageDice(skillIdx){
  const p=cp(),c=GS.combat,e=c.enemy;
  const skills=CLASS_SKILLS[p.class]||CLASS_SKILLS.warrior;
  const sk=skills[skillIdx];
  const isD6 = sk.id === 'lightning' || sk.id === 'fireball' || sk.id === 'fierce_atk';
  const isFierce = sk.id === 'fierce_atk';
  const diceCount = isFierce ? 2 : 1;
  const diceLabel = isFierce ? 'D4 + D6' : (isD6 ? 'D6' : 'D4');
  
  // Show damage dice popup with animation
  const diceHtml = `
    <div style="text-align:center;padding:20px">
      <div style="font-size:14px;color:var(--dim);margin-bottom:15px">Rolling ${diceLabel}...</div>
      <div style="display:flex;justify-content:center;gap:15px;margin:20px 0">
        ${isFierce ? 
          `<div class="dice" id="damageDie1" style="width:60px;height:60px;font-size:42px">🎲</div>
           <div class="dice" id="damageDie2" style="width:60px;height:60px;font-size:42px">🎲</div>` :
          `<div class="dice" id="damageDie1" style="width:60px;height:60px;font-size:42px">🎲</div>`
        }
      </div>
      <div id="damageRollResult" style="font-size:14px;color:var(--gold);min-height:20px"></div>
    </div>`;
  
  openModal(`🎲 Damage Roll`, diceHtml, [{label:'Roll', fn:()=>{animateAndRollDamage(skillIdx);}}]);
}

function animateAndRollDamage(skillIdx){
  const p=cp(),c=GS.combat,e=c.enemy;
  const skills=CLASS_SKILLS[p.class]||CLASS_SKILLS.warrior;
  const sk=skills[skillIdx];
  const isD6 = sk.id === 'lightning' || sk.id === 'fireball' || sk.id === 'fierce_atk';
  const isFierce = sk.id === 'fierce_atk';
  const d4Faces = ['⚀','⚁','⚂','⚃'];
  const d6Faces = ['⚀','⚁','⚂','⚃','⚄','⚅'];
  
  // Animate dice
  let ticks = 0;
  const die1 = document.getElementById('damageDie1');
  const die2 = document.getElementById('damageDie2');
  
  if(die1) die1.classList.add('rolling');
  if(die2) die2.classList.add('rolling');
  
  const iv = setInterval(()=>{
    if(die1) die1.textContent = isFierce ? d4Faces[Math.floor(Math.random()*4)] : (isD6 ? d6Faces[Math.floor(Math.random()*6)] : d4Faces[Math.floor(Math.random()*4)]);
    if(die2) die2.textContent = d6Faces[Math.floor(Math.random()*6)];
    if(++ticks > 10){
      clearInterval(iv);
      closeModal();
      executeDamageRoll(skillIdx);
    }
  },50);
}

function executeDamageRoll(skillIdx){
  const p=cp(),c=GS.combat,e=c.enemy;
  const skills=CLASS_SKILLS[p.class]||CLASS_SKILLS.warrior;
  const sk=skills[skillIdx];
  const isD6 = sk.id === 'lightning' || sk.id === 'fireball' || sk.id === 'fierce_atk';
  const isFierce = sk.id === 'fierce_atk';
  const d4Faces = ['⚀','⚁','⚂','⚃'];
  const d6Faces = ['⚀','⚁','⚂','⚃','⚄','⚅'];
  
  // Animate dice
  let ticks = 0;
  const die1 = document.getElementById('damageDie1');
  const die2 = document.getElementById('damageDie2');
  
  if(die1) die1.classList.add('rolling');
  if(die2) die2.classList.add('rolling');
  
  const iv = setInterval(()=>{
    if(die1) die1.textContent = isFierce ? d4Faces[Math.floor(Math.random()*4)] : (isD6 ? d6Faces[Math.floor(Math.random()*6)] : d4Faces[Math.floor(Math.random()*4)]);
    if(die2) die2.textContent = d6Faces[Math.floor(Math.random()*6)];
    if(++ticks > 10){
      clearInterval(iv);
      if(die1) die1.classList.remove('rolling');
      if(die2) die2.classList.remove('rolling');
      
      // Final roll values
      let roll;
      if(isFierce){
        const d4 = Math.floor(Math.random()*4)+1;
        const d6 = Math.floor(Math.random()*6)+1;
        roll = {d4: d4, d6: d6, total: d4+d6};
        if(die1) die1.textContent = d4Faces[d4-1];
        if(die2) die2.textContent = d6Faces[d6-1];
      }else{
        roll = isD6 ? Math.floor(Math.random()*6)+1 : Math.floor(Math.random()*4)+1;
        if(die1) die1.textContent = isD6 ? d6Faces[roll-1] : d4Faces[roll-1];
      }
      
      const rollText = isFierce ? `${roll.d4} + ${roll.d6}` : roll;
      const rr = document.getElementById('damageRollResult');
      if(rr) rr.textContent = `Result: ${rollText}`;
      
      // Show damage result after short delay
      setTimeout(()=>{
        const s=calcStats(p);
        let dmg = 0;
        let dmgText = '';
        
        if(p.class === 'warrior'){
          if(sk.id === 'basic_atk'){
            dmg = roll + Math.ceil(s.str*0.5);
            dmgText = `D4:${roll} + STR:${Math.ceil(s.str*0.5)}`;
          }else if(sk.id === 'fierce_atk'){
            dmg = roll.d4 + roll.d6 + Math.floor(s.str*0.5);
            dmgText = `D4:${roll.d4} + D6:${roll.d6} + STR:${Math.floor(s.str*0.5)}`;
          }else if(sk.id === 'magic_bolt'){
            dmg = roll + Math.floor(s.int*0.5);
            dmgText = `D4:${roll} + INT:${Math.floor(s.int*0.5)}`;
          }
        }else if(p.class === 'mage'){
          if(sk.id === 'basic_atk'){
            dmg = roll + Math.floor(s.int*0.25);
            dmgText = `D4:${roll} + INT:${Math.floor(s.int*0.25)}`;
          }else if(sk.id === 'lightning' || sk.id === 'fireball'){
            dmg = roll + Math.floor(s.int*0.5);
            dmgText = `D6:${roll} + INT:${Math.floor(s.int*0.5)}`;
          }
        }else if(p.class === 'ranger'){
          dmg = roll + Math.floor(s.dex*0.5);
          dmgText = `D4:${roll} + DEX:${Math.floor(s.dex*0.5)}`;
        }else if(p.class === 'monk'){
          dmg = roll + Math.floor(s.dex*0.5) + Math.floor(s.str*0.5);
          dmgText = `D4:${roll} + DEX:${Math.floor(s.dex*0.5)} + STR:${Math.floor(s.str*0.5)}`;
        }
        
        e.hp = Math.max(0, e.hp - dmg);
        
        openModal('⚔️ Damage', 
          `<div style="text-align:center;padding:20px">
            <div style="font-size:36px;margin-bottom:10px">💥</div>
            <div style="font-size:24px;color:#f44;font-weight:bold;margin-bottom:10px">-${dmg} HP</div>
            <div style="font-size:12px;color:var(--dim)">${dmgText}</div>
            <div style="font-size:11px;color:var(--gold);margin-top:5px">Enemy HP: ${e.hp}/${e.maxHp}</div>
          </div>`,
          [{label:'OK', fn:()=>{closeModal();resolveSkill(skillIdx,isFierce?roll.total:roll,true);}}]
        );
      },400);
    }
  },60);
}

function resolveSkill(skillIdx,roll,isHit){
  const p=cp(),c=GS.combat,e=c.enemy;
  const skills=CLASS_SKILLS[p.class]||CLASS_SKILLS.warrior;
  const sk=skills[skillIdx];if(!sk)return;
  if(sk.mpCost>0)p.mp=Math.max(0,p.mp-sk.mpCost);
  
  // Fierce Attack cooldown (2 turns) - will decrement at START of next player turn
  if(sk.id === 'fierce_atk'){
    c.fierceRecharge = 2;
    c._fierceJustUsed = true; // Flag to decrement on next turn start
  }
  
  // Wolf attack
  if(c.wolf&&c.wolf.hp>0 && isHit){
    const s = calcStats(p);
    const wdmg=Math.max(1,Math.floor(s.str*.15));
    e.hp=Math.max(0,e.hp-wdmg);
    c.log.push(`🐺 Wolf bites for ${wdmg} dmg!`);
    c.wolf.turns--;if(c.wolf.turns<=0){c.wolf=null;c.log.push('🐺 Wolf departs.');}
  }
  if(isHit && (sk.kind === 'atk' || sk.kind === 'mgk')){
    spawnPtc(window.innerWidth*.64,window.innerHeight*.35,'#e05050',5);
  }
  if(e.hp<=0){combatWin();return;}
  renderCombat();
  doEnemyTurn();
  updPlayers();
}

function doEnemyTurn(){
  const p=cp(),c=GS.combat,e=c.enemy;
  // Reset Fierce Attack decrement flag for player's next turn
  c._fierceDecremented = false;
  
  const affordable=e.skills.filter(sk=>(e.mp||99)>=sk.cost);
  const sk=affordable.length?affordable[Math.floor(Math.random()*affordable.length)]:e.skills[0];
  const html=`
    <div class="mo-title">👾 ${e.name} acts!</div>
    <div class="mo-text">${e.name} uses: <strong style="color:var(--gold)">${sk.name}</strong><br><span style="font-size:10px;color:var(--dim)">${sk.desc||''}</span></div>
    <div style="text-align:center;padding:40px;">
      <div style="font-size:44px;margin-bottom:10px">⚔️</div>
      <div style="color:var(--dim);font-size:11px">Enemy attacks...</div>
    </div>`;
  openModal(null,null,[],html);
  setTimeout(()=>{
    const roll = Math.floor(Math.random() * 40) + 1;
    c.enemyRoll = roll;
    resolveEnemyAttack(sk,roll);
  },500);
}

function resolveEnemyAttack(sk,roll){
  const p=cp(),c=GS.combat,e=c.enemy;
  const playerAC=p.armorClass||12;
  const defMult=c.defending?c.tempDefMult:1.0;
  c.defending=false;c.tempDefMult=0.5;
  let dmg=0;
  if(sk.type==='buff'){
    if(sk.ac){e._buffAC = (e._buffAC || 0) + sk.ac;}
    if(sk.hp){e.hp=Math.min(e.maxHp,e.hp+sk.hp);}
    if(sk.str){e._buffStr = (e._buffStr || 0) + sk.str; e.str += sk.str;}
    c.log.push(`💪 ${e.name} uses ${sk.name}! (self buff)`);
    if(e.mp!==undefined)e.mp=Math.max(0,e.mp-(sk.cost||0));
    spawnPtc(window.innerWidth*.63,window.innerHeight*.35,'#8a4aaa',4);
  }else{
    const hits=sk.hits||1;let total=0;let hitCount=0;
    for(let h=0;h<hits;h++){
      const d4=Math.floor(Math.random()*4)+1;
      const enemyMod=e.str;
      const hitRoll=Math.floor(Math.random()*20)+1+enemyMod;
      c.log.push(`🎲 Enemy Hit: ${hitRoll} vs AC ${playerAC}`);
      if(hitRoll<playerAC){
        c.log.push(`❌ ${e.name}'s attack missed!`);
        continue;
      }
      hitCount++;
      let baseDmg=0;
      if(sk.dmg){
        baseDmg=Math.floor(e.str*sk.dmg);
      }
      const d=Math.max(1,Math.floor(baseDmg*defMult));
      total+=d;
    }
    dmg=total;
    if(sk.heal&&e)e.hp=Math.min(e.maxHp,e.hp+Math.floor(dmg*(sk.heal||0)));
    if(sk.poison){p.poison=(p.poison||0)+sk.poison;c.log.push(`☠ ${p.name} poisoned for ${sk.poison} turns!`);}
    if(sk.stun&&Math.random()<.35){p.skipTurns=1;c.log.push(`😵 ${p.name} stunned next turn!`);}
    if(e.mp!==undefined)e.mp=Math.max(0,e.mp-(sk.cost||0));
    p.hp=Math.max(0,p.hp-dmg);
    c.log.push(`${e.icon} ${e.name} — ${sk.name}: ${dmg} dmg${hits>1?` (${hitCount}/${hits} hits)`:''}${defMult<1?' [BLOCKED]':''}`);
    if(dmg>0)spawnPtc(window.innerWidth*.35,window.innerHeight*.35,'#e05050',5);
  }
  if(p.hp<=0){
    const fi=p.inventory.find(i=>i.id==='phoenix_feather'&&!i.used);
    if(fi){fi.used=true;p.hp=p.maxHp;c.log.push(`✦ Phoenix Feather! ${p.name} revives at full HP!`);spawnPtc(window.innerWidth*.35,window.innerHeight*.35,'#ff9900',14);renderCombat();return;}
    combatLose();return;
  }
  
  // Show enemy attack result with OK button
  const dmgIcon = dmg > 0 ? '⚔️' : (sk.type === 'buff' ? '✨' : '💨');
  openModal(`${e.icon} ${e.name} attacks!`, 
    `<div style="text-align:center;padding:15px">
      <div style="font-size:14px;margin-bottom:5px">Used: <strong>${sk.name}</strong></div>
      <div style="font-size:36px;margin-bottom:10px">${dmgIcon}</div>
      <div style="font-size:40px;color:${dmg > 0 ? '#ff6060' : '#60c060'};font-weight:bold">
        ${dmg > 0 ? `-${dmg} HP to ${p.name}` : (sk.type === 'buff' ? 'Buff applied!' : 'No damage')}
      </div>
      <div style="font-size:11px;color:var(--dim);margin-top:10px">Your HP: ${p.hp}/${p.maxHp}</div>
    </div>`,
    [{label:'OK', fn:()=>{closeModal();renderCombat();updPlayers();}}]
  );
}

function closeCombatFled(){
  closeModal();toast(`${cp().name} escaped!`,'good');GS.combat=null;endTurn();
}
function combatWin(){
  const p=cp(),e=GS.combat.enemy;closeModal();spawnPtc(window.innerWidth/4,window.innerHeight/4,'#f0c060',40);
  let expGain=0;
  if(e.isMiniBoss||e.isFinalBoss){
    expGain=30+Math.floor(Math.random()*20);
  }else{
    expGain=10+Math.floor(Math.random()*10);
  }
  p.exp=(p.exp||0)+expGain;
  const expNeeded=p.level*50;
  let leveledUp=false;
  if(p.exp>=expNeeded){
    p.level++;p.exp-=expNeeded;p.statPoints=(p.statPoints||0)+2;
    p.maxHp+=10;p.hp=Math.min(p.hp+10,p.maxHp);
    leveledUp=true;
    toast(`${p.name} leveled up to ${p.level}! +2 stat points, +10 HP`,'imp');
  }
  if(e.isFinalBoss){
    p.bossesDefeated++;toast(`${p.name} defeated ${e.name}! (${p.bossesDefeated}/3)`,'imp');
    if(p.bossesDefeated>=3){showVictory(p);return;}
    openModal('⚡ Final Boss Defeated!',`${e.icon} ${e.name} vanquished!\nYou claim: ${e.reward}\nBosses: ${p.bossesDefeated}/3\n+${expGain} EXP${leveledUp?' (Level '+p.level+')':''}`,[{label:'Press On!',fn:()=>{closeModal();if(leveledUp && p.statPoints > 0){showLevelUpStats(p);}else{closeEndTurn();}}}]);
  }else if(e.isMiniBoss){
    toast(`${p.name} defeated ${e.name}! +${expGain} EXP`,'good');
    const star=Math.random()<.5?3:4;
    openModal('👾 Mini Boss Defeated!',`${e.icon} ${e.name} falls!\n+${expGain} EXP${leveledUp?' (Level '+p.level+')':''}\nDraw a ${star}⭐ card!`,[{label:`Draw Card`,fn:()=>{closeModal();if(leveledUp && p.statPoints > 0){GS._pendingAfterLevelUp='drawCard';GS._pendingCardStar=star;showLevelUpStats(p);}else{drawCardReward(star);}}}]);
  }else{
    toast(`${p.name} defeated ${e.name}! +${expGain} EXP${leveledUp?' (Level '+p.level+')':''}`,'good');
    openModal('⚔️ Enemy Defeated!', 
      `<div style="text-align:center;padding:20px">
        <div style="font-size:48px;margin-bottom:10px">🏆</div>
        <div style="font-size:20px;color:#f0c060;font-weight:bold;margin-bottom:10px">VICTORY!</div>
        <div style="font-size:14px;color:var(--dim);margin-bottom:15px">${e.icon} ${e.name} defeated!</div>
        <div style="font-size:16px;color:#4f4;font-weight:bold;margin-bottom:5px">+${expGain} EXP</div>
        ${leveledUp ? `<div style="font-size:14px;color:#f0c060;font-weight:bold">🎉 LEVEL UP! Now level ${p.level}!</div>` : ''}
      </div>`,
      [{label:'Continue', fn:()=>{closeModal();if(leveledUp && p.statPoints > 0){showLevelUpStats(p);}else{closeEndTurn();}}}]
    );
  }
  
  updPlayers();
}

function showLevelUpStats(p){
  if(!p || p.statPoints <= 0){
    closeEndTurn();
    return;
  }
  
  const s = calcStats(p);
  const html = `
    <div class="panel-title">🎉 LEVEL UP!</div>
    <div style="text-align:center;margin-bottom:20px;color:var(--gold)">${p.name} is now level ${p.level}!</div>
    <div style="text-align:center;margin-bottom:15px;color:#4f4">Points to spend: ${p.statPoints}</div>
    <div style="display:flex;justify-content:center;gap:15px;margin:20px 0">
      <div style="text-align:center">
        <div style="font-size:11px;color:var(--dim)">STR</div>
        <div style="font-size:20px;color:#f44;font-weight:bold">${s.str}</div>
        <button class="s-btn" onclick="allocateStat('str')" ${p.statPoints <= 0 ? 'disabled style="opacity:0.3"' : ''}>+</button>
      </div>
      <div style="text-align:center">
        <div style="font-size:11px;color:var(--dim)">INT</div>
        <div style="font-size:20px;color:#44f;font-weight:bold">${s.int}</div>
        <button class="s-btn" onclick="allocateStat('int')" ${p.statPoints <= 0 ? 'disabled style="opacity:0.3"' : ''}>+</button>
      </div>
      <div style="text-align:center">
        <div style="font-size:11px;color:var(--dim)">DEX</div>
        <div style="font-size:20px;color:#4f4;font-weight:bold">${s.dex}</div>
        <button class="s-btn" onclick="allocateStat('dex')" ${p.statPoints <= 0 ? 'disabled style="opacity:0.3"' : ''}>+</button>
      </div>
      <div style="text-align:center">
        <div style="font-size:11px;color:var(--dim)">HP</div>
        <div style="font-size:20px;color:#f0c060;font-weight:bold">${s.hp}</div>
        <button class="s-btn" onclick="allocateStat('hp')" ${p.statPoints <= 0 ? 'disabled style="opacity:0.3"' : ''}>+</button>
      </div>
    </div>
    <div style="text-align:center;margin-top:15px">
      <button class="menu-btn" onclick="finishLevelUp()" ${p.statPoints > 0 ? 'disabled style="opacity:0.5"' : ''}>Done</button>
    </div>
  `;
  openModal(null, null, [], html);
}

function allocateStat(stat){
  const p = cp();
  if(!p || p.statPoints <= 0) return;
  
  p.statPoints--;
  if(stat === 'str') p.allocStr = (p.allocStr || 0) + 1;
  else if(stat === 'int') p.allocInt = (p.allocInt || 0) + 1;
  else if(stat === 'dex') p.allocDex = (p.allocDex || 0) + 1;
  else if(stat === 'hp'){ p.allocHp = (p.allocHp || 0) + 1; p.maxHp += 10; p.hp += 10; }
  
  showLevelUpStats(p);
  updPlayers();
}

function finishLevelUp(){
  closeModal();
  updPlayers();
  // Check if there's a pending action after level up
  if(GS._pendingAfterLevelUp){
    const action = GS._pendingAfterLevelUp;
    GS._pendingAfterLevelUp = null;
    if(action === 'drawCard'){
      drawCardReward(GS._pendingCardStar);
      GS._pendingCardStar = null;
    }else{
      closeEndTurn();
    }
  }else{
    closeEndTurn();
  }
}

function combatLose(){
  const p=cp(),e=GS.combat.enemy;closeModal();
  // Death penalties
  const lostGold=Math.floor(p.gold/4);
  p.gold=Math.max(0,p.gold-lostGold);
  p.hp=1;
  // Lose a random equipped item
  const equippedSlots=Object.entries(p.equipped||{}).filter(([slot,id])=>id!=null);
  let lostItemName='nothing';
  if(equippedSlots.length>0){
    const [slot,itemId]=equippedSlots[Math.floor(Math.random()*equippedSlots.length)];
    lostItemName=ITEMS[itemId]?.name||itemId;
    p.equipped[slot]=null;
    // Also remove from inventory
    const invIdx=p.inventory.findIndex(i=>i.id===itemId);
    if(invIdx>=0)p.inventory.splice(invIdx,1);
  }
  // Move back 14 spaces
  const prevIdx=p.tileIdx;
  p.tileIdx=Math.max(board.startTile,p.tileIdx-14);
  toast(`${p.name} defeated by ${e.name}! Lost ${lostGold} gold, ${lostItemName}, fell back ${prevIdx-p.tileIdx} spaces!`,'bad');
  openModal('💀 Defeated!',
    `${p.name} was beaten by ${e.icon} ${e.name}!\n\n` +
    `💰 Lost ${lostGold} gold (half your purse)\n` +
    `🗡️ Lost: ${lostItemName}\n` +
    `❤️ HP restored to 1\n` +
    `↩️ Moved back ${prevIdx-p.tileIdx} spaces`,
    [{label:'↩️ Limp Away...',fn:closeEndTurn}]);
  updPlayers();
}
function useConsumableInCombat(){
  const p=cp();const cons=p.inventory.filter(it=>it.type==='consumable'&&!it.used);
  if(!cons.length){renderCombat();return;}
  const html=`<div class="mo-title">🧪 Use Consumable</div><div class="mo-choices">
    ${cons.map((it,i)=>`<button class="act-btn" onclick="useCmbItem(${i})"><span style="font-size:16px">${it.icon}</span> ${it.name} — ${it.desc}</button>`).join('')}
    <button class="act-btn" onclick="renderCombat()">← Back</button>
  </div>`;
  openModal(null,null,[],html);
}
function useCmbItem(idx){
  const p=cp(),cons=p.inventory.filter(it=>it.type==='consumable'&&!it.used);
  const it=cons[idx];if(!it)return;it.used=true;
  if(it.healHp){p.hp=Math.min(p.maxHp,p.hp+it.healHp);toast(`+${it.healHp} HP!`,'good');}
  if(it.healMp){p.mp=Math.min(p.maxMp,p.mp+it.healMp);toast(`+${it.healMp} MP!`,'good');}
  updPlayers();renderCombat();
}

// ══════════════════════════════════════════════════════
//  CARD DRAWS
// ══════════════════════════════════════════════════════
function drawCardReward(star){
  const p=cp();
  const r=Math.random();let rar;
  if(star<=1)rar=r<.95?'common':'rare';
  else if(star===4)rar=r<.5?'common':'rare';
  else if(star===3)rar=r<.05?'common':r<.65?'rare':'epic';
  else if(star===4)rar=r<.01?'common':r<.11?'rare':r<.80?'epic':'legendary';
  else rar=r<.1?'epic':'legendary';
  const isExtra=Math.random()<.35;
  let pool;
  if(isExtra){pool=Object.values(ITEMS).filter(it=>(it.type==='consumable'||it.type==='accessory')&&it.rarity===rar&&it.classes.includes(p.class));}
  else{pool=Object.values(ITEMS).filter(it=>it.type!=='consumable'&&it.rarity===rar&&it.classes.includes(p.class));}
  if(!pool.length)pool=Object.values(ITEMS).filter(it=>it.rarity==='common'&&it.classes.includes(p.class));
  if(!pool.length){endTurn();return;}
  const cards=[...pool].sort(()=>Math.random()-.5).slice(0,Math.min(3,pool.length));
  GS.currentCards=cards;

  // Show face-down cards - player picks one blind
  const html=`<div class="mo-title">✦ ${star}⭐ Card Draw</div>
    <div class="card-hint">✦ Click a card to claim it (face down!) ✦</div>
    <div class="card-deck" id="cardDeck">
      ${cards.map((c,i)=>`
        <div class="card-container" id="cardCont${i}" onclick="pickCard(${i})">
          <div class="card-inner" id="cardInner${i}">
            <div class="card-back">
              <div class="card-back-pattern"></div>
              <div class="card-back-symbol">🃏</div>
              <div class="card-back-text">?</div>
            </div>
            <div class="card-face ${c.rarity}" id="cardFace${i}">
              <span style="position:absolute;top:4px;right:4px;font-size:6px;letter-spacing:1px;padding:1px 3px;text-transform:uppercase;color:${c.rarity==='legendary'?'#f0c060':c.rarity==='epic'?'#aa66ff':c.rarity==='rare'?'#4080d0':'#888'}">${c.rarity}</span>
              <div style="font-size:46px;margin:14px 0 5px">${c.icon}</div>
              <div style="font-size:8px;color:#e8d5a0;font-weight:600;margin-bottom:3px">${c.name}</div>
              <div style="font-size:7px;color:#907850;font-family:'IM Fell English',serif;line-height:1.4">${itemStatLine(c)}</div>
              <div style="font-size:7px;color:#907850;font-family:'IM Fell English',serif;margin-top:3px;font-style:italic">${c.desc||''}</div>
            </div>
          </div>
        </div>`).join('')}
    </div>`;
  openModal(null,null,[{label:'Skip Reward',fn:closeEndTurn}],html);
}

function revealCard(idx){
  const c=GS.currentCards[idx];if(!c)return;
  // Fill in the card face
  const face=document.getElementById(`cardFace${idx}`);
  if(face){
    face.className=`card-face ${c.rarity}`;
    face.innerHTML=`
      <span style="position:absolute;top:4px;right:4px;font-size:6px;letter-spacing:1px;padding:1px 3px;text-transform:uppercase;color:${c.rarity==='legendary'?'#f0c060':c.rarity==='epic'?'#aa66ff':c.rarity==='rare'?'#4080d0':'#888'}">${c.rarity}</span>
      <div style="font-size:46px;margin:14px 0 5px">${c.icon}</div>
      <div style="font-size:8px;color:#e8d5a0;font-weight:600;margin-bottom:3px">${c.name}</div>
      <div style="font-size:7px;color:#907850;font-family:'IM Fell English',serif;line-height:1.4">${itemStatLine(c)}</div>
      <div style="font-size:7px;color:#907850;font-family:'IM Fell English',serif;margin-top:3px;font-style:italic">${c.desc||''}</div>
      <div style="margin-top:8px;border-top:1px solid rgba(455,455,455,0.1);padding-top:5px">
        <button onclick="pickCard(${idx})" style="width:100%;background:rgba(440,194,96,0.15);border:1px solid #a07840;color:#f0c060;font-family:'Cinzel',serif;font-size:8px;padding:4px;cursor:pointer;letter-spacing:1px">✦ TAKE</button>
      </div>`;
  }
  // Flip the card
  const inner=document.getElementById(`cardInner${idx}`);
  if(inner)inner.classList.add('flipped');
  // Disable clicking once revealed (prevent double-flip)
  const cont=document.getElementById(`cardCont${idx}`);
  if(cont)cont.onclick=null;
}
function pickCard(idx){
  const p=cp(),c=GS.currentCards[idx];if(!c)return;
  
  // Flip the card to reveal it
  const inner=document.getElementById(`cardInner${idx}`);
  if(inner)inner.classList.add('flipped');
  
  // Fill the card face
  const face=document.getElementById(`cardFace${idx}`);
  if(face){
    face.className=`card-face ${c.rarity}`;
    face.innerHTML=`
      <span style="position:absolute;top:4px;right:4px;font-size:6px;letter-spacing:1px;padding:1px 3px;text-transform:uppercase;color:${c.rarity==='legendary'?'#f0c060':c.rarity==='epic'?'#aa66ff':c.rarity==='rare'?'#4080d0':'#888'}">${c.rarity}</span>
      <div style="font-size:46px;margin:14px 0 5px">${c.icon}</div>
      <div style="font-size:8px;color:#e8d5a0;font-weight:600;margin-bottom:3px">${c.name}</div>
      <div style="font-size:7px;color:#907850;font-family:'IM Fell English',serif;line-height:1.4">${itemStatLine(c)}</div>
      <div style="font-size:7px;color:#907850;font-family:'IM Fell English',serif;margin-top:3px;font-style:italic">${c.desc||''}</div>
      <div style="margin-top:8px;border-top:1px solid rgba(455,455,255,0.1);padding-top:5px;color:#4f4;font-weight:bold">✓ SELECTED</div>`;
  }
  
  // Disable clicking on other cards
  GS.currentCards.forEach((_,i)=>{
    const cont=document.getElementById(`cardCont${i}`);
    if(cont && i !== idx) cont.onclick=null;
  });
  
  // Wait a moment then close
  setTimeout(()=>{
    p.inventory.push({...c});toast(`${p.name} obtained ${c.name}!`,'good');
    spawnPtc(window.innerWidth/4,window.innerHeight/4,c.rarity==='legendary'?'#f0c060':c.rarity==='epic'?'#aa6aff':c.rarity==='rare'?'#4080d0':'#aaa',14);
    closeModal();endTurn();updPlayers();
  },1200);
}

// ══════════════════════════════════════════════════════
//  INVENTORY
// ══════════════════════════════════════════════════════
function openInventory(playerIdx){
  const p=GS.players[playerIdx];renderInventory(p,playerIdx);
  document.getElementById('invModal').classList.add('on');
}
function closeInv(){document.getElementById('invModal').classList.remove('on');closeModal();}

function openCharacterCard(playerIdx){
  const p=GS.players[playerIdx];
  const base = CLASSES[p.class];
  const s = calcStats(p);
  
  let bonusStr = 0, bonusInt = 0, bonusDex = 0, bonusAC = 0;
  Object.values(p.equipped || {}).forEach(itemId => {
    if(itemId){
      const it = ITEMS[itemId] || p.inventory.find(i => i.id === itemId);
      if(it){
        bonusStr += it.str || 0;
        bonusInt += it.int || 0;
        bonusDex += it.dex || 0;
        bonusAC += it.ac || 0;
      }
    }
  });
  
  const allocStr = p.allocStr||0, allocInt = p.allocInt||0, allocDex = p.allocDex||0;
  const totalBaseStr = base.str + allocStr, totalBaseInt = base.int + allocInt, totalBaseDex = base.dex + allocDex;
  const overall = Math.floor((s.str + s.int + s.dex + s.ac + (s.str+s.int+s.dex) / 3) / 4);
  
  const rarity = p.bossesDefeated === 3 ? 'legendary' : p.bossesDefeated === 4 ? 'gold' : p.bossesDefeated === 1 ? 'silver' : 'bronze';
  const cardColor = rarity === 'legendary' ? {bg:'linear-gradient(180deg,#c9a447 0%,#8b6914 50%,#5c4a1f 100%)',border:'#ffd700',glow:'#ffd700'} : rarity === 'gold' ? {bg:'linear-gradient(180deg,#d4af37 0%,#aa8c4c 50%,#7a6640 100%)',border:'#d4af37',glow:'#d4af37'} : rarity === 'silver' ? {bg:'linear-gradient(180deg,#c0c0c0 0%,#9a9a9a 50%,#6a6a6a 100%)',border:'#c0c0c0',glow:'#c0c0c0'} : {bg:'linear-gradient(180deg,#cd7f34 0%,#a66648 50%,#7a4a1e 100%)',border:'#cd7f34',glow:'#cd7f34'};
  
  let html = `
    <div style="display:flex;gap:40px;padding:40px;justify-content:center;flex-wrap:wrap">
      <div id="fifaCard" onclick="this.classList.toggle('flipped')" style="width:320px;height:480px;cursor:pointer;perspective:1000px">
        <div style="width:100%;height:100%;position:relative;transition:transform 0.6s;transform-style:preserve-3d" id="cardInner">
          <div style="position:absolute;width:100%;height:100%;backface-visibility:hidden;-webkit-backface-visibility:hidden">
            <div style="width:320px;height:480px;background:${cardColor.bg};border:4px solid ${cardColor.border};border-radius:16px;padding:12px;box-shadow:0 0 30px ${cardColor.glow}40,0 10px 40px rgba(0,0,0,0.5),inset 0 2px 0 rgba(255,255,255,0.3);position:relative;overflow:hidden;box-sizing:border-box">
              <div style="position:absolute;top:0;left:0;right:0;bottom:0;background:linear-gradient(135deg,rgba(255,255,255,0.2) 0%,transparent 50%,transparent 100%);pointer-events:none"></div>
              <div style="position:absolute;top:6px;left:6px;background:rgba(0,0,0,0.8);border-radius:4px;padding:3px 8px;border:2px solid ${cardColor.border}">
                <div style="font-size:32px;color:${cardColor.border};font-weight:900;line-height:1;text-shadow:0 2px 2px rgba(0,0,0,0.5)">${overall}</div>
                <div style="font-size:7px;color:#fff;text-align:center;font-weight:bold">OVR</div>
              </div>
              <div style="position:absolute;top:6px;right:6px;font-size:28px;text-shadow:0 2px 2px rgba(0,0,0,0.5)">${base.icon}</div>
              <div style="text-align:center;margin-top:40px;margin-bottom:4px">
                <div style="font-size:24px;color:#fff;font-weight:bold;text-shadow:0 2px 4px rgba(0,0,0,0.8)">${p.name}</div>
                <div style="font-size:9px;color:${cardColor.border};font-weight:bold;letter-spacing:1px">${base.name.toUpperCase()}</div>
              </div>
              <div style="text-align:center;margin-bottom:8px">
                <div id="charCardSprite" style="width:100px;height:100px;margin:0 auto;filter:drop-shadow(0 4px 8px rgba(0,0,0,0.6))"></div>
              </div>
              <div style="font-size:6px;color:#fff;opacity:0.5;text-align:center;margin-bottom:4px">(Click to flip)</div>
              <div style="padding:0 6px">
                <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:2px;margin-bottom:4px">
                  <div class="stat-box" style="text-align:center;padding:4px;background:rgba(0,0,0,0.5);border-radius:3px" title="STR: ${totalBaseStr} base + ${bonusStr} gear = ${s.str}">
                    <div style="font-size:14px;font-weight:bold;color:#fff">${s.str}</div>
                    <div style="font-size:5px;color:#aaa;font-weight:bold">STR</div>
                  </div>
                  <div class="stat-box" style="text-align:center;padding:4px;background:rgba(0,0,0,0.5);border-radius:3px" title="INT: ${totalBaseInt} base + ${bonusInt} gear = ${s.int}">
                    <div style="font-size:14px;font-weight:bold;color:#fff">${s.int}</div>
                    <div style="font-size:5px;color:#aaa;font-weight:bold">INT</div>
                  </div>
                  <div class="stat-box" style="text-align:center;padding:5px;background:rgba(0,0,0,0.5);border-radius:4px" title="DEX: ${totalBaseDex} base + ${bonusDex} gear = ${s.dex}">
                    <div style="font-size:16px;font-weight:bold;color:#fff">${s.dex}</div>
                    <div style="font-size:6px;color:#aaa;font-weight:bold">DEX</div>
                  </div>
                  <div class="stat-box" style="text-align:center;padding:5px;background:rgba(0,0,0,0.5);border-radius:4px" title="Armor Class">
                    <div style="font-size:16px;font-weight:bold;color:#fff">${s.ac + (p.armorClass||12)}</div>
                    <div style="font-size:6px;color:#aaa;font-weight:bold">AC</div>
                  </div>
                </div>
                <div style="display:flex;justify-content:space-between;align-items:center;padding:5px;background:rgba(0,0,0,0.5);border-radius:4px;font-size:10px">
                  <div style="display:flex;gap:3px;align-items:center">
                    <span style="color:#f55">❤</span>
                    <span style="color:#fff;font-weight:bold">${p.hp}/${p.maxHp}</span>
                  </div>
                  <div style="display:flex;gap:3px;align-items:center">
                    <span style="color:#55f">💧</span>
                    <span style="color:#fff;font-weight:bold">${p.mp}/${p.maxMp}</span>
                  </div>
                  <div style="display:flex;gap:3px;align-items:center">
                    <span style="color:#fb0">💰</span>
                    <span style="color:#fff;font-weight:bold">${p.gold}</span>
                  </div>
                </div>
              </div>
              <div style="text-align:center;margin-top:6px">
                <span style="color:${cardColor.border};font-size:10px">★</span>
                <span style="color:${cardColor.border};font-size:10px${p.bossesDefeated >= 1 ? '' : ';opacity:0.3'}">★</span>
                <span style="color:${cardColor.border};font-size:10px${p.bossesDefeated >= 4 ? '' : ';opacity:0.3'}">★</span>
                <span style="color:${cardColor.border};font-size:10px${p.bossesDefeated >= 3 ? '' : ';opacity:0.3'}">★</span>
              </div>
            </div>
          </div>
          <div style="position:absolute;width:100%;height:100%;backface-visibility:hidden;-webkit-backface-visibility:hidden;transform:rotateY(180deg)">
            <div style="width:320px;height:480px;background:linear-gradient(180deg,#1a1a4a 0%,#0a0a1a 100%);border:4px solid ${cardColor.border};border-radius:16px;padding:10px;box-shadow:0 0 30px ${cardColor.glow}40,0 10px 40px rgba(0,0,0,0.5);box-sizing:border-box;overflow:hidden">
              <div style="text-align:center;margin-bottom:4px">
                <div style="font-size:11px;color:${cardColor.border};font-weight:bold">${p.name}</div>
                <div style="font-size:7px;color:#888">${base.name}</div>
              </div>
              <div style="font-size:8px;color:#fb0;font-weight:bold;margin:4px 0 3px;text-align:center;letter-spacing:1px;border-bottom:1px solid #3a3a5a;padding-bottom:2px">📊 STATS</div>
              <div style="display:grid;gap:3px;font-size:7px">
                <div style="display:flex;justify-content:space-between;align-items:center;background:rgba(0,0,0,0.4);padding:3px;border-radius:2px;border-left:3px solid #f55">
                  <span style="color:#f55;font-weight:bold">STR</span>
                  <span style="color:#fff">${totalBaseStr}+${bonusStr}=${s.str}</span>
                </div>
                <div style="display:flex;justify-content:space-between;align-items:center;background:rgba(0,0,0,0.4);padding:3px;border-radius:2px;border-left:3px solid #55f">
                  <span style="color:#55f;font-weight:bold">INT</span>
                  <span style="color:#fff">${totalBaseInt}+${bonusInt}=${s.int}</span>
                </div>
                <div style="display:flex;justify-content:space-between;align-items:center;background:rgba(0,0,0,0.4);padding:3px;border-radius:2px;border-left:3px solid #5f5">
                  <span style="color:#5f5;font-weight:bold">DEX</span>
                  <span style="color:#fff">${totalBaseDex}+${bonusDex}=${s.dex}</span>
                </div>
                <div style="display:flex;justify-content:space-between;align-items:center;background:rgba(0,0,0,0.4);padding:3px;border-radius:2px;border-left:3px solid #f55">
                  <span style="color:#f55;font-weight:bold">AC</span>
                  <span style="color:#fff">${p.armorClass||12}+${bonusAC}=${s.ac + (p.armorClass||12)}</span>
                </div>
              </div>
              <div style="font-size:8px;color:#fb0;font-weight:bold;margin:6px 0 3px;text-align:center;letter-spacing:1px;border-bottom:1px solid #3a3a5a;padding-bottom:2px">🎒 GEAR</div>
              <div style="display:flex;flex-direction:column;gap:2px">
                ${Object.entries(p.equipped || {}).map(([slot, itemId]) => {
                  const it = itemId ? (ITEMS[itemId] || p.inventory.find(i => i.id === itemId)) : null;
                  return `<div style="background:rgba(0,0,0,0.4);padding:3px;border-radius:2px;display:flex;align-items:center;gap:4px">
                    <span style="font-size:12px">${it ? it.icon : '⬜'}</span>
                    <div style="flex:1;overflow:hidden">
                      <div style="font-size:6px;color:#888;text-transform:uppercase">${slot}</div>
                      <div style="font-size:7px;color:#ccc;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${it ? it.name : 'Empty'}</div>
                    </div>
                  </div>`;
                }).join('')}
              </div>
              <div style="text-align:center;margin-top:4px;font-size:6px;color:#666">(Click to flip back)</div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <style>
      .stat-box:hover { background: rgba(455,455,455,0.4) !important; transform: scale(1.05); }
      #fifaCard.flipped #cardInner { transform: rotateY(180deg); }
    </style>
    <button class="act-btn pri" style="width:auto;padding:10px 40px;margin:10px auto;display:block;font-size:14px" onclick="closeInv()">Close</button>
  `;
  document.getElementById('invBox').innerHTML = html;
  document.getElementById('invModal').classList.add('on');
  
  const spriteContainer = document.getElementById('charCardSprite');
  if(spriteContainer){
    const sprite = renderSprite(p.class, 100, p.color || base.color);
    spriteContainer.appendChild(sprite);
  }
}
function openSkills(playerIdx){
  const p = GS.players[playerIdx];
  const base = CLASSES[p.class];
  const skills = CLASS_SKILLS[p.class] || CLASS_SKILLS.warrior;
  
  let html = `
    <div class="mo-title" style="font-size:16px">✨ Skills: ${p.name}</div>
    <div style="display:flex;flex-wrap:wrap;gap:15px;padding:15px;justify-content:center;max-width:600px;margin:0 auto">
      ${skills.map(sk => `
        <div style="background:rgba(6,10,6,.97);border:4px solid var(--gold);border-radius:8px;padding:15px;min-width:180px;text-align:center">
          <div style="font-size:48px;margin-bottom:8px">${sk.icon}</div>
          <div style="font-size:14px;color:var(--gold);font-weight:bold;margin-bottom:5px">${sk.name}</div>
          <div style="font-size:11px;color:#907850;font-family:'IM Fell English',serif;margin-bottom:8px">${sk.desc}</div>
          <div style="font-size:11px;color:#6080ff">${sk.mpCost > 0 ? sk.mpCost + ' MP Cost' : 'Free to use'}</div>
        </div>
      `).join('')}
    </div>
    <button class="act-btn pri" style="width:auto;padding:8px 30px;margin:15px auto;display:block" onclick="closeInv()">Close</button>
  `;
  document.getElementById('invBox').innerHTML = html;
  document.getElementById('invModal').classList.add('on');
}
function renderInventory(p,pi){
  const s=calcStats(p);
  const slotNames={weapon:'⚔️ Weapon',head:'🪖 Head',body:'🛡️ Body',feet:'👢 Feet',accessory:'💍 Accsr'};
  const equippedItems=Object.entries(p.equipped||{}).map(([slot,id])=>{
    const it=id?ITEMS[id]||p.inventory.find(i=>i.id===id):null;return{slot,it};
  });
  const html=`
    <div class="mo-title">📦 ${p.name}'s Inventory</div>
    <div style="font-size:9px;color:var(--dim);text-align:center;margin-bottom:10px">
      STR:${s.str} INT:${s.int} DEX:${s.dex} AC:${p.armorClass||12} · 💰${p.gold}
    </div>
    <div class="inv-layout">
      <div class="inv-left">
        <div class="sb-ttl">BAG (${p.inventory.filter(i=>!i.used).length} items)</div>
        <div class="inv-grid">
          ${p.inventory.filter(i=>!i.used).map((it,i)=>`
            <div class="inv-slot ${p.equipped&&Object.values(p.equipped).includes(it.id)?'equipped':''}" onclick="invItemAction(${pi},${i})">
              ${it.icon}
              <div class="ctip"><strong>${it.name}</strong> <span style="color:var(--dim)">[${it.rarity}]</span><br>${it.desc||''}<br>${itemStatLine(it)}<br><br><em style="color:var(--gold)">${it.slot?'Click to equip':'Click to use'}</em></div>
            </div>`).join('')}
          ${p.inventory.filter(i=>!i.used).length===0?'<div style="font-size:9px;color:var(--dim);grid-column:1/-1;padding:6px">Empty bag</div>':''}
        </div>
      </div>
      <div class="inv-right">
        <div class="sb-ttl">EQUIPPED</div>
        <div class="equip-slots">
          ${equippedItems.map(({slot,it})=>`
            <div class="eq-slot ${it?'filled':''}" onclick="${it?`unequip(${pi},'${slot}')`:''}" title="${it?'Click to unequip':'Empty slot'}">
              <span class="eq-icon">${it?it.icon:'　'}</span>
              <div style="font-size:7px;color:var(--dim)">${slotNames[slot]}</div>
              ${it?`<div class="stat-preview">${itemStatLine(it).split(' · ').slice(0,4).join(' · ')}</div><div class="ctip"><strong>${it.name}</strong><br>${it.desc||''}<br>${itemStatLine(it)}<br><em style="color:var(--red-l)">Click to unequip</em></div>`:''}
            </div>`).join('')}
        </div>
        <div style="margin-top:8px;font-size:9px;color:var(--dim)">Bosses: ${[0,1,4].map(j=>`<span style="font-size:14px;${j<p.bossesDefeated?'filter:none':'filter:grayscale(1);opacity:.3'}">💀</span>`).join('')}</div>
      </div>
    </div>
    <div style="display:flex;gap:6px;margin-top:14px;justify-content:center">
      <button class="act-btn pri" style="width:auto;padding:6px 40px" onclick="closeInv()">Close</button>
    </div>`;
  document.getElementById('invBox').innerHTML=html;
}
function invItemAction(pi,itemIdx){
  const p=GS.players[pi];const vis=p.inventory.filter(i=>!i.used);const it=vis[itemIdx];if(!it)return;
  if(it.type==='consumable'){
    if(it.healHp){p.hp=Math.min(p.maxHp,p.hp+it.healHp);toast(`${p.name} used ${it.name}! +${it.healHp} HP`,'good');}
    if(it.healMp){p.mp=Math.min(p.maxMp,p.mp+it.healMp);toast(`${p.name} used ${it.name}! +${it.healMp} MP`,'good');}
    it.used=true;
  }else if(it.slot){
    const prev=p.equipped[it.slot];
    if(prev===it.id){p.equipped[it.slot]=null;toast(`${p.name} unequipped ${it.name}`);}
    else{p.equipped[it.slot]=it.id;toast(`${p.name} equipped ${it.name}!`);}
  }
  updPlayers();renderInventory(p,pi);
}
function unequip(pi,slot){
  const p=GS.players[pi];const id=p.equipped[slot];if(!id)return;
  const it=ITEMS[id]||p.inventory.find(i=>i.id===id);
  p.equipped[slot]=null;toast(`${p.name} unequipped ${it?.name||slot}.`);
  updPlayers();renderInventory(p,pi);
}

// ══════════════════════════════════════════════════════
//  HELPERS
// ══════════════════════════════════════════════════════
function itemStatLine(it){
  const parts=[];
  if(it.str)parts.push(`STR+${it.str}`);
  if(it.int)parts.push(`INT+${it.int}`);
  if(it.dex)parts.push(`DEX+${it.dex}`);
  if(it.ac)parts.push(`AC+${it.ac}`);
  if(it.spd)parts.push(`SPD+${it.spd}`);
  if(it.hp)parts.push(`HP+${it.hp}`);
  if(it.mp)parts.push(`MP+${it.mp}`);
  if(it.healHp)parts.push(`Heal ${it.healHp}HP`);
  if(it.healMp)parts.push(`Heal ${it.healMp}MP`);
  if(it.rollBonus)parts.push(`+${it.rollBonus} Dice`);
  if(it.revive)parts.push('Revive 1×');
  return parts.join(' · ')||'—';
}
function endTurn(){
  GS.phase='roll';GS.highlightedTiles=[];GS.combat=null;
  const order=GS.initOrder,pos=order.indexOf(GS.curP);
  GS.curP=order[(pos+1)%order.length];
  if((pos+1)%order.length===0)GS.turn++;
  updPlayers();renderActs();startTurn();
}
function closeEndTurn(){closeModal();endTurn();}
function setBanner(t){document.getElementById('turnBanner').textContent=t;}
function updPlayers(){
  const c=document.getElementById('playersList');if(!c)return;
  c.innerHTML=GS.players.map((p,i)=>{
    const pct=Math.max(0,Math.min(100,p.hp/p.maxHp*100));
    const mpct=Math.max(0,Math.min(100,p.mp/p.maxMp*100));
    const isCur=i===GS.curP;const cls=CLASSES[p.class];
    const sk=[0,1,4].map(j=>`<span class="skull${j<p.bossesDefeated?' on':''}">💀</span>`).join('');
    const curs=(p.curses||{});
    const curseHtml=Object.entries(curs).filter(([k,v])=>v>0).map(([k,v])=>{
      const icon={suffocate:'💨',blindness:'👁️',paralysis:'⚡'}[k]||'❓';
      const name=k.charAt(0).toUpperCase()+k.slice(1);
      return `<span class="curse-badge" title="${name}: ${v} turn(s)">${icon}</span>`;
    }).join('');
    const expPct=p.level?Math.min(100,(p.exp||0)/(p.level*50)*100):0;
    return `<div class="pi-card${isCur?' cur':''}">
      <div class="pi-btns">
        <button class="pi-btn" onclick="event.stopPropagation();openCharacterCard(${i})" title="Character Card">Summary</button>
        <button class="pi-btn" onclick="event.stopPropagation();openSkills(${i})" title="Skills">Skills</button>
        <button class="pi-btn" onclick="event.stopPropagation();openInventory(${i})" title="Inventory">Inventory</button>
      </div>
      <div class="pi-name" onclick="openInventory(${i})">${cls.icon} ${p.name}${isCur?' ◀':''}</div>
      <div class="pi-cls">${cls.name} Lv.${p.level||1} · ${p.gold}💰 ${p.statPoints>0?'⭐'+p.statPoints:''} ${curseHtml}</div>
      <div class="pi-bar"><div class="pi-fill pi-hp-fill" style="width:${pct}%"></div></div>
      <div class="pi-bar"><div class="pi-fill pi-mp-fill" style="width:${mpct}%"></div></div>
      <div class="pi-bar"><div class="pi-fill" style="width:${expPct}%;background:linear-gradient(90deg,#a06000,#d09000)"></div></div>
      <div class="pi-stats"><span>HP:<span class="pi-sv">${p.hp}/${p.maxHp}</span></span><span>MP:<span class="pi-sv">${p.mp}/${p.maxMp}</span></span><span>AC:<span class="pi-sv">${p.armorClass||12}</span></span><span>EXP:<span class="pi-sv">${p.exp||0}/${p.level*50}</span></div>
      <div class="skulls">${sk}</div>
    </div>`;
  }).join('');
}
function renderActs(){
  const c=document.getElementById('actionBtns');if(!c)return;
  if(GS.phase==='roll'){c.innerHTML=`<button class="act-btn pri" onclick="rollDice()">🎲 Roll Dice</button>`;}
  else if(GS.phase==='move'){c.innerHTML=`<div style="font-size:8px;color:var(--dim);text-align:center;padding:4px">Click a highlighted tile<br><span style="color:var(--gold)">${GS.diceVal} moves — drag to pan</span></div>`;}
  else{c.innerHTML=`<div style="font-size:8px;color:var(--dim);text-align:center;font-style:italic;padding:4px">Resolving...</div>`;}
}
function toast(msg,type=''){
  const el=document.getElementById('gameToast');if(!el)return;
  const col=type==='imp'?'#f0c060':type==='bad'?'#e05050':type==='good'?'#40a060':'#907850';
  el.style.color=col;el.textContent=msg;el.style.display='block';el.style.opacity='1';
  clearTimeout(el._t);el._t=setTimeout(()=>{el.style.opacity='0';setTimeout(()=>{el.style.display='none';},400);},4600);
}
function openModal(title,text,choices,rawHtml){
  const box=document.getElementById('modalBox');
  if(rawHtml){
    box.innerHTML=rawHtml;
    if(choices?.length){const d=document.createElement('div');d.className='mo-choices';d.style.marginTop='10px';choices.forEach(c=>{const b=document.createElement('button');b.className='act-btn pri';b.textContent=c.label;b.onclick=c.fn;d.appendChild(b);});box.appendChild(d);}
  }else{
    box.innerHTML=`<div class="mo-title">${title||''}</div><div class="mo-text">${(text||'').replace(/\n/g,'<br>')}</div><div class="mo-choices">${(choices||[]).map(c=>`<button class="act-btn pri">${c.label}</button>`).join('')}</div>`;
    box.querySelectorAll('.act-btn.pri').forEach((b,i)=>{if(choices?.[i])b.onclick=choices[i].fn;});
  }
  document.getElementById('modal').classList.add('on');
}

// ══════════════════════════════════════════════════════
//  CARD SELECTION - Face-down cards, player picks, then reveal
// ══════════════════════════════════════════════════════
let pendingCardSelection = null;

function showCardSelection(cards, onSelect){
  if(!cards || cards.length === 0){
    onSelect(null);
    return;
  }
  
  pendingCardSelection = { cards, onSelect };
  
  const cardHtml = cards.map((card, idx) => `
    <div class="route-card face-down" data-idx="${idx}" onclick="selectRouteCard(${idx})">
      <div class="card-back">🃏</div>
      <div class="card-front" style="display:none">
        <div class="rc-icon">${card.icon}</div>
        <div class="rc-title">${card.title}</div>
        <div class="rc-type">${card.type}</div>
      </div>
    </div>
  `).join('');
  
  const mb = document.getElementById('modalBox');
  mb.innerHTML = `
    <div class="mo-title">Choose Your Path</div>
    <div class="mo-text">Select one of the following events:</div>
    <div class="route-card-grid">${cardHtml}</div>
  `;
  document.getElementById('modal').classList.add('on');
}

function selectRouteCard(idx){
  const { cards, onSelect } = pendingCardSelection;
  const selectedCard = cards[idx];
  
  // Reveal animation - flip all cards
  const cardEls = document.querySelectorAll('.route-card');
  cardEls.forEach((el, i) => {
    if(i === idx){
      el.classList.add('selected');
      el.querySelector('.card-back').style.display = 'none';
      el.querySelector('.card-front').style.display = 'block';
      el.style.borderColor = 'var(--gold)';
      el.style.boxShadow = '0 0 20px rgba(240,192,96,0.5)';
    }else{
      el.style.opacity = '0.4';
    }
  });
  
  // Execute after short delay for reveal effect
  setTimeout(() => {
    document.getElementById('modal').classList.remove('on');
    pendingCardSelection = null;
    onSelect(selectedCard);
  }, 800);
}

// Show merchant in card selection context
function showMerchant(){
  const p = cp();
  openModal('🐪 Wandering Merchant','The merchant shows you wares.',[
    {label:'Buy HP Potion (30g)',fn:()=>{if(p.gold>=30){p.gold-=30;p.inventory.push(ITEMS.hp_potion);closeModal();toast('Bought HP Potion!','good');closeEndTurn();}else{toast('Not enough gold!','bad');}}},
    {label:'Buy MP Potion (30g)',fn:()=>{if(p.gold>=30){p.gold-=30;p.inventory.push(ITEMS.mana_potion);closeModal();toast('Bought MP Potion!','good');closeEndTurn();}else{toast('Not enough gold!','bad');}}},
    {label:'Leave',fn:()=>{closeModal();closeEndTurn();}}
  ]);
}

function closeModal(){document.getElementById('modal').classList.remove('on');document.getElementById('modalBox').innerHTML='';}
function showVictory(p){
  closeModal();
  const el=document.createElement('div');
  el.style.cssText='position:fixed;inset:0;background:rgba(0,0,0,.93);z-index:999;display:flex;align-items:center;justify-content:center';
  el.innerHTML=`<div class="victory-wrap"><div class="v-title">✦ VICTORY ✦</div>
    <div style="font-family:'IM Fell English',serif;font-size:17px;color:var(--text);margin-bottom:14px">${CLASSES[p.class].icon} ${p.name} has defeated 3 Final Bosses!</div>
    <div style="font-size:14px;color:var(--dim);margin-bottom:44px;font-family:'IM Fell English',serif;font-style:italic">The Enchanted Path is conquered. The realm is saved!</div>
    <div style="font-size:46px;margin-bottom:18px">💀💀💀</div>
    <button class="start-btn" onclick="location.reload()">⟶ Play Again</button></div>`;
  document.body.appendChild(el);
  setInterval(()=>spawnPtc(Math.random()*window.innerWidth,Math.random()*window.innerHeight,'#f0c060',8),450);
}
function spawnPtc(cx,cy,color,n){
  for(let i=0;i<n;i++){const el=document.createElement('div');el.className='ptc';const a=(Math.random()*360)*Math.PI/180,d=40+Math.random()*80;el.style.cssText=`left:${cx}px;top:${cy}px;width:${3+Math.random()*4}px;height:${3+Math.random()*4}px;background:${color};--dx:${Math.cos(a)*d}px;--dy:${Math.sin(a)*d-48}px;animation-duration:${.55+Math.random()*.6}s`;document.body.appendChild(el);setTimeout(()=>el.remove(),1400);}
}
function showDamageNumber(damage, isPlayerDamage = false){
  const modal = document.getElementById('modal');
  const dmgEl = document.createElement('div');
  dmgEl.style.cssText = `
    position: fixed;
    left: 50%;
    top: 40%;
    transform: translate(-50%, -50%);
    font-size: 48px;
    font-weight: bold;
    color: ${isPlayerDamage ? '#ff4040' : '#40ff40'};
    text-shadow: 4px 4px 4px rgba(0,0,0,0.8);
    animation: dmgFloat 1s ease-out forwards;
    z-index: 1000;
    pointer-events: none;
  `;
  dmgEl.textContent = `-${damage}`;
  document.body.appendChild(dmgEl);
  setTimeout(() => dmgEl.remove(), 1000);
}
const dmgStyle = document.createElement('style');
dmgStyle.textContent = `@keyframes dmgFloat{0%{transform:translate(-50%,-50%) scale(0.5);opacity:1}100%{transform:translate(-50%,-100%) scale(1.5);opacity:0}}`;
document.head.appendChild(dmgStyle);

// Preload character images
['warrior','mage','ranger','monk'].forEach(cls => {
  const img = new Image();
  img.src = 'assets/' + cls + '.png';
});

window.addEventListener('resize',()=>{initBg();if(board.tiles.length){resizeBoard();drawBoard();}});
initBg();drawBg();renderForms();
document.getElementById('loadGameBtn').addEventListener('click',()=>loadGame());
</script>
</body>
</html>
